<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Routes).Assembly"
            AdditionalAssemblies="AssembliesUtil.GetBlazorAssemblies()">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(ESC.CONCOST.WebApp.Components.Layout.AppShellLayout)">
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
            </AuthorizeRouteView>
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(ESC.CONCOST.WebApp.Components.Layout.AppShellLayout)">
                <Error404 />
            </LayoutView>
        </NotFound>
       @*  <Navigating>
            <Loading LoadingText="Nạp module .." />
        </Navigating> *@
    </Router>
</CascadingAuthenticationState>
