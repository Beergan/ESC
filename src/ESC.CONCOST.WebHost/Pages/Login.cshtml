@page "/login"
@model ESC.CONCOST.WebHost.Pages.LoginModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="ko">
@{
    if ((User.Identity?.IsAuthenticated ?? false) == true)
    {
        Response.Redirect("/");
    }
}
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>로그인 — ESC 물가변동 조정 관리</title>

    <link rel="icon" type="image/png" href="assets/img/img3.png">
    <link rel="stylesheet" href="assets/bootstrap/5.1.3/css/bootstrap.min.css" />
    <link href="~/assets/font-awesome/5.15.1/css/all.min.css" rel="stylesheet" />
    <link href="~/assets/app.css" rel="stylesheet" />

    <style>
        /* ── Design Tokens ── */
        :root {
            --accent:          rgb(30, 41, 59);
            --accent-dark:     #d4751a;
            --accent-light:    #fef3e8;
            --accent-gradient: linear-gradient(135deg, rgb(30, 41, 59) 0%, #e8751a 60%, #d4630e 100%);
            --navy:            #1e3a5f;
            --navy-dark:       #0d2137;
            --navy-mid:        #162d4a;
            --navy-gradient:   linear-gradient(135deg, #1e3a5f 0%, #0d2137 60%, #162d4a 100%);
            --accent-glow:     0 8px 32px rgba(30, 58, 95, .35);
            --bg:              #f4f6f9;
            --text-dark:       #1d1d1f;
            --text-muted:      #6b6b73;
            --radius:          20px;
            --shadow-card:     0 20px 60px rgba(0, 0, 0, .10);
            --shadow-btn:      0 6px 20px rgba(30, 58, 95, .40);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Noto Sans', 'Noto Sans KR', system-ui, sans-serif;
            font-size: 13px;
            font-weight: 600;
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            align-items: stretch;
            overflow: hidden;
        }

        /* ── LEFT BRAND PANEL ── */
        .brand-panel {
            width: 45%;
            min-height: 100vh;
            background: var(--navy-gradient);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 48px 52px;
            position: relative;
            overflow: hidden;
        }

        .brand-panel::before {
            content: '';
            position: absolute;
            width: 420px; height: 420px;
            border-radius: 50%;
            border: 60px solid rgba(255,255,255,.08);
            top: -120px; right: -120px;
        }

        .brand-panel::after {
            content: '';
            position: absolute;
            width: 280px; height: 280px;
            border-radius: 50%;
            border: 48px solid rgba(255,255,255,.06);
            bottom: -60px; left: -80px;
        }

        .brand-circle-mid {
            position: absolute;
            width: 160px; height: 160px;
            border-radius: 50%;
            background: rgba(255,255,255,.07);
            bottom: 180px; right: 40px;
        }

        .brand-top { position: relative; z-index: 2; }

        .brand-logo-wrap {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 60px;
        }

        .brand-logo-wrap img {
            height: 40px;
            filter: brightness(0) invert(1);
            opacity: .95;
        }

        .brand-logo-wrap .brand-name {
            font-size: 18px;
            font-weight: 800;
            color: #fff;
            letter-spacing: -.3px;
        }

        .brand-tagline {
            font-size: 36px;
            font-weight: 900;
            color: #fff;
            line-height: 1.15;
            letter-spacing: -.5px;
            margin-bottom: 20px;
        }

        .brand-tagline span {
            display: block;
            opacity: .65;
            font-size: 22px;
            font-weight: 600;
        }

        .brand-desc {
            font-size: 13.5px;
            color: rgba(255,255,255,.75);
            line-height: 1.7;
            max-width: 340px;
            font-weight: 500;
        }

        /* Feature pills */
        .feature-list {
            display: flex;
            flex-direction: column;
            gap: 14px;
            position: relative;
            z-index: 2;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(255,255,255,.12);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,.18);
            border-radius: 14px;
            padding: 12px 16px;
            color: #fff;
            font-size: 12.5px;
            font-weight: 700;
            transition: background .2s;
        }

        .feature-item:hover { background: rgba(255,255,255,.18); }

        .feature-item i {
            width: 32px; height: 32px;
            border-radius: 10px;
            background: rgba(255,255,255,.20);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }

        .brand-bottom {
            position: relative;
            z-index: 2;
            color: rgba(255,255,255,.5);
            font-size: 11px;
            font-weight: 500;
        }

        /* ── RIGHT FORM PANEL ── */
        .form-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 24px;
            background: var(--bg);
            background-image:
                radial-gradient(circle at 85% 15%, rgba(240,138,36,.07) 0%, transparent 50%),
                radial-gradient(circle at 10% 85%, rgba(240,138,36,.05) 0%, transparent 50%);
            position: relative;
            overflow: hidden auto;
        }

        /* Language picker */
        .lang-switcher { position: absolute; top: 28px; right: 28px; }

        .lang-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            background: #fff;
            border: 1px solid rgba(0,0,0,.09);
            border-radius: 50rem;
            padding: 7px 14px;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-dark);
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,0,0,.06);
            transition: box-shadow .2s;
        }

        .lang-btn:hover { box-shadow: 0 4px 14px rgba(0,0,0,.10); }

        .lang-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            background: #fff;
            border: 1px solid rgba(0,0,0,.07);
            border-radius: 16px;
            padding: 8px;
            min-width: 150px;
            box-shadow: 0 10px 30px rgba(0,0,0,.10);
            z-index: 100;
        }

        .lang-dropdown.open { display: block; }

        .lang-option {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 9px 12px;
            border-radius: 10px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-dark);
            transition: background .15s;
        }

        .lang-option:hover { background: var(--accent-light); color: var(--accent); }
        .lang-option.active { background: var(--navy-gradient); color: #fff; }

        /* Login Card */
        .login-card {
            background: #fff;
            border-radius: var(--radius);
            box-shadow: var(--shadow-card);
            border: 1px solid rgba(0,0,0,.06);
            padding: 44px 40px 36px;
            width: 100%;
            max-width: 420px;
            animation: slideUp .5s cubic-bezier(.22,1,.36,1) both;
            visibility: hidden;
        }

        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(28px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .login-header { text-align: center; margin-bottom: 32px; }

        .login-icon {
            width: 64px; height: 64px;
            background: var(--navy-gradient);
            border-radius: 20px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            color: #fff;
            margin-bottom: 20px;
            box-shadow: var(--accent-glow);
        }

        .login-title {
            font-size: 22px;
            font-weight: 900;
            color: var(--text-dark);
            letter-spacing: -.4px;
            margin-bottom: 6px;
        }

        .login-subtitle {
            font-size: 12.5px;
            color: var(--text-muted);
            font-weight: 500;
        }

        /* Form Inputs */
        .field-group { margin-bottom: 18px; }

        .field-label {
            display: block;
            font-size: 11.5px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 7px;
            text-transform: uppercase;
            letter-spacing: .6px;
        }

        .input-wrap { position: relative; }

        .input-wrap .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 14px;
            pointer-events: none;
            transition: color .2s;
        }

        .form-input {
            width: 100%;
            border: 1.5px solid rgba(0,0,0,.10);
            border-radius: 14px;
            padding: 12px 14px 12px 42px;
            font-size: 13px;
            font-weight: 600;
            font-family: inherit;
            color: var(--text-dark);
            background: #fafafa;
            outline: none;
            transition: border-color .2s, box-shadow .2s, background .2s;
        }

        .form-input::placeholder { color: #aaa; font-weight: 500; }

        .form-input:focus {
            border-color: var(--navy);
            background: #fff;
            box-shadow: 0 0 0 4px rgba(30,58,95,.10);
        }

        .form-input:focus ~ .input-icon,
        .input-wrap:focus-within .input-icon { color: var(--navy); }

        /* Password toggle */
        .pw-toggle {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-muted);
            font-size: 14px;
            padding: 2px;
            transition: color .2s;
        }

        .pw-toggle:hover { color: var(--accent); }

        /* Remember + Forgot */
        .remember-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
        }

        .remember-label {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-dark);
            user-select: none;
        }

        .remember-label input[type="checkbox"] {
            width: 16px; height: 16px;
            accent-color: var(--accent);
            border-radius: 5px;
            cursor: pointer;
        }

        .forgot-link {
            font-size: 12px;
            font-weight: 700;
            color: var(--accent);
            text-decoration: none;
        }

        .forgot-link:hover { text-decoration: underline; }

        /* Login Button */
        .btn-login {
            width: 100%;
            padding: 14px;
            background: var(--navy-gradient);
            border: none;
            border-radius: 14px;
            color: #fff;
            font-size: 14px;
            font-weight: 800;
            font-family: inherit;
            cursor: pointer;
            box-shadow: var(--shadow-btn);
            transition: transform .15s, box-shadow .15s, filter .15s;
            letter-spacing: .2px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 20px;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(30,58,95,.45);
            filter: brightness(1.08);
        }

        .btn-login:active { transform: translateY(0); box-shadow: var(--shadow-btn); }
        .btn-login.loading .btn-text { display: none; }
        .btn-login .btn-spinner { display: none; }
        .btn-login.loading .btn-spinner { display: inline-block; }

        /* Error message */
        .error-msg {
            display: none;
            background: #fff0f0;
            border: 1px solid #ffd5d5;
            border-radius: 12px;
            padding: 10px 14px;
            font-size: 12px;
            font-weight: 600;
            color: #c0392b;
            margin-bottom: 16px;
            align-items: center;
            gap: 8px;
        }

        .error-msg.show { display: flex; }

        /* Footer hint */
        .login-footer {
            text-align: center;
            margin-top: 20px;
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
        }

        .login-footer a {
            color: var(--navy);
            font-weight: 800;
            text-decoration: none;
        }

        .login-footer a:hover { text-decoration: underline; }

        /* Spinner */
        @@keyframes spin { to { transform: rotate(360deg); } }

        .spinner {
            width: 18px; height: 18px;
            border: 2.5px solid rgba(255,255,255,.4);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .7s linear infinite;
            display: inline-block;
        }

        /* Feature item animations */
        .feature-item:nth-child(1) { animation: fadeRight .5s .15s both; }
        .feature-item:nth-child(2) { animation: fadeRight .5s .28s both; }
        .feature-item:nth-child(3) { animation: fadeRight .5s .40s both; }

        @@keyframes fadeRight {
            from { opacity: 0; transform: translateX(-18px); }
            to   { opacity: 1; transform: translateX(0); }
        }

        /* Responsive */
        @@media (max-width: 900px) {
            .brand-panel { display: none; }
            .form-panel  { padding: 32px 16px; }
            .login-card  { padding: 36px 24px 28px; }
        }

        @@media (max-width: 480px) {
            .login-card  { padding: 28px 18px 22px; }
            .login-title { font-size: 20px; }
            .lang-switcher { top: 16px; right: 16px; }
        }
    </style>
</head>

<body>

    <!-- ═══════════════ LEFT — BRAND PANEL ═══════════════ -->
    <aside class="brand-panel">
        <div class="brand-circle-mid"></div>

        <div class="brand-top">
            <div class="brand-logo-wrap">
                <img class="img-fluid" alt="logo" height="40" title="logo" src="/assets/images/favicon-.png" />
                <span class="brand-name">ESC 물가변동 조정 관리</span>
            </div>

            <div class="brand-tagline">
                전문적인 가격 조정<br>
                <span>관리 시스템</span>
            </div>

            <p class="brand-desc">
                건설 계약 물가변동 조정을 위한 전문 플랫폼 —
                Kd 계산, 지수 관리, PDF 보고서 자동 생성까지
                하나의 시스템에서 관리하세요.
            </p>
        </div>

        <div class="feature-list">
            <div class="feature-item">
                <i class="fa-solid fa-chart-line"></i>
                자동화된 데이터 분석
            </div>
            <div class="feature-item">
                <i class="fa-regular fa-clock"></i>
                실시간 가격 변동 추적
            </div>
            <div class="feature-item">
                <i class="fa-regular fa-file-lines"></i>
                효율적인 문서 관리
            </div>
        </div>

        <div class="brand-bottom">
            © 2026 ESC CON-COST System. All rights reserved.
        </div>
    </aside>

    <!-- ═══════════════ RIGHT — FORM PANEL ═══════════════ -->
    <main class="form-panel">

        <!-- Language Switcher: KO (primary) / EN (secondary) -->
        <div class="lang-switcher" id="langSwitcher">
            <button class="lang-btn" id="langBtn" onclick="toggleLang()">
                <span id="langFlag">🇰🇷</span>
                <span id="langName">한국어</span>
                <i class="fa-solid fa-chevron-down" style="font-size:10px; opacity:.6;"></i>
            </button>
            <div class="lang-dropdown" id="langDropdown">
                <div class="lang-option" data-lang="ko" onclick="setLang('ko')">🇰🇷 한국어</div>
                <div class="lang-option" data-lang="en" onclick="setLang('en')">🇬🇧 English</div>
            </div>
        </div>

        <!-- Login Card -->
        <form method="post" class="login-card" id="loginCard">

            <!-- Header -->
            <div class="login-header">
                <img class="img-fluid" alt="logo" style="height:75px!important" title="logo" src="/assets/images/favicon-.png" />
                <h1 class="login-title" data-i18n="login_title">시스템 로그인</h1>
                <p class="login-subtitle" data-i18n="login_subtitle">계정 정보를 입력해 주세요</p>
            </div>

            <!-- Error -->
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState["error"]?.Errors.Count > 0)
            {
                <div class="error-msg show" id="errorMsg">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span id="errorText">@ViewData.ModelState["error"].Errors[0].ErrorMessage</span>
                </div>
            }
            else
            {
                <div class="error-msg" id="errorMsg">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span id="errorText"></span>
                </div>
            }

            <!-- Email -->
            <div class="field-group">
                <label class="field-label" data-i18n="login_id_label">이메일 주소</label>
                <div class="input-wrap">
                    <input type="email" name="UserId" class="form-input" id="inputId"
                           placeholder="email@company.com"
                           data-i18n-placeholder="login_id_placeholder"
                           autocomplete="email" required>
                    <i class="fa-regular fa-envelope input-icon"></i>
                </div>
            </div>

            <!-- Password -->
            <div class="field-group">
                <label class="field-label" data-i18n="login_pw_label">비밀번호</label>
                <div class="input-wrap">
                    <input type="password" name="Password" class="form-input" id="inputPw"
                           placeholder="••••••••"
                           autocomplete="current-password" required>
                    <i class="fa-solid fa-lock input-icon"></i>
                    <button class="pw-toggle" type="button" onclick="togglePw()" tabindex="-1">
                        <i class="fa-regular fa-eye" id="pwEye"></i>
                    </button>
                </div>
            </div>

            <!-- Remember + Forgot -->
            <div class="remember-row">
                <label class="remember-label">
                    <input type="checkbox" id="rememberMe">
                    <span data-i18n="login_remember">로그인 상태 유지</span>
                </label>
                <a href="#" class="forgot-link" data-i18n="login_forgot">비밀번호 찾기</a>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn-login" id="btnLogin" onclick="showLoading()">
                <span class="btn-text">
                    <i class="fa-solid fa-arrow-right-to-bracket"></i>
                    <span data-i18n="login_btn">로그인</span>
                </span>
                <span class="btn-spinner">
                    <span class="spinner"></span>
                </span>
            </button>

            <!-- Register Link -->
            <div class="login-footer">
                <span data-i18n="login_no_account">계정이 없으신가요?</span>
                &nbsp;<a href="/esc-register" data-i18n="login_register">회원가입</a>
            </div>

        </form>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        /* ── i18n dictionary (KO primary / EN secondary) ── */
        const T = {
            ko: {
                login_title:          '시스템 로그인',
                login_subtitle:       '계정 정보를 입력해 주세요',
                login_id_label:       '이메일 주소',
                login_id_placeholder: 'email@company.com',
                login_pw_label:       '비밀번호',
                login_remember:       '로그인 상태 유지',
                login_forgot:         '비밀번호 찾기',
                login_btn:            '로그인',
                login_no_account:     '계정이 없으신가요?',
                login_register:       '회원가입',
                error_wrong:          '아이디 또는 비밀번호가 올바르지 않습니다.',
            },
            en: {
                login_title:          'System Login',
                login_subtitle:       'Please enter your account information',
                login_id_label:       'Email Address',
                login_id_placeholder: 'email@company.com',
                login_pw_label:       'Password',
                login_remember:       'Remember me',
                login_forgot:         'Forgot password?',
                login_btn:            'Sign In',
                login_no_account:     "Don't have an account?",
                login_register:       'Sign Up',
                error_wrong:          'Incorrect email or password.',
            },
        };

        const langMeta = {
            ko: { flag: '🇰🇷', name: '한국어' },
            en: { flag: '🇬🇧', name: 'English' },
        };

        /* ── Apply language ── */
        function applyLang(lang) {
            if (!T[lang]) lang = 'ko';
            localStorage.setItem('selectedLang', lang);

            const dict = T[lang];

            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (dict[key] !== undefined) el.textContent = dict[key];
            });

            document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
                const key = el.getAttribute('data-i18n-placeholder');
                if (dict[key] !== undefined) el.placeholder = dict[key];
            });

            document.getElementById('langFlag').textContent = langMeta[lang].flag;
            document.getElementById('langName').textContent = langMeta[lang].name;

            document.querySelectorAll('.lang-option').forEach(opt => {
                opt.classList.toggle('active', opt.dataset.lang === lang);
            });

            document.documentElement.lang = lang;
        }

        /* ── Language dropdown ── */
        function toggleLang() {
            document.getElementById('langDropdown').classList.toggle('open');
        }

        function setLang(lang) {
            applyLang(lang);
            document.getElementById('langDropdown').classList.remove('open');
        }

        document.addEventListener('click', e => {
            if (!document.getElementById('langSwitcher').contains(e.target)) {
                document.getElementById('langDropdown').classList.remove('open');
            }
        });

        /* ── Password toggle ── */
        function togglePw() {
            const inp = document.getElementById('inputPw');
            const eye = document.getElementById('pwEye');
            if (inp.type === 'password') {
                inp.type = 'text';
                eye.className = 'fa-regular fa-eye-slash';
            } else {
                inp.type = 'password';
                eye.className = 'fa-regular fa-eye';
            }
        }

        /* ── Submit loading state ── */
        function showLoading() {
            const id = document.getElementById('inputId').value.trim();
            const pw = document.getElementById('inputPw').value;
            if (id && pw) {
                document.getElementById('btnLogin').classList.add('loading');
            }
        }

        /* ── Init: apply saved language before showing card (prevents FOUT) ── */
        (function init() {
            const saved = localStorage.getItem('selectedLang') || 'ko';
            applyLang(saved);
            document.getElementById('loginCard').style.visibility = 'visible';
        })();
    </script>
</body>
</html>
