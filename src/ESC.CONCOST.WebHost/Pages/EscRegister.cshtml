@page "/esc-register"
@model ESC.CONCOST.WebHost.Pages.EscRegisterModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="ko">
@{
    if ((User.Identity?.IsAuthenticated ?? false) == true)
    {
        Response.Redirect("/");
    }
}
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>회원 가입 — ESC 물가변동 조정 관리</title>

    <link rel="icon" type="image/png" href="assets/img/img3.png">
    <link rel="stylesheet" href="assets/bootstrap/5.1.3/css/bootstrap.min.css" />
    <link href="~/assets/font-awesome/5.15.1/css/all.min.css" rel="stylesheet" />
    <link href="~/assets/app.css" rel="stylesheet" />

    <style>
        /* ── Design Tokens (ESC Navy theme — identical to login) ── */
        :root {
            --navy:            #1e3a5f;
            --navy-dark:       #0d2137;
            --navy-mid:        #162d4a;
            --accent:          rgb(30, 41, 59);
            --accent-dark:     #d4751a;
            --accent-light:    #fef3e8;
            --accent-gradient: linear-gradient(135deg, rgb(30, 41, 59) 0%, #e8751a 60%, #d4630e 100%);
            --navy-gradient:   linear-gradient(135deg, #1e3a5f 0%, #0d2137 60%, #162d4a 100%);
            --bg:              #f4f6f9;
            --text-dark:       #1d1d1f;
            --text-muted:      #6b6b73;
            --radius:          20px;
            --shadow-card:     0 20px 60px rgba(0,0,0,.10);
            --shadow-btn:      0 6px 20px rgba(30,58,95,.40);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Noto Sans', 'Noto Sans KR', system-ui, sans-serif;
            font-size: 13px;
            font-weight: 600;
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            align-items: stretch;
            overflow: hidden;
        }

        /* ── LEFT BRAND PANEL ── */
        .brand-panel {
            width: 45%;
            min-height: 100vh;
            background: var(--navy-gradient);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 48px 52px;
            position: relative;
            overflow: hidden;
        }

        .brand-panel::before {
            content: '';
            position: absolute;
            width: 420px; height: 420px;
            border-radius: 50%;
            border: 60px solid rgba(255,255,255,.08);
            top: -120px; right: -120px;
        }

        .brand-panel::after {
            content: '';
            position: absolute;
            width: 280px; height: 280px;
            border-radius: 50%;
            border: 48px solid rgba(255,255,255,.06);
            bottom: -60px; left: -80px;
        }

        .brand-circle-mid {
            position: absolute;
            width: 160px; height: 160px;
            border-radius: 50%;
            background: rgba(255,255,255,.07);
            bottom: 180px; right: 40px;
        }

        .brand-top { position: relative; z-index: 2; }

        .brand-logo-wrap {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 60px;
        }

        .brand-logo-wrap img {
            height: 40px;
            filter: brightness(0) invert(1);
            opacity: .95;
        }

        .brand-logo-wrap .brand-name {
            font-size: 18px;
            font-weight: 800;
            color: #fff;
            letter-spacing: -.3px;
        }

        .brand-tagline {
            font-size: 36px;
            font-weight: 900;
            color: #fff;
            line-height: 1.15;
            letter-spacing: -.5px;
            margin-bottom: 20px;
        }

        .brand-tagline span {
            display: block;
            opacity: .65;
            font-size: 22px;
            font-weight: 600;
        }

        .brand-desc {
            font-size: 13.5px;
            color: rgba(255,255,255,.75);
            line-height: 1.7;
            max-width: 340px;
            font-weight: 500;
        }

        /* Feature pills */
        .feature-list {
            display: flex;
            flex-direction: column;
            gap: 14px;
            position: relative;
            z-index: 2;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(255,255,255,.12);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,.18);
            border-radius: 14px;
            padding: 12px 16px;
            color: #fff;
            font-size: 12.5px;
            font-weight: 700;
            transition: background .2s;
        }

        .feature-item:hover { background: rgba(255,255,255,.18); }

        .feature-item i {
            width: 32px; height: 32px;
            border-radius: 10px;
            background: rgba(255,255,255,.20);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }

        .brand-bottom {
            position: relative;
            z-index: 2;
            color: rgba(255,255,255,.5);
            font-size: 11px;
            font-weight: 500;
        }

        /* ── RIGHT FORM PANEL ── */
        .form-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 24px;
            background: var(--bg);
            background-image:
                radial-gradient(circle at 85% 15%, rgba(240,138,36,.07) 0%, transparent 50%),
                radial-gradient(circle at 10% 85%, rgba(240,138,36,.05) 0%, transparent 50%);
            position: relative;
            overflow: hidden auto;
        }

        /* Language switcher — identical markup pattern as login */
        .lang-switcher { position: absolute; top: 28px; right: 28px; }

        .lang-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            background: #fff;
            border: 1px solid rgba(0,0,0,.09);
            border-radius: 50rem;
            padding: 7px 14px;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-dark);
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,0,0,.06);
            transition: box-shadow .2s;
        }

        .lang-btn:hover { box-shadow: 0 4px 14px rgba(0,0,0,.10); }

        .lang-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            background: #fff;
            border: 1px solid rgba(0,0,0,.07);
            border-radius: 16px;
            padding: 8px;
            min-width: 150px;
            box-shadow: 0 10px 30px rgba(0,0,0,.10);
            z-index: 100;
        }

        .lang-dropdown.open { display: block; }

        .lang-option {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 9px 12px;
            border-radius: 10px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-dark);
            transition: background .15s;
        }

        .lang-option:hover { background: var(--accent-light); color: var(--accent); }
        .lang-option.active { background: var(--navy-gradient); color: #fff; }

        /* Register Card */
        .register-card {
            background: #fff;
            border-radius: var(--radius);
            box-shadow: var(--shadow-card);
            border: 1px solid rgba(0,0,0,.06);
            padding: 40px 40px 32px;
            width: 100%;
            max-width: 460px;
            animation: slideUp .5s cubic-bezier(.22,1,.36,1) both;
            visibility: hidden;
        }

        /* Success card has no FOUT issue — always visible */
        .register-card.success-card { visibility: visible; }

        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(28px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .card-header-area { margin-bottom: 28px; }

        .card-title {
            font-size: 20px;
            font-weight: 900;
            color: var(--text-dark);
            letter-spacing: -.4px;
            margin-bottom: 4px;
        }

        .card-subtitle {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
        }

        /* Step indicator */
        .step-bar {
            display: flex;
            gap: 6px;
            margin-bottom: 28px;
        }

        .step-dot {
            height: 4px;
            border-radius: 99px;
            flex: 1;
            background: rgba(0,0,0,.08);
            transition: background .3s;
        }

        .step-dot.active { background: var(--navy); }
        .step-dot.done   { background: var(--accent); }

        /* Section labels */
        .section-label {
            font-size: 10.5px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .8px;
            color: var(--navy);
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(30,58,95,.12);
        }

        /* Form fields */
        .field-group { margin-bottom: 16px; }

        .field-label {
            display: block;
            font-size: 11.5px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .input-wrap { position: relative; }

        .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 13px;
            pointer-events: none;
            transition: color .2s;
        }

        .form-input {
            width: 100%;
            border: 1.5px solid rgba(0,0,0,.10);
            border-radius: 12px;
            padding: 11px 12px 11px 40px;
            font-size: 13px;
            font-weight: 600;
            font-family: inherit;
            color: var(--text-dark);
            background: #fafafa;
            outline: none;
            transition: border-color .2s, box-shadow .2s, background .2s;
        }

        .form-input::placeholder { color: #bbb; font-weight: 400; }

        .form-input:focus {
            border-color: var(--navy);
            background: #fff;
            box-shadow: 0 0 0 4px rgba(30,58,95,.10);
        }

        .input-wrap:focus-within .input-icon { color: var(--navy); }

        /* Password toggle */
        .pw-toggle {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-muted);
            font-size: 13px;
            padding: 2px;
            transition: color .2s;
        }

        .pw-toggle:hover { color: var(--navy); }

        /* Alert box */
        .alert-box {
            display: none;
            border-radius: 12px;
            padding: 10px 14px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 16px;
            align-items: center;
            gap: 8px;
        }

        .alert-box.show  { display: flex; }
        .alert-box.error { background: #fff0f0; border: 1px solid #ffd5d5; color: #c0392b; }

        /* Submit button */
        .btn-submit {
            width: 100%;
            padding: 13px;
            background: var(--navy-gradient);
            border: none;
            border-radius: 13px;
            color: #fff;
            font-size: 14px;
            font-weight: 800;
            font-family: inherit;
            cursor: pointer;
            box-shadow: var(--shadow-btn);
            transition: transform .15s, box-shadow .15s, filter .15s;
            letter-spacing: .2px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 16px;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(30,58,95,.45);
            filter: brightness(1.08);
        }

        .btn-submit:active  { transform: translateY(0); }
        .btn-submit:disabled { opacity: .65; cursor: not-allowed; transform: none; }
        .btn-submit .btn-spinner { display: none; }
        .btn-submit.loading .btn-text { display: none; }
        .btn-submit.loading .btn-spinner { display: inline-block; }

        @@keyframes spin { to { transform: rotate(360deg); } }

        .spinner {
            width: 16px; height: 16px;
            border: 2.5px solid rgba(255,255,255,.4);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .7s linear infinite;
            display: inline-block;
        }

        /* Footer link */
        .login-link {
            text-align: center;
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
        }

        .login-link a {
            color: var(--navy);
            font-weight: 800;
            text-decoration: none;
        }

        .login-link a:hover { text-decoration: underline; }

        /* Feature item animations */
        .feature-item:nth-child(1) { animation: fadeRight .5s .15s both; }
        .feature-item:nth-child(2) { animation: fadeRight .5s .28s both; }
        .feature-item:nth-child(3) { animation: fadeRight .5s .40s both; }

        @@keyframes fadeRight {
            from { opacity: 0; transform: translateX(-18px); }
            to   { opacity: 1; transform: translateX(0); }
        }

        /* Responsive */
        @@media (max-width: 900px) {
            .brand-panel  { display: none; }
            .form-panel   { padding: 32px 16px; }
            .register-card { padding: 32px 22px 26px; }
        }

        @@media (max-width: 480px) {
            .register-card { padding: 28px 18px 22px; }
            .lang-switcher { top: 16px; right: 16px; }
        }
    </style>
</head>

<body>

    <!-- ═══ LEFT — BRAND PANEL ═══ -->
    <aside class="brand-panel">
        <div class="brand-circle-mid"></div>

        <div class="brand-top">
            <div class="brand-logo-wrap">
                <img class="img-fluid" alt="logo" height="40" title="logo" src="/assets/images/favicon-.png" />
                <span class="brand-name">ESC 물가변동 조정 관리</span>
            </div>

            <div class="brand-tagline">
                전문적인 가격 조정<br>
                <span>관리 시스템</span>
            </div>

            <p class="brand-desc">
                건설 계약 물가변동 조정을 위한 전문 플랫폼 —
                Kd 계산, 지수 관리, PDF 보고서 자동 생성까지
                하나의 시스템에서 관리하세요.
            </p>
        </div>

        <div class="feature-list">
            <div class="feature-item">
                <i class="fa-solid fa-chart-line"></i>
                자동화된 데이터 분석
            </div>
            <div class="feature-item">
                <i class="fa-regular fa-clock"></i>
                실시간 가격 변동 추적
            </div>
            <div class="feature-item">
                <i class="fa-regular fa-file-lines"></i>
                효율적인 문서 관리
            </div>
        </div>

        <div class="brand-bottom">
            © 2026 ESC CON-COST System. All rights reserved.
        </div>
    </aside>

    <!-- ═══ RIGHT — FORM PANEL ═══ -->
    <main class="form-panel">

        <!-- Language Switcher — same structure as login -->
        <div class="lang-switcher" id="langSwitcher">
            <button type="button" class="lang-btn" id="langBtn" onclick="toggleLang()">
                <span id="langFlag">🇰🇷</span>
                <span id="langName">한국어</span>
                <i class="fa-solid fa-chevron-down" style="font-size:10px; opacity:.6;"></i>
            </button>
            <div class="lang-dropdown" id="langDropdown">
                <div class="lang-option" data-lang="ko" onclick="setLang('ko')">🇰🇷 한국어</div>
                <div class="lang-option" data-lang="en" onclick="setLang('en')">🇬🇧 English</div>
            </div>
        </div>

        @if (Model.IsSuccess)
        {
            <!-- SUCCESS STATE -->
            <div class="register-card success-card" style="text-align:center; padding:52px 40px;">
                <div style="font-size:3.5rem; margin-bottom:20px;">✅</div>
                <h2 style="font-size:20px; font-weight:900; color:#1a7a40; margin-bottom:10px;">
                    회원가입 완료!
                </h2>
                <p style="font-size:13px; color:var(--text-muted); line-height:1.7; margin-bottom:28px;">
                    계정이 성공적으로 등록되었습니다.<br>
                    관리자 검토 후 이메일로 승인 여부를 알려드립니다.
                </p>
                <p style="font-size:12px; color:var(--text-muted);">
                    이미 승인된 경우 바로 로그인하세요.
                </p>
                <a href="/login" style="display:inline-block; margin-top:20px; padding:12px 32px;
                   background:var(--navy-gradient); color:#fff; border-radius:12px;
                   font-weight:800; font-size:13px; text-decoration:none;
                   box-shadow:0 6px 20px rgba(30,58,95,.30);">
                    로그인 하기
                </a>
            </div>
        }
        else
        {
            <form method="post" class="register-card" id="registerForm">
                @Html.AntiForgeryToken()

                <!-- Header -->
                <div class="card-header-area">
                    <div class="card-title" data-i18n="reg_title">계정 정보 입력</div>
                    <div class="card-subtitle" data-i18n="reg_subtitle">회원가입 후 관리자 승인이 필요합니다</div>
                </div>

                <!-- Step indicator -->
            

                <!-- Error message -->
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState["error"]?.Errors.Count > 0)
                {
                    <div class="alert-box error show">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span>@ViewData.ModelState["error"].Errors[0].ErrorMessage</span>
                    </div>
                }
                else
                {
                    <div class="alert-box error" id="errorMsg">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span id="errorText"></span>
                    </div>
                }

                <!-- Section 1: Company Info -->
                <div class="section-label">
                    <i class="fa-solid fa-building"></i>
                    <span data-i18n="reg_section_company">회사 정보</span>
                </div>

                <div class="field-group">
                    <label class="field-label" for="CompanyName">
                        <span data-i18n="reg_company_label">회사명</span> <span style="color:#e74c3c">*</span>
                    </label>
                    <div class="input-wrap">
                        <i class="fa-solid fa-building input-icon"></i>
                        <input type="text" name="CompanyName" id="CompanyName"
                               class="form-input"
                               placeholder="주식회사 건설 ABC"
                               data-i18n-placeholder="reg_company_ph"
                               value="@Model.CompanyName"
                               required maxlength="255" />
                    </div>
                </div>

                <div class="field-group">
                    <label class="field-label" for="CeoName">
                        <span data-i18n="reg_ceo_label">성명</span> <span style="color:#e74c3c">*</span>
                    </label>
                    <div class="input-wrap">
                        <i class="fa-solid fa-user input-icon"></i>
                        <input type="text" name="CeoName" id="CeoName"
                               class="form-input"
                               placeholder="홍길동"
                               data-i18n-placeholder="reg_ceo_ph"
                               value="@Model.CeoName"
                               required maxlength="100" />
                    </div>
                </div>

                <div class="field-group">
                    <label class="field-label" for="BusinessLicense">
                        <span data-i18n="reg_biz_label">사업자 등록 번호</span>
                    </label>
                    <div class="input-wrap">
                        <i class="fa-solid fa-id-card input-icon"></i>
                        <input type="text" name="BusinessLicense" id="BusinessLicense"
                               class="form-input"
                               placeholder="000-00-00000"
                               data-i18n-placeholder="reg_biz_ph"
                               value="@Model.BusinessLicense"
                               maxlength="50" />
                    </div>
                </div>

                <!-- Section 2: Login Info -->
                <div class="section-label" style="margin-top:4px;">
                    <i class="fa-solid fa-lock"></i>
                    <span data-i18n="reg_section_login">로그인 정보</span>
                </div>

                <div class="field-group">
                    <label class="field-label" for="Email">
                        <span data-i18n="reg_email_label">이메일 주소</span> <span style="color:#e74c3c">*</span>
                    </label>
                    <div class="input-wrap">
                        <i class="fa-regular fa-envelope input-icon"></i>
                        <input type="email" name="Email" id="Email"
                               class="form-input"
                               placeholder="email@company.com"
                               data-i18n-placeholder="reg_email_ph"
                               value="@Model.Email"
                               required maxlength="255"
                               autocomplete="email" />
                    </div>
                </div>

                <div class="field-group">
                    <label class="field-label" for="Password">
                        <span data-i18n="reg_pw_label">비밀번호</span> <span style="color:#e74c3c">*</span>
                    </label>
                    <div class="input-wrap">
                        <i class="fa-solid fa-lock input-icon"></i>
                        <input type="password" name="Password" id="Password"
                               class="form-input"
                               placeholder="6자 이상 입력하세요"
                               data-i18n-placeholder="reg_pw_ph"
                               required minlength="6"
                               autocomplete="new-password" />
                        <button type="button" class="pw-toggle" onclick="togglePw('Password','eyePw1')" tabindex="-1">
                            <i class="fa-regular fa-eye" id="eyePw1"></i>
                        </button>
                    </div>
                </div>

                <div class="field-group">
                    <label class="field-label" for="PasswordConfirm">
                        <span data-i18n="reg_pw2_label">비밀번호 확인</span> <span style="color:#e74c3c">*</span>
                    </label>
                    <div class="input-wrap">
                        <i class="fa-solid fa-lock input-icon"></i>
                        <input type="password" name="PasswordConfirm" id="PasswordConfirm"
                               class="form-input"
                               placeholder="비밀번호를 다시 입력하세요"
                               data-i18n-placeholder="reg_pw2_ph"
                               required minlength="6"
                               autocomplete="new-password" />
                        <button type="button" class="pw-toggle" onclick="togglePw('PasswordConfirm','eyePw2')" tabindex="-1">
                            <i class="fa-regular fa-eye" id="eyePw2"></i>
                        </button>
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn-submit" id="btnSubmit">
                    <span class="btn-spinner"><span class="spinner"></span></span>
                    <span class="btn-text">
                        <i class="fa-solid fa-user-plus"></i>&nbsp;
                        <span data-i18n="reg_btn">회원가입</span>
                    </span>
                </button>

                <div class="login-link">
                    <span data-i18n="reg_have_account">이미 계정이 있으신가요?</span>
                    &nbsp;<a href="/login" data-i18n="reg_login_link">로그인</a>
                </div>

            </form>
        }

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        /* ── i18n dictionary (KO primary / EN secondary) ── */
        const TR = {
            ko: {
                reg_title:           '계정 정보 입력',
                reg_subtitle:        '회원가입 후 관리자 승인이 필요합니다',
                reg_section_company: '회사 정보',
                reg_company_label:   '회사명',
                reg_company_ph:      '주식회사 건설 ABC',
                reg_ceo_label:       '성명',
                reg_ceo_ph:          '홍길동',
                reg_biz_label:       '사업자 등록 번호',
                reg_biz_ph:          '000-00-00000',
                reg_section_login:   '로그인 정보',
                reg_email_label:     '이메일 주소',
                reg_email_ph:        'email@company.com',
                reg_pw_label:        '비밀번호',
                reg_pw_ph:           '6자 이상 입력하세요',
                reg_pw2_label:       '비밀번호 확인',
                reg_pw2_ph:          '비밀번호를 다시 입력하세요',
                reg_btn:             '회원가입',
                reg_have_account:    '이미 계정이 있으신가요?',
                reg_login_link:      '로그인',
                reg_pw_mismatch:     '비밀번호가 일치하지 않습니다.',
            },
            en: {
                reg_title:           'Create Account',
                reg_subtitle:        'Registration requires admin approval',
                reg_section_company: 'Company Information',
                reg_company_label:   'Company Name',
                reg_company_ph:      'ABC Construction Co., Ltd.',
                reg_ceo_label:       'Full Name',
                reg_ceo_ph:          'John Doe',
                reg_biz_label:       'Business Registration No.',
                reg_biz_ph:          '000-00-00000',
                reg_section_login:   'Login Information',
                reg_email_label:     'Email Address',
                reg_email_ph:        'email@company.com',
                reg_pw_label:        'Password',
                reg_pw_ph:           'Minimum 6 characters',
                reg_pw2_label:       'Confirm Password',
                reg_pw2_ph:          'Re-enter your password',
                reg_btn:             'Sign Up',
                reg_have_account:    'Already have an account?',
                reg_login_link:      'Sign In',
                reg_pw_mismatch:     'Passwords do not match.',
            },
        };

        const langMeta = {
            ko: { flag: '🇰🇷', name: '한국어' },
            en: { flag: '🇬🇧', name: 'English' },
        };

        /* ── Apply language — same function signature as login ── */
        function applyLang(lang) {
            if (!TR[lang]) lang = 'ko';
            localStorage.setItem('selectedLang', lang);

            const dict = TR[lang];

            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (dict[key] !== undefined) el.textContent = dict[key];
            });

            document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
                const key = el.getAttribute('data-i18n-placeholder');
                if (dict[key] !== undefined) el.placeholder = dict[key];
            });

            document.getElementById('langFlag').textContent = langMeta[lang].flag;
            document.getElementById('langName').textContent = langMeta[lang].name;

            document.querySelectorAll('.lang-option').forEach(opt => {
                opt.classList.toggle('active', opt.dataset.lang === lang);
            });

            document.documentElement.lang = lang;
        }

        /* ── Language dropdown — same pattern as login ── */
        function toggleLang() {
            document.getElementById('langDropdown').classList.toggle('open');
        }

        function setLang(lang) {
            applyLang(lang);
            document.getElementById('langDropdown').classList.remove('open');
        }

        document.addEventListener('click', e => {
            if (!document.getElementById('langSwitcher').contains(e.target)) {
                document.getElementById('langDropdown').classList.remove('open');
            }
        });

        /* ── Password toggle ── */
        function togglePw(inputId, iconId) {
            const inp = document.getElementById(inputId);
            const ico = document.getElementById(iconId);
            if (inp.type === 'password') {
                inp.type = 'text';
                ico.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                inp.type = 'password';
                ico.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        /* ── Client-side validation & loading state ── */
        document.getElementById('registerForm')?.addEventListener('submit', function (e) {
            const pw     = document.getElementById('Password').value;
            const cpw    = document.getElementById('PasswordConfirm').value;
            const err    = document.getElementById('errorMsg');
            const errTxt = document.getElementById('errorText');
            const lang   = localStorage.getItem('selectedLang') || 'ko';

            if (pw !== cpw) {
                e.preventDefault();
                errTxt.textContent = TR[lang].reg_pw_mismatch;
                err.classList.add('show');
                return;
            }
            err?.classList.remove('show');
            const btn = document.getElementById('btnSubmit');
            btn.classList.add('loading');
            btn.disabled = true;
            document.getElementById('dot1').classList.add('done');
            document.getElementById('dot2').classList.add('active');
        });

        /* ── Init: apply saved language before showing card (prevents FOUT) ── */
        (function init() {
            const saved = localStorage.getItem('selectedLang') || 'ko';
            applyLang(saved);
            const card = document.getElementById('registerForm');
            if (card) card.style.visibility = 'visible';
        })();
    </script>
</body>
</html>
