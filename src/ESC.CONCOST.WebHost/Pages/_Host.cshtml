@page "/"
@namespace ESC.CONCOST.WebApp.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ESC.CONCOST.WebApp

@{
    Layout = null;
}
@{
    if ((User.Identity?.IsAuthenticated ?? false) == false)
    {
        Response.Redirect("/login");
    }

    //string blazorMode = HttpContext.Request.Cookies[nameof(blazorMode)] ?? "wasm";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>HRM [v@(ESC.CONCOST.WebHost.AutoClass.FullVersion) @ESC.CONCOST.WebHost.AutoClass.BuildName]</title>

    <meta name="description" content=" - Giải pháp quản lý trung tâm đào tạo du học" />
    <meta name="keywords" content="phan mem, quan ly trung tam dao tao du hoc, dien toan dam may" />
    <meta property="og:title" content=" - Quản lý trung tâm đào tạo du học" />
    <meta property="og:image" content="~/assets/images/logo_.png" />
    <meta property="og:description" content=".vn - Giải pháp quản lý trung tâm đào tạo du học" />

    <base href="~/" />
    <link rel="icon" href="~/assets/images/favicon-.png" />
    <link rel="mask-icon" href="~/assets/images/favicon-.png" />
    <link rel="icon" sizes="16x16" href="~/assets/images/favicon-.png" />
    <link rel="icon" sizes="192x192" href="~/assets/images/favicon-.png" />
    @* Google Font: Noto Sans (matches UI Prototype design) *@
    <link rel="stylesheet" href="_content/MudBlazor/MudBlazor.min.css" />
    <link rel="stylesheet" href="assets/bootstrap/5.1.3/css//bootstrap.min.css" />
    <link rel="stylesheet" href="assets/font-awesome/5.15.1/css/all.css" />
    @* Font Awesome 6 – required for new icons used in header navbar *@
    <link href="~/assets/font-awesome/5.15.1/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="assets/app.css" />
       <link rel="stylesheet" href="assets/style.css" />
</head>
<body>
    <div id="app">
        <component type="typeof(App)" render-mode="ServerPrerendered" />
    </div>
    <script src="_framework/blazor.server.js" autostart="false"></script>
 
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="assets/jquery/jquery-3.5.1.min.js"></script>
    <script src="assets/bootstrap/5.1.3/js/bootstrap.bundle.min.js"></script>
    <script src="assets/sweetalert2/sweetalert2.js"></script>
    <script src="assets/sweetalert2/sweetalert2-blazor.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="assets/app.js?v=1.1"></script>
    <script src="js/upload_helper.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrious/4.0.2/qrious.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script>
        window.addEventListener('pageshow', function (event) {
            if (event.persisted) {
                window.location.reload();
            }
        });

        Blazor.start({
            configureSignalR: function (builder) {
                builder.withServerTimeout(60 * 60 * 1000);
                builder.withKeepAliveInterval(30 * 1000);
            },
            circuit: {
                reconnectionOptions: {
                    maxRetries: 120,
                    retryIntervalMilliseconds: function (previousAttempts) {
                        return Math.min(1000 * Math.max(previousAttempts, 1), 10000);
                    }
                }
            }
        });

        function initDraggableModals() {
            const observer = new MutationObserver(function (mutations) {
                mutations.forEach(function (mutation) {
                    mutation.addedNodes.forEach(function (node) {
                        if (node.nodeType === 1) {
                            const modals = node.matches && node.matches('.modal') ? [node] : node.querySelectorAll('.modal');
                            modals.forEach(makeDraggable);
                        }
                    });
                });
            });

            observer.observe(document.body, { childList: true, subtree: true });
            document.querySelectorAll('.modal').forEach(makeDraggable);
        }

        function makeDraggable(modal) {
            if (modal.dataset.draggableInitialized) return;
            modal.dataset.draggableInitialized = 'true';

            const header = modal.querySelector('.modal-header');
            const dialog = modal.querySelector('.modal-dialog');
            const content = modal.querySelector('.modal-content');

            if (!header || !dialog || !content) return;

            let isDragging = false;
            let offsetX = 0;
            let offsetY = 0;
            let startX = 0;
            let startY = 0;

            // Giới hạn cố định - chỉ tính 1 lần khi bắt đầu kéo
            let minX = -9999, maxX = 9999, minY = -9999, maxY = 9999;

            const updateBounds = () => {
                const rect = content.getBoundingClientRect();
                minX = -rect.left + 20;                           // Cách trái + lề 20px
                maxX = window.innerWidth - rect.right - 20;       // Cách phải + lề 20px
                minY = -rect.top + 20;                            // Cách trên
                maxY = window.innerHeight - rect.bottom - 20;     // Cách dưới
            };

            const onDragStart = (e) => {
                if (e.target.closest('.close, button[aria-label="Close"]')) return;

                updateBounds(); // Chỉ tính bounds 1 lần khi bắt đầu kéo

                startX = e.clientX - offsetX;
                startY = e.clientY - offsetY;
                isDragging = true;
                document.body.style.overflow = 'hidden';
            };

            const onDragMove = (e) => {
                if (!isDragging) return;
                e.preventDefault();

                let newX = e.clientX - startX;
                let newY = e.clientY - startY;

                // Áp dụng giới hạn (rất nhanh vì không tính rect)
                newX = Math.max(minX, Math.min(maxX, newX));
                newY = Math.max(minY, Math.min(maxY, newY));

                offsetX = newX;
                offsetY = newY;

                dialog.style.transform = `translate(${newX}px, ${newY}px)`;
            };

            const onDragEnd = () => {
                isDragging = false;
                document.body.style.overflow = '';
            };

            const resetPosition = () => {
                dialog.style.transform = 'translate(0px, 0px)';
                offsetX = 0;
                offsetY = 0;
            };

            // Khi resize cửa sổ → cập nhật lại vị trí nếu đang ra ngoài
            const handleResize = () => {
                if (!modal.classList.contains('show')) return;
                updateBounds();
                offsetX = Math.max(minX, Math.min(maxX, offsetX));
                offsetY = Math.max(minY, Math.min(maxY, offsetY));
                dialog.style.transform = `translate(${offsetX}px, ${offsetY}px)`;
            };

            // Attach events
            header.addEventListener('mousedown', onDragStart);
            document.addEventListener('mousemove', onDragMove);
            document.addEventListener('mouseup', onDragEnd);
            modal.addEventListener('shown.bs.modal', resetPosition);
            window.addEventListener('resize', handleResize);

            // Reset nếu modal đang mở khi script chạy
            if (modal.classList.contains('show')) {
                resetPosition();
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initDraggableModals);
        } else {
            initDraggableModals();
        }
    </script>
</body>
</html>
