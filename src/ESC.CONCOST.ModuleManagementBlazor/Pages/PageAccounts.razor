@code {
    private const string AccountFilterAll = "All";
    private const string AccountFilterNotCreated = "NotCreated";
    private const string AccountFilterLocked = "Locked";

    private IEnumerable<ModelAccountListItem> _dataSource = new List<ModelAccountListItem>();
    private string _accountFilter = AccountFilterAll;
    private OptionItem<Guid>? _selectedPermissionRole;
    private ModelUserAccount _modelEdit = new();
    private ModelPasswordChange _modelPwdChange = new();
    private bool _showPassword = false;
    private List<OptionItem<Guid>> _optRoles = new();

    private ModalComponent _modalEdit = default!;
    private ModalComponent _modalPwd = default!;

    private bool _checkPermissionAdmin;
    private bool _isLoading;
    private string _modalEditTitle = string.Empty;
    private void OnPermissionRoleChanged(OptionItem<Guid>? role)
    {
        _selectedPermissionRole = role;
        _modelEdit.GuidPrimissions = role?.Value ?? Guid.Empty;
    }
    private IEnumerable<ModelAccountListItem> FilteredAccounts
    {
        get
        {
            if (_accountFilter == AccountFilterAll)
            {
                return _dataSource;
            }

            if (_accountFilter == AccountFilterNotCreated)
            {
                return _dataSource.Where(x => !x.HasUser);
            }

            if (_accountFilter == AccountFilterLocked)
            {
                return _dataSource.Where(x => x.HasUser && x.Active == false);
            }

            return _dataSource.Where(x => x.AccountType == _accountFilter);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _checkPermissionAdmin = await _svc.CheckPermissionAdmin();

        if (_checkPermissionAdmin)
        {
            await ResetData();
        }
    }

    private async Task ResetData()
    {
        try
        {
            _isLoading = true;

            var rsp = await AppStatic.CallApi(() => _svc.GetListAccounts());

            if (!rsp.Success)
            {
                _ = swal.Error(rsp.Message);
                return;
            }

            _dataSource = rsp.Items ?? new List<ModelAccountListItem>();

            var rsp2 = await AppStatic.CallApi(() => _svc.GetListRoles());

            if (!rsp2.Success)
            {
                _ = swal.Error(rsp2.Message);
                return;
            }

            _optRoles = rsp2.Items?.ToList() ?? new List<OptionItem<Guid>>();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
    private void TogglePasswordVisible()
    {
        _showPassword = !_showPassword;
    }
    private void SetFilter(string filter)
    {
        _accountFilter = filter;
    }

    private string GetTabClass(string filter)
    {
        return _accountFilter == filter
            ? "account-tab active"
            : "account-tab";
    }

    private string GetAvatarText(ModelAccountListItem model)
    {
        if (model == null || string.IsNullOrWhiteSpace(model.DisplayName))
        {
            return "?";
        }

        return model.DisplayName.Trim()[0].ToString().ToUpper();
    }

    private void ViewDetail(ModelAccountListItem model)
    {
        if (model == null)
        {
            return;
        }

        if (model.AccountType == BasicCodes.AccountType.Customer && model.CustomerGuid.HasValue)
        {
            NavigationManager.NavigateTo($"/admin/customers/detail/{model.CustomerGuid.Value}");
            return;
        }

        if (model.AccountType == BasicCodes.AccountType.Employee && model.GuidEmployee.HasValue)
        {
            NavigationManager.NavigateTo($"/employee/profile/{model.GuidEmployee.Value}");
            return;
        }

        if (!string.IsNullOrWhiteSpace(model.UserName) && model.UserName != "-")
        {
            NavigationManager.NavigateTo($"/management/account");
        }
    }

    private async Task  OpenCreateModal(ModelAccountListItem model)
    {
        if (model == null)
        {
            return;
        }


        if (model.AccountType != BasicCodes.AccountType.Employee)
        {
            _ = swal.Error(Text["임직원 계정만 여기에서 생성할 수 있습니다.|Only employee accounts can be created here."]);
            return;
        }

        if (!model.GuidEmployee.HasValue)
        {
            _ = swal.Error(Text["직원 정보가 올바르지 않습니다.|Employee information is invalid."]);
            return;
        }

        _modelEdit = new ModelUserAccount
        {
            GuidEmployee = model.GuidEmployee.Value,
            FirstName = model.FirstName,
            LastName = model.LastName,
            Email = model.Email,
            Phone = model.Phone,
            UserName = model.Email,
            Password = GenerateTemporaryPassword(),
        };

        _modalEditTitle = Text["계정 생성|Create Account"];
        await  _modalEdit.Show();
    }
    private string GenerateTemporaryPassword()
    {
        var randomCode = Guid.NewGuid()
            .ToString("N")
            .Substring(0, 6)
            .ToUpperInvariant();

        return $"Esc@{DateTime.Now:yyyy}{randomCode}";
    }
    private async Task OpenChangePasswordModal(ModelAccountListItem model)
    {
        if (model == null || !model.HasUser)
        {
            return;
        }

        _modelPwdChange = new ModelPasswordChange
        {
            UserName = model.UserName,
            Password = string.Empty,
            PasswordConfirm = string.Empty
        };

        await  _modalPwd.Show();
    }

    private async Task OnFormEditSubmit()
    {
        var rsp = await AppStatic.CallApi(
            () => _svc.CreateUser(_modelEdit, NavigationManager.BaseUri)
        );

        if (!rsp.Success)
        {
            _ = swal.Error(rsp.Message);
            return;
        }

        await _modalEdit.Show();

        await swal.Alert(
            Text["계정이 생성되었습니다.|Account has been created."],
            Text["완료|Success"]
        );
        await _modalEdit.Close();
        await ResetData();
    }

    private async Task OnFormPwdChangeSubmit()
    {
        var rsp = await AppStatic.CallApi(
            () => _svc.ChangePassword(_modelPwdChange)
        );

        if (!rsp.Success)
        {
            _ = swal.Error(rsp.Message);
            return;
        }

         await _modalPwd.Show();

        await swal.Alert(
            Text["비밀번호가 변경되었습니다.|Password has been changed."],
            Text["완료|Success"]
        );

        await ResetData();
    }
}