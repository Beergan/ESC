        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 20px;
    }
    .password-input-wrap {
        position: relative;
        width: 100%;
    }

        .password-input-wrap .password-input {
            padding-right: 46px;
        }

    .password-eye-btn {
        position: absolute;
        top: 50%;
        right: 12px;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        color: #6b7280;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .password-eye-btn:hover {
            background: #f1f5f9;
            color: #12345a;
        }

    .account-summary-row {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 12px;
