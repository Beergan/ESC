    }

    .account-summary-card {
        background: #fff;
        border: 1px solid #e4ebf3;
        border-radius: 14px;
        padding: 14px 16px;
        box-shadow: 0 8px 22px rgba(20, 52, 91, .04);
    }

        .account-summary-card .summary-label {
            color: #6c7785;
            font-size: 12px;
            font-weight: 700;
