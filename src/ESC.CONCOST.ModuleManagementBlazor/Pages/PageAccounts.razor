@page "/management/account"
@attribute [Authorize]
@inject IManagementAccountService _svc
@inject IServiceBase _svcBa
@inject ISweetAlertService swal
@inject ITextTranslator Text
@inject NavigationManager NavigationManager
@using ESC.CONCOST.Abstract
@using ESC.CONCOST.ModuleManagementCore
@using ESC.CONCOST.ModuleManagementCore.Models
@using ESC.CONCOST.SharedComponents.Components
@using System.Threading.Tasks

<div class="erp-container account-management-page">
    <div class="account-page-header">
        <div>
            <h2 class="erp-page-title mb-1">
                <i class="fa-solid fa-user-gear"></i>
                @Text["계정 통합 관리|Unified Account Management"]
            </h2>
            <div class="text-muted small">
                @Text["임직원, 고객 및 관리자 계정을 통합 관리합니다.|Manage employee, customer and admin accounts in one place."]
            </div>
        </div>

        <button class="btn btn-light border fw-bold" style="border-radius: 10px;" @onclick="ResetData">
            <i class="fa-solid fa-rotate me-1"></i>
            @Text["새로고침|Refresh"]
        </button>
    </div>

    @if (_checkPermissionAdmin)
    {
        <div class="account-summary-row">
            <div class="account-summary-card">
                <div class="summary-label">@Text["전체 계정|All Accounts"]</div>
                <div class="summary-value">@_dataSource.Count()</div>
            </div>

            <div class="account-summary-card">
                <div class="summary-label">@Text["임직원|Employees"]</div>
                <div class="summary-value">@_dataSource.Count(x => x.AccountType == BasicCodes.AccountType.Employee)</div>
            </div>

            <div class="account-summary-card">
                <div class="summary-label">@Text["고객|Customers"]</div>
                <div class="summary-value">@_dataSource.Count(x => x.AccountType == BasicCodes.AccountType.Customer)</div>
            </div>

            <div class="account-summary-card">
                <div class="summary-label">@Text["관리자|Admins"]</div>
                <div class="summary-value">@_dataSource.Count(x => x.AccountType == BasicCodes.AccountType.Admin)</div>
            </div>

            <div class="account-summary-card">
                <div class="summary-label">@Text["미등록|Not Created"]</div>
                <div class="summary-value">@_dataSource.Count(x => !x.HasUser)</div>
            </div>
        </div>

        <div class="account-tabs">
            <button class="@GetTabClass(AccountFilterAll)" @onclick="() => SetFilter(AccountFilterAll)">
                @Text["전체|All"]
            </button>

            <button class="@GetTabClass(BasicCodes.AccountType.Employee)" @onclick="() => SetFilter(BasicCodes.AccountType.Employee)">
                @Text["임직원|Employees"]
            </button>

            <button class="@GetTabClass(BasicCodes.AccountType.Customer)" @onclick="() => SetFilter(BasicCodes.AccountType.Customer)">
                @Text["고객|Customers"]
            </button>

            <button class="@GetTabClass(BasicCodes.AccountType.Admin)" @onclick="() => SetFilter(BasicCodes.AccountType.Admin)">
                @Text["관리자|Admins"]
            </button>

            <button class="@GetTabClass(AccountFilterNotCreated)" @onclick="() => SetFilter(AccountFilterNotCreated)">
                @Text["미등록|Not Created"]
            </button>

            <button class="@GetTabClass(AccountFilterLocked)" @onclick="() => SetFilter(AccountFilterLocked)">
                @Text["잠김|Locked"]
            </button>
        </div>
    }

    <div class="erp-card">
        @if (!_checkPermissionAdmin)
        {
            <div class="text-center py-5">
                <i class="fa-solid fa-lock fs-1 text-muted opacity-20 mb-3"></i>
                <h5 class="fw-bold">@Text["접근 권한이 없습니다!|Access Denied"]</h5>
            </div>
        }
        else if (_isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary mb-3" role="status"></div>
                <div class="fw-bold">@Text["데이터를 불러오는 중...|Loading data..."]</div>
            </div>
        }
        else
        {
            <CustomTable DataSource="@FilteredAccounts.ToList()"
                         PageSize="20"
                         WrapperClass="erp-table-premium border-0 shadow-none p-0"
                         AllowFiltering="true"
                         SearchPlaceholder="@Text["이름, 회사명, 이메일, 사용자 ID 검색...|Search name, company, email, username..."]">
                <Columns>
                    <TableColumn Title="@Text["구분|Type"]" Sortable="true" Property="AccountType">
                        <Template>
                            <span class="@BasicCodes.AccountType.GetBadgeClass(context.AccountType)">
                                @BasicCodes.AccountType.GetTextKr(context.AccountType)
                            </span>
                        </Template>
                    </TableColumn>

                    <TableColumn Title="@Text["이름 / 회사명|Name / Company"]" Sortable="true" Property="DisplayName">
                        <Template>
                            <div class="d-flex align-items-center">
                                <div class="erp-avatar-circle me-3">
                                    @GetAvatarText(context)
                                </div>

                                <div>
                                    <div class="erp-link-name" role="button" @onclick="() => ViewDetail(context)">
                                        @context.DisplayName
                                    </div>

                                    <div class="erp-meta-info" style="font-size: 11px;">
                                        @if (context.AccountType == BasicCodes.AccountType.Employee)
                                        {
                                            <span>
                                                <i class="fa-solid fa-id-badge me-1"></i>
                                                @Text["임직원|Employee"]
                                                @if (!string.IsNullOrWhiteSpace(context.EmployeeCode))
                                                {
                                                    <span> · @context.EmployeeCode</span>
                                                }
                                            </span>
                                        }
                                        else if (context.AccountType == BasicCodes.AccountType.Customer)
                                        {
                                            <span>
                                                <i class="fa-solid fa-building me-1"></i>
                                                @context.BusinessLicense
                                            </span>
                                        }
                                        else
                                        {
                                            <span>
                                                <i class="fa-solid fa-shield-halved me-1"></i>
                                                @Text["시스템 관리자|System Admin"]
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </Template>
                    </TableColumn>

                    <TableColumn Title="@Text["이메일 / 연락처|Email / Phone"]" Sortable="true" Property="Email">
                        <Template>
                            <div class="erp-meta-info" style="flex-direction: column; align-items: flex-start; gap: 2px;">
                                <div class="text-dark">
                                    <i class="fa-solid fa-envelope me-1 opacity-50"></i>
                                    @(string.IsNullOrWhiteSpace(context.Email) ? "-" : context.Email)
                                </div>
                                <div class="text-muted">
                                    <i class="fa-solid fa-phone me-1 opacity-50"></i>
                                    @(string.IsNullOrWhiteSpace(context.Phone) ? "-" : context.Phone)
                                </div>
                            </div>
                        </Template>
                    </TableColumn>

                    <TableColumn Title="@Text["사용자 ID|User ID"]" Sortable="true" Property="UserName">
                        <Template>
                            @if (context.HasUser)
                            {
                                <span class="badge bg-light text-navy fw-bold border" style="font-size: 11px; padding: 5px 10px; border-radius: 8px;">
                                    @context.UserName
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small italic">@Text["미등록|Unregistered"]</span>
                            }
                        </Template>
                    </TableColumn>

                    <TableColumn Title="@Text["상태|Status"]" Sortable="true" Property="Active">
                        <Template>
                            <div class="d-flex flex-wrap gap-1">
                                @if (!context.HasUser || context.Active == null)
                                {
                                    <span class="erp-badge-status bg-warning-soft text-warning">
                                        <i class="fa-solid fa-user-clock"></i>
                                        @Text["미등록|Not Created"]
                                    </span>
                                }
                                else if (context.Active == true)
                                {
                                    <span class="erp-badge-status bg-success-soft text-success">
                                        <i class="fa-solid fa-user-check"></i>
                                        @Text["사용 중|Active"]
                                    </span>
                                }
                                else
                                {
                                    <span class="erp-badge-status bg-danger-soft text-danger">
                                        <i class="fa-solid fa-user-slash"></i>
                                        @Text["잠김|Locked"]
                                    </span>
                                }

                                @if (context.AccountType == BasicCodes.AccountType.Customer && context.CustomerApprovalStatus.HasValue)
                                {
                                    <span class="@BasicCodes.CustomerApprovalStatus.GetBadgeClass(context.CustomerApprovalStatus.Value)">
                                        @BasicCodes.CustomerApprovalStatus.GetTextKr(context.CustomerApprovalStatus.Value)
                                    </span>
                                }

                                @if (context.AccountType == BasicCodes.AccountType.Customer && !string.IsNullOrWhiteSpace(context.MembershipType))
                                {
                                    <span class="@BasicCodes.MembershipType.GetBadgeClass(context.MembershipType)">
                                        @context.MembershipType
                                    </span>
                                }
                            </div>
                        </Template>
                    </TableColumn>
                </Columns>

                <Actions>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-light text-primary"
                                style="border-radius: 8px;"
                                @onclick="() => ViewDetail(context)"
                                title="@Text["상세보기|View Details"]">
                            <i class="fa-solid fa-arrow-right"></i>
                        </button>

                        @if (context.AccountType == BasicCodes.AccountType.Employee && !context.HasUser)
                        {
                            <button class="btn btn-sm btn-light text-success"
                                    style="border-radius: 8px;"
                                    @onclick="() => OpenCreateModal(context)"
                                    title="@Text["계정 생성|Create Account"]">
                                <i class="fa-solid fa-user-plus"></i>
                            </button>
                        }

                        @if (context.HasUser)
                        {
                            <button class="btn btn-sm btn-light text-orange"
                                    style="border-radius: 8px;"
                                    @onclick="() => OpenChangePasswordModal(context)"
                                    title="@Text["비밀번호 변경|Change Password"]">
                                <i class="fa-solid fa-key"></i>
                            </button>
                        }
                    </div>
                </Actions>
            </CustomTable>
        }
    </div>
</div>

<ModalComponent @ref="_modalEdit" Title="@_modalEditTitle" OnConfirm="OnFormEditSubmit">
    <EditForm Model="@_modelEdit" id="accountForm">
        <DataAnnotationsValidator />

        <div class="row g-4">
            <div class="col-md-6">
                <label class="form-label-bold">@Text["성|Last Name"]</label>
                <input type="text" class="form-control-custom bg-light" value="@_modelEdit.LastName" disabled />
            </div>

            <div class="col-md-6">
                <label class="form-label-bold">@Text["이름|First Name"]</label>
                <input type="text" class="form-control-custom bg-light" value="@_modelEdit.FirstName" disabled />
            </div>

            <div class="col-md-12">
                <label class="form-label-bold">@Text["사용자 ID|User ID"] *</label>
                <InputText class="form-control-custom" @bind-Value="_modelEdit.UserName" placeholder="@Text["사용자 ID|User ID"]" />
                <CustomValidationMessage For="@(() => _modelEdit.UserName)" />
            </div>

            <div class="col-md-12">
                <label class="form-label-bold">@Text["비밀번호|Password"] *</label>

                <div class="password-input-wrap">
                    <InputText type="@(_showPassword ? "text" : "password")"
                               class="form-control-custom password-input"
                               @bind-Value="_modelEdit.Password"
                               placeholder="@Text["비밀번호|Password"]" />

                    <button type="button"
                            class="password-eye-btn"
                            @onclick="TogglePasswordVisible">
                        <i class="@(_showPassword ? "fa-solid fa-eye-slash" : "fa-solid fa-eye")"></i>
                    </button>
                </div>

                <CustomValidationMessage For="@(() => _modelEdit.Password)" />
            </div>

            <div class="col-md-12">
                <label class="form-label-bold">@Text["권한 그룹|Permission Group"] *</label>
                <DropdownSelect TItem="OptionItem<Guid>"
                                DataSource="@_optRoles"
                                Value="_selectedPermissionRole"
                                ValueChanged="OnPermissionRoleChanged"
                                TextSelector="@(x => x.Text)"
                                Placeholder="@Text["권한 그룹 선택|Select Permission Group"]"
                                IconClass="fa-solid fa-hard-hat" DropdownPlacement="Top"
                                WrapperClass="w-100"  />

                <CustomValidationMessage For="@(() => _modelEdit.GuidPrimissions)" />
            </div>
        </div>
    </EditForm>
</ModalComponent>

<ModalComponent @ref="_modalPwd" Title="@Text["비밀번호 변경|Change Password"]" OnConfirm="OnFormPwdChangeSubmit">
    <EditForm Model="@_modelPwdChange" id="pwdForm">
        <DataAnnotationsValidator />

        <div class="row g-4">
            <div class="col-12">
                <label class="form-label-bold">@Text["사용자 ID|User ID"]</label>
                <input type="text" class="form-control-custom bg-light" value="@_modelPwdChange.UserName" disabled />
            </div>

            <div class="col-12">
                <label class="form-label-bold">@Text["새 비밀번호|New Password"] *</label>
                <InputText type="password" class="form-control-custom" @bind-Value="_modelPwdChange.Password" />
                <CustomValidationMessage For="@(() => _modelPwdChange.Password)" />
            </div>

            <div class="col-12">
                <label class="form-label-bold">@Text["비밀번호 확인|Confirm Password"] *</label>
                <InputText type="password" class="form-control-custom" @bind-Value="_modelPwdChange.PasswordConfirm" />
                <CustomValidationMessage For="@(() => _modelPwdChange.PasswordConfirm)" />
            </div>
        </div>
    </EditForm>
</ModalComponent>

<style>
