    private async Task HandleValidSubmit()
    {
        if (IsBusy)
        {
            return;
        }

        if (!await ValidateCurrentStepAsync())
        {
            return;
        }

        try
        {
            IsBusy = true;

            var result = await ESCService.CreateContractAsync(Model);

            if (result == null || !result.Success)
            {
                IsBusy = false;
                StateHasChanged();

                await Alert.Error(
                    string.IsNullOrWhiteSpace(result?.Message)
                        ? Text["저장에 실패했습니다.|Failed to save the project."]
                        : Text[result.Message],
                    Text["오류|Error"]
                );

                return;
            }

            await Alert.Alert(
                Text["성공|Success"],
                Text["프로젝트가 저장되었습니다.|Project saved successfully."]
            );

            Navigation.NavigateTo("/escalation/workspace");
        }
        catch
        {
            IsBusy = false;
            StateHasChanged();

            await Alert.Error(
                Text["저장 중 오류가 발생했습니다.|An error occurred while saving."],
                Text["오류|Error"]
            );
        }
        finally
        {
            IsBusy = false;
        }
    }
