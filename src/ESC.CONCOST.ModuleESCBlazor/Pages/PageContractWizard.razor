    private async Task<bool> ValidateCurrentStepAsync()
    {
        var errorMessage = GetCurrentStepValidationMessage();

        if (string.IsNullOrWhiteSpace(errorMessage))
        {
            return true;
        }

        await Alert.Error(
            errorMessage,
            Text["검증 오류|Validation Error"]
        );

        return false;
    }

    private string GetCurrentStepValidationMessage()
    {
        var validation = ContractWizardValidator.Validate(Model, CurrentStep);
        return validation.IsValid ? string.Empty : Text[validation.Message];
    }

    private string ValidateStep1()
    {
        if (string.IsNullOrWhiteSpace(Model.ProjectName))
        {
            return Text["공사명을 입력하세요|Please enter Project Name"];
        }

        if (string.IsNullOrWhiteSpace(Model.Contractor))
        {
            return Text["시공사명을 입력하세요|Please enter Contractor"];
        }

        if (string.IsNullOrWhiteSpace(Model.Client))
        {
            return Text["발주처명을 입력하세요|Please enter Client"];
        }

        if (string.IsNullOrWhiteSpace(Model.WorkType))
        {
            return Text["공사 종류를 선택하세요|Please select Work Type"];
        }

        if (string.IsNullOrWhiteSpace(Model.ContractMethod))
        {
            return Text["계약방법을 선택하세요|Please select Contract Method"];
        }

        if (Model.BidRate <= 0)
        {
            return Text["낙찰율은 0보다 커야 합니다|Bid Rate must be greater than 0"];
        }

        if (Model.BidRate > 100)
        {
            return Text["낙찰율은 100%를 초과할 수 없습니다|Bid Rate cannot exceed 100%"];
        }

        return string.Empty;
    }

    private string ValidateStep2()
    {
        if (Model.ContractAmount <= 0)
        {
            return Text["계약금액을 입력하세요|Please enter Contract Amount"];
        }

        if (Model.AdvanceAmt < 0)
        {
            return Text["선금액은 0보다 작을 수 없습니다|Advance Payment cannot be less than 0"];
        }

        if (Model.AdvanceAmt > Model.ContractAmount)
        {
            return Text["선금액은 계약금액보다 클 수 없습니다|Advance Payment cannot exceed Contract Amount"];
        }

        if (!Model.ContractDate.HasValue)
        {
            return Text["계약체결일을 선택하세요|Please select Contract Date"];
        }

        if (!Model.BidDate.HasValue)
        {
            return Text["입찰일을 선택하세요|Please select Bid Date"];
        }

        if (!Model.StartDate.HasValue)
        {
            return Text["착공일을 선택하세요|Please select Start Date"];
        }

        if (!Model.CompletionDate.HasValue)
        {
            return Text["준공예정일을 선택하세요|Please select Completion Date"];
        }

        if (Model.CompletionDate.Value <= Model.StartDate.Value)
        {
            return Text["준공일은 착공일보다 늦어야 합니다|Completion Date must be after Start Date"];
        }

        if (Model.ContractDate.Value < Model.BidDate.Value)
        {
            return Text["계약체결일은 입찰일보다 빠를 수 없습니다|Contract Date cannot be earlier than Bid Date"];
        }

        return string.Empty;
    }

    private string ValidateStep3()
    {
        if (!Model.CompareDate.HasValue)
        {
            return Text["조정기준일을 선택하세요|Please select Adjustment Base Date"];
        }

        if (Model.ThresholdRate <= 0)
        {
            return Text["등락율 기준은 0보다 커야 합니다|Fluctuation Rate must be greater than 0"];
        }

        if (Model.ThresholdDays <= 0)
        {
            return Text["경과기간 기준은 0보다 커야 합니다|Time Threshold must be greater than 0"];
        }

        if (Model.ExcludedAmt < 0)
        {
            return Text["적용제외금액은 0보다 작을 수 없습니다|Exclusion Amount cannot be less than 0"];
        }

        if (Model.CompareDate.HasValue && Model.BidDate.HasValue)
        {
            var diffDays = (Model.CompareDate.Value.Date - Model.BidDate.Value.Date).Days;

            if (diffDays < Model.ThresholdDays)
            {
                return Text[
                    $"경과기간이 {diffDays}일입니다. 조정기준일은 입찰일로부터 {Model.ThresholdDays}일 이상이어야 합니다.|The elapsed period is {diffDays} days. The adjustment base date must be at least {Model.ThresholdDays} days after the bid date."
                ];
            }
        }

        if (!string.IsNullOrWhiteSpace(Model.PreviousMonth) && !IsValidYearMonth(Model.PreviousMonth))
        {
            return Text["직전연월 형식은 YYYY-MM 이어야 합니다|Previous Month format must be YYYY-MM"];
        }

        return string.Empty;
    }

    private static bool IsValidYearMonth(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        return DateTime.TryParseExact(
            value,
            "yyyy-MM",
            CultureInfo.InvariantCulture,
            DateTimeStyles.None,
            out _
        );
    }

