</style>

@code {
    [Parameter]
    public Guid CustomerGuid { get; set; }

    private Customer? Customer { get; set; }
    private bool IsLoading { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomerAsync();
    }

    private async Task LoadCustomerAsync()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = string.Empty;

            var result = await CustomerAdminService.GetCustomerAsync(CustomerGuid);

            if (result == null || !result.Success || result.Item == null)
            {
                ErrorMessage = string.IsNullOrWhiteSpace(result?.Message)
                    ? Text["고객 정보를 불러올 수 없습니다.|Cannot load customer detail."]
                    : result.Message;

                Customer = null;
                return;
            }

            Customer = result.Item;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            Customer = null;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void BackToList()
    {
        Navigation.NavigateTo("/admin/customers");
    }

    private async Task ApproveCustomerAsync()
    {
        if (Customer == null)
        {
            return;
        }

        var confirm = await Alert.ConfirmDelete(
            Text[$"'{Customer.CompanyName}' 고객을 승인하시겠습니까?|Approve customer '{Customer.CompanyName}'?"],
            Text["승인 확인|Approve Confirmation"]
        );

        if (!confirm)
        {
            return;
        }

        var result = await CustomerAdminService.ApproveAsync(Customer.Guid);

        if (result.Success)
        {
            Customer.ApprovalStatus = BasicCodes.CustomerApprovalStatus.Approved;
            Customer.RejectReason = string.Empty;

            await Alert.Alert(
                Text["승인되었습니다.|Approved successfully."],
                Text["완료|Success"]
            );
        }
        else
        {
            await Alert.Error(result.Message, Text["오류|Error"]);
        }
    }

    private async Task RejectCustomerAsync()
    {
        if (Customer == null)
        {
            return;
        }

        var confirm = await Alert.ConfirmDelete(
            Text[$"'{Customer.CompanyName}' 고객을 거절하시겠습니까?|Reject customer '{Customer.CompanyName}'?"],
            Text["거절 확인|Reject Confirmation"]
        );

        if (!confirm)
        {
            return;
        }

        var reason = Text["관리자에 의해 거절되었습니다.|Rejected by admin."];

        var result = await CustomerAdminService.RejectAsync(Customer.Guid, reason);

        if (result.Success)
        {
            Customer.ApprovalStatus = BasicCodes.CustomerApprovalStatus.Rejected;
            Customer.RejectReason = reason;

            await Alert.Alert(
                Text["거절되었습니다.|Rejected successfully."],
                Text["완료|Success"]
            );
        }
        else
        {
            await Alert.Error(result.Message, Text["오류|Error"]);
        }
    }

    private async Task TogglePaidAsync()
    {
        if (Customer == null)
        {
            return;
        }

        var newPaidStatus = !Customer.IsPaid;

        var result = await CustomerAdminService.SetPaidAsync(Customer.Guid, newPaidStatus);

        if (result.Success)
        {
            Customer.IsPaid = newPaidStatus;

            await Alert.Alert(
                Text["결제 상태가 변경되었습니다.|Payment status has been updated."],
                Text["완료|Success"]
            );
        }
        else
        {
            await Alert.Error(result.Message, Text["오류|Error"]);
        }
    }

    private async Task ChangeMembershipAsync()
    {
        if (Customer == null)
        {
            return;
        }

        var nextMembership = Customer.MembershipType switch
        {
            BasicCodes.MembershipType.Free => BasicCodes.MembershipType.Paid,
            BasicCodes.MembershipType.Paid => BasicCodes.MembershipType.Enterprise,
            _ => BasicCodes.MembershipType.Free
        };

        var result = await CustomerAdminService.SetMembershipAsync(Customer.Guid, nextMembership);

        if (result.Success)
        {
            Customer.MembershipType = nextMembership;

            await Alert.Alert(
                Text["멤버십이 변경되었습니다.|Membership has been updated."],
                Text["완료|Success"]
            );
        }
        else
        {
            await Alert.Error(result.Message, Text["오류|Error"]);
        }
    }
}