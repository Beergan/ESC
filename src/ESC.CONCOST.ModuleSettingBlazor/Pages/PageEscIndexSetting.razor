@page "/management/esc-index-setting"

@using ESC.CONCOST.Abstract
@using ESC.CONCOST.ModuleSetting
@using System.Globalization

@inject ITextTranslator Text
@inject IEscIndexService IndexService
@inject IJSRuntime JS

<div class="esc-admin-page">
    <div class="esc-page-header">
        <div>
            <div class="esc-page-kicker">
                <i class="fa-solid fa-sliders"></i>
                @Text["ESC 관리자 설정|ESC Admin Settings"]
            </div>

            <h2>@Text["지수 그룹 및 항목 설정|Index Group & Item Settings"]</h2>

            <p>
                @Text["월별 지수 입력과 ESC 계산식에서 사용할 그룹과 지수 항목을 관리합니다.|Manage groups and index items used for monthly index input and ESC calculation."]
            </p>
        </div>

        <div class="esc-page-actions">
            <button type="button" class="esc-btn esc-btn-light" @onclick="LoadDataAsync" disabled="@_loading">
                <i class="fa-solid fa-rotate"></i>
                @Text["새로고침|Refresh"]
            </button>

            <button type="button" class="esc-btn esc-btn-primary" @onclick="CreateGroup" disabled="@_loading">
                <i class="fa-solid fa-folder-plus"></i>
                @Text["새 그룹|New Group"]
            </button>

            <button type="button" class="esc-btn esc-btn-success" @onclick="CreateIndex" disabled="@(!_selectedGroupId.HasValue || _loading)">
                <i class="fa-solid fa-plus"></i>
                @Text["지수 추가|Add Index"]
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="esc-alert @(_isError ? "error" : "success")">
            <i class="fa-solid @(_isError ? "fa-triangle-exclamation" : "fa-circle-check")"></i>
            <span>@_message</span>
            <button type="button" @onclick="ClearMessage">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
    }

    <section class="esc-guide-card">
        <div class="guide-title">
            <i class="fa-solid fa-circle-info"></i>
            @Text["관리 흐름 안내|Management Flow"]
        </div>

        <div class="guide-content">
            <div>
                <strong>1. @Text["그룹 생성|Create Group"]</strong>
                <span>@Text["노무비, 재료비, 경비처럼 월별 입력 화면의 탭이 됩니다.|It becomes a tab on the monthly input page, such as Labor, Material, Expense."]</span>
            </div>

            <div>
                <strong>2. @Text["지수 생성|Create Index"]</strong>
                <span>@Text["각 그룹에 연결되는 실제 입력 항목입니다.|Actual input items linked to each group."]</span>
            </div>

            <div>
                <strong>3. @Text["월별 입력에서 사용|Used Monthly"]</strong>
                <span>@Text["월별 입력 화면은 여기서 만든 그룹과 지수를 자동으로 읽습니다.|Monthly input page automatically reads groups and indexes from here."]</span>
            </div>
        </div>
    </section>

    <div class="esc-setting-layout">
        <section class="esc-card group-card">
            <div class="esc-card-header">
                <div>
                    <h3>@Text["지수 그룹|Index Groups"]</h3>
                    <span>@Text["월별 입력 화면의 탭으로 표시됩니다.|Displayed as tabs on the monthly input page."]</span>
                </div>

                <strong>@FilteredGroups.Count()</strong>
            </div>

            <div class="esc-search">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input value="@_groupSearch"
                       @oninput="OnGroupSearchChanged"
                       placeholder="@Text["그룹 코드 또는 이름 검색|Search group code or name"]" />
            </div>

            <div class="esc-group-list">
                @if (_loading)
                {
                    <div class="esc-empty">
                        <i class="fa-solid fa-spinner fa-spin"></i>
                        <strong>@Text["불러오는 중입니다.|Loading..."]</strong>
                    </div>
                }
                else if (!FilteredGroups.Any())
                {
                    <div class="esc-empty">
                        <i class="fa-regular fa-folder-open"></i>
                        <strong>@Text["등록된 그룹이 없습니다.|No groups found."]</strong>
                        <span>@Text["새 그룹 버튼으로 먼저 그룹을 생성하세요.|Create a group first using the New Group button."]</span>
                    </div>
                }
                else
                {
                    @foreach (var group in FilteredGroups)
                    {
                        <button type="button"
                                class="esc-group-item @(group.Id == _selectedGroupId ? "active" : "")"
                                @onclick="() => SelectGroup(group)">
                            <div class="group-icon">
                                <i class="@GetIcon(group.IconClass)"></i>
                            </div>

                            <div class="group-info">
                                <strong>@GetGroupDisplayName(group)</strong>
                                <span>
                                    <code>@group.GroupCode</code>
                                    · @Text["정렬|Sort"] @group.SortOrder
                                </span>
                            </div>

                            <div class="group-side">
                                @if (group.IsActive)
                                {
                                    <span class="esc-badge green">@Text["사용|Active"]</span>
                                }
                                else
                                {
                                    <span class="esc-badge gray">@Text["중지|Inactive"]</span>
                                }

                                <button type="button"
                                        class="group-edit-btn"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => EditGroup(group)"
                                        title="@Text["그룹 수정|Edit Group"]">
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                            </div>
                        </button>
                    }
                }
            </div>
        </section>

        <section class="esc-card">
            <div class="esc-card-header">
                <div>
                    <h3>@Text["지수 항목|Index Items"]</h3>
                    <span>
                        @if (_selectedGroupId.HasValue)
                        {
                            @GetSelectedGroupTitle()
                        }
                        else
                        {
                            @Text["그룹을 선택하세요.|Please select a group."]
                        }
                    </span>
                </div>

                <div class="header-count">
                    <button type="button"
                            class="esc-btn esc-btn-success esc-btn-sm"
                            @onclick="CreateIndex"
                            disabled="@(!_selectedGroupId.HasValue)">
                        <i class="fa-solid fa-plus"></i>
                        @Text["지수 추가|Add Index"]
                    </button>

                    <strong>@FilteredIndexes.Count()</strong>
                </div>
            </div>

            <div class="esc-toolbar">
                <div class="esc-search wide">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input value="@_indexSearch"
                           @oninput="OnIndexSearchChanged"
                           placeholder="@Text["지수명, 코드, 출처/비고 검색|Search name, code, source/note"]" />
                </div>

                <select class="esc-input status-select" @bind="_statusFilter">
                    <option value="ALL">@Text["전체 상태|All Status"]</option>
                    <option value="ACTIVE">@Text["사용|Active"]</option>
                    <option value="INACTIVE">@Text["중지|Inactive"]</option>
                </select>
            </div>

            <div class="esc-table-wrap">
                <table class="esc-table">
                    <thead>
                        <tr>
                            <th style="width:150px;">@Text["코드|Code"]</th>
                            <th>@Text["지수명|Index Name"]</th>
                            <th style="width:160px;">@Text["그룹|Group"]</th>
                            <th style="width:130px;">@Text["유형|Type"]</th>
                            <th style="width:100px;">@Text["단위|Unit"]</th>
                            <th>@Text["출처/비고|Source / Note"]</th>
                            <th style="width:100px;">@Text["상태|Status"]</th>
                            <th style="width:130px;">@Text["관리|Manage"]</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (_loading)
                        {
                            <tr>
                                <td colspan="8">
                                    <div class="esc-empty">
                                        <i class="fa-solid fa-spinner fa-spin"></i>
                                        <strong>@Text["불러오는 중입니다.|Loading..."]</strong>
                                    </div>
                                </td>
                            </tr>
                        }
                        else if (!_selectedGroupId.HasValue)
                        {
                            <tr>
                                <td colspan="8">
                                    <div class="esc-empty">
                                        <i class="fa-solid fa-layer-group"></i>
                                        <strong>@Text["왼쪽에서 그룹을 선택하세요.|Select a group on the left."]</strong>
                                    </div>
                                </td>
                            </tr>
                        }
                        else if (!FilteredIndexes.Any())
                        {
                            <tr>
                                <td colspan="8">
                                    <div class="esc-empty">
                                        <i class="fa-solid fa-database"></i>
                                        <strong>@Text["등록된 지수 항목이 없습니다.|No index items found."]</strong>
                                        <span>@Text["지수 추가 버튼으로 이 그룹에 항목을 생성하세요.|Create an item in this group using the Add Index button."]</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in FilteredIndexes)
                            {
                                <tr>
                                    <td>
                                        <code class="esc-code">@item.IndexCode</code>
                                    </td>

                                    <td>
                                        <div class="index-name">
                                            <strong>@GetIndexDisplayName(item)</strong>
                                            @if (!string.IsNullOrWhiteSpace(item.IndexNameEn) && Text.IsKorean)
                                            {
                                                <small>@item.IndexNameEn</small>
                                            }
                                        </div>
                                    </td>

                                    <td>
                                        <span class="esc-badge blue">@GetGroupNameByCode(item.GroupCode)</span>
                                    </td>

                                    <td>
                                        <span class="esc-badge purple">@GetTypeText(item.Type)</span>
                                    </td>

                                    <td>
                                        <span class="unit-text">@item.Unit</span>
                                    </td>

                                    <td>
                                        @if (string.IsNullOrWhiteSpace(item.DataSource))
                                        {
                                            <span class="empty-note">-</span>
                                        }
                                        else
                                        {
                                            <div class="source-note">
                                                <i class="fa-regular fa-note-sticky"></i>
                                                <span>@item.DataSource</span>
                                            </div>
                                        }
                                    </td>

                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="esc-badge green">@Text["사용|Active"]</span>
                                        }
                                        else
                                        {
                                            <span class="esc-badge gray">@Text["중지|Inactive"]</span>
                                        }
                                    </td>

                                    <td>
                                        <div class="row-actions">
                                            <button type="button"
                                                    class="icon-btn"
                                                    @onclick="() => EditIndex(item)"
                                                    title="@Text["수정|Edit"]">
                                                <i class="fa-solid fa-pen"></i>
                                            </button>

                                            <button type="button"
                                                    class="icon-btn"
                                                    @onclick="() => ToggleIndexAsync(item)"
                                                    title="@Text["상태 변경|Toggle Status"]">
                                                <i class="fa-solid fa-power-off"></i>
                                            </button>

                                            <button type="button"
                                                    class="icon-btn danger"
                                                    @onclick="() => DeleteIndexAsync(item)"
                                                    title="@Text["삭제|Delete"]">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    @if (_showGroupModal)
    {
        <div class="esc-modal-backdrop">
            <div class="esc-modal">
                <div class="esc-modal-header">
                    <div>
                        <h3>@_groupModalTitle</h3>
                        <p>@Text["그룹은 월별 입력 화면의 탭으로 사용됩니다.|Groups are used as tabs on the monthly input page."]</p>
                    </div>

                    <button type="button" class="modal-close" @onclick="CloseGroupModal">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>

                <EditForm Model="_groupEdit" OnValidSubmit="SaveGroupAsync">
                    <DataAnnotationsValidator />

                    <div class="modal-body">
                        <div class="form-grid">
                            <div class="field">
                                <label>@Text["그룹 코드|Group Code"] *</label>
                                <InputText class="esc-input"
                                           @bind-Value="_groupEdit.GroupCode"
                                           disabled="@(_groupEdit.Id > 0)"
                                           placeholder="LABOR, MATERIAL, EQUIPMENT" />
                                <ValidationMessage For="@(() => _groupEdit.GroupCode)" />
                                <small>@Text["저장 후 코드는 변경하지 않는 것이 안전합니다.|It is safer not to change the code after saving."]</small>
                            </div>

                            <div class="field">
                                <label>@Text["정렬 순서|Sort Order"]</label>
                                <InputNumber class="esc-input" @bind-Value="_groupEdit.SortOrder" />
                            </div>

                            <div class="field">
                                <label>@Text["그룹명 한국어|Group Name Korean"] *</label>
                                <InputText class="esc-input"
                                           @bind-Value="_groupEdit.GroupName"
                                           placeholder="예: 노무비" />
                                <ValidationMessage For="@(() => _groupEdit.GroupName)" />
                            </div>

                            <div class="field">
                                <label>@Text["그룹명 영어|Group Name English"]</label>
                                <InputText class="esc-input"
                                           @bind-Value="_groupEdit.GroupNameEn"
                                           placeholder="Ex: Labor Cost" />
                            </div>

                            <div class="field">
                                <label>@Text["아이콘 CSS|Icon CSS"]</label>
                                <InputText class="esc-input"
                                           @bind-Value="_groupEdit.IconClass"
                                           placeholder="fa-solid fa-layer-group" />
                            </div>

                            <div class="field">
                                <label>@Text["사용 여부|Active"]</label>
                                <label class="check-line">
                                    <InputCheckbox @bind-Value="_groupEdit.IsActive" />
                                    <span>@Text["사용함|Active"]</span>
                                </label>
                            </div>

                            <div class="field full">
                                <label>@Text["설명|Description"]</label>
                                <InputTextArea class="esc-input textarea"
                                               @bind-Value="_groupEdit.Description"
                                               placeholder="@Text["관리자가 이해하기 쉬운 설명을 입력하세요.|Enter a description that admin can easily understand."]" />
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        @if (_groupEdit.Id > 0)
                        {
                            <button type="button"
                                    class="esc-btn esc-btn-danger"
                                    @onclick="() => DeleteGroupAsync(_groupEdit)"
                                    disabled="@_saving">
                                <i class="fa-solid fa-trash"></i>
                                @Text["삭제|Delete"]
                            </button>
                        }

                        <div class="spacer"></div>

                        <button type="button" class="esc-btn esc-btn-light" @onclick="CloseGroupModal" disabled="@_saving">
                            @Text["취소|Cancel"]
                        </button>

                        <button type="submit" class="esc-btn esc-btn-primary" disabled="@_saving">
                            <i class="fa-solid fa-floppy-disk"></i>
                            @Text["저장|Save"]
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @if (_showIndexModal)
    {
        <div class="esc-modal-backdrop">
            <div class="esc-modal large">
                <div class="esc-modal-header">
                    <div>
                        <h3>@_indexModalTitle</h3>
                        <p>@Text["월별 입력 화면에서 입력할 지수 항목입니다.|This is an index item entered on the monthly input page."]</p>
                    </div>

                    <button type="button" class="modal-close" @onclick="CloseIndexModal">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>

                <EditForm Model="_indexEdit" OnValidSubmit="SaveIndexAsync">
                    <DataAnnotationsValidator />

                    <div class="modal-body">
                        <div class="form-grid">
                            <div class="field">
                                <label>@Text["지수 코드|Index Code"] *</label>
                                <InputText class="esc-input"
                                           @bind-Value="_indexEdit.IndexCode"
                                           placeholder="LABOR_001" />
                                <ValidationMessage For="@(() => _indexEdit.IndexCode)" />
                            </div>

                            <div class="field">
                                <label>@Text["그룹|Group"] *</label>
                                <select class="esc-input" @bind="_selectedGroupIdForIndex">
                                    <option value="">@Text["그룹 선택|Select Group"]</option>
                                    @foreach (var group in _groups.Where(x => x.IsActive).OrderBy(x => x.SortOrder))
                                    {
                                        <option value="@group.Id">@GetGroupDisplayName(group)</option>
                                    }
                                </select>
                            </div>

                            <div class="field">
                                <label>@Text["지수명 한국어|Index Name Korean"] *</label>
                                <InputText class="esc-input"
                                           @bind-Value="_indexEdit.IndexName"
                                           placeholder="예: 노임단가" />
                                <ValidationMessage For="@(() => _indexEdit.IndexName)" />
                            </div>

                            <div class="field">
                                <label>@Text["지수명 영어|Index Name English"]</label>
                                <InputText class="esc-input"
                                           @bind-Value="_indexEdit.IndexNameEn"
                                           placeholder="Ex: Labor Wage Index" />
                            </div>

                            <div class="field">
                                <label>@Text["유형|Type"]</label>
                                <select class="esc-input" @bind="_indexEdit.Type">
                                    <option value="@IndexValueTypeValue">@Text["값형|Value"]</option>
                                    <option value="@IndexValueTypeRate">@Text["요율형|Rate"]</option>
                                    <option value="@IndexValueTypeUnitPrice">@Text["단가형|Unit Price"]</option>
                                </select>
                                <small>@Text["계산 방식 구분용입니다.|Used to classify calculation input type."]</small>
                            </div>

                            <div class="field">
                                <label>@Text["단위|Unit"]</label>
                                <InputText class="esc-input"
                                           @bind-Value="_indexEdit.Unit"
                                           placeholder="%, 원, 원/kg, point" />
                            </div>

                            <div class="field">
                                <label>@Text["갱신 주기|Update Frequency"]</label>
                                <select class="esc-input" @bind="_indexEdit.UpdateFreq">
                                    <option value="MONTHLY">@Text["월별|Monthly"]</option>
                                    <option value="QUARTERLY">@Text["분기별|Quarterly"]</option>
                                    <option value="YEARLY">@Text["연도별|Yearly"]</option>
                                </select>
                            </div>

                            <div class="field">
                                <label>@Text["정렬 순서|Sort Order"]</label>
                                <InputNumber class="esc-input" @bind-Value="_indexEdit.SortOrder" />
                            </div>

                            <div class="field">
                                <label>@Text["PPI 유형|PPI Type"]</label>
                                <label class="check-line">
                                    <InputCheckbox @bind-Value="_indexEdit.IsPpiType" />
                                    <span>@Text["생산자물가지수 유형|Producer Price Index Type"]</span>
                                </label>
                            </div>

                            <div class="field">
                                <label>@Text["사용 여부|Active"]</label>
                                <label class="check-line">
                                    <InputCheckbox @bind-Value="_indexEdit.IsActive" />
                                    <span>@Text["사용함|Active"]</span>
                                </label>
                            </div>

                            <div class="field full">
                                <label>@Text["출처/비고|Source / Note"]</label>
                                <InputTextArea class="esc-input textarea"
                                               @bind-Value="_indexEdit.DataSource"
                                               placeholder="@Text["예: 한국은행 생산자물가지수, 조달청 가격정보, 관리자 직접 입력|Ex: Bank of Korea PPI, PPS price information, manual input by admin"]" />
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer">
                        @if (_indexEdit.Id > 0)
                        {
                            <button type="button"
                                    class="esc-btn esc-btn-danger"
                                    @onclick="() => DeleteIndexAsync(_indexEdit)"
                                    disabled="@_saving">
                                <i class="fa-solid fa-trash"></i>
                                @Text["삭제|Delete"]
                            </button>
                        }

                        <div class="spacer"></div>

                        <button type="button" class="esc-btn esc-btn-light" @onclick="CloseIndexModal" disabled="@_saving">
                            @Text["취소|Cancel"]
                        </button>

                        <button type="submit" class="esc-btn esc-btn-primary" disabled="@_saving">
                            <i class="fa-solid fa-floppy-disk"></i>
                            @Text["저장|Save"]
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
</div>

<style>
    .esc-admin-page {
        padding: 28px 38px;
        background: #f3f7fb;
        min-height: calc(100vh - 64px);
        color: #102a43;
    }

    .esc-page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 18px;
        margin-bottom: 18px;
    }

    .esc-page-kicker {
        color: #0f4c81;
        font-size: 13px;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
    }

    .esc-page-header h2 {
        margin: 0;
        font-size: 28px;
        font-weight: 900;
        color: #12345a;
    }

    .esc-page-header p {
        margin: 6px 0 0;
        font-size: 13px;
        color: #64748b;
    }

    .esc-page-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .esc-guide-card {
        background: #eef6ff;
        border: 1px solid #bfdbfe;
        border-radius: 18px;
        padding: 16px 18px;
        margin-bottom: 16px;
    }

    .guide-title {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #0f4c81;
        font-size: 14px;
        font-weight: 900;
        margin-bottom: 12px;
    }

    .guide-content {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }

        .guide-content div {
            background: #fff;
            border: 1px solid #dbeafe;
            border-radius: 14px;
            padding: 12px;
        }

        .guide-content strong {
            display: block;
            color: #12345a;
            font-size: 13px;
            font-weight: 900;
            margin-bottom: 5px;
        }

        .guide-content span {
            color: #64748b;
            font-size: 12px;
            line-height: 1.55;
        }

    .esc-setting-layout {
        display: grid;
        grid-template-columns: 380px minmax(0, 1fr);
        gap: 18px;
    }

    .esc-card {
        background: #fff;
        border: 1px solid #dbe6f3;
        border-radius: 20px;
        box-shadow: 0 14px 34px rgba(15, 46, 82, .06);
        overflow: hidden;
