@code {
    private const string IndexValueTypeValue = "VALUE";
    private const string IndexValueTypeRate = "RATE";
    private const string IndexValueTypeUnitPrice = "UNIT_PRICE";

    private bool _loading;
    private bool _saving;

    private string _message = string.Empty;
    private bool _isError;

    private List<EscIndexGroup> _groups = new();
    private List<IndexType> _indexes = new();

    private EscIndexGroup _groupEdit = new();
    private IndexType _indexEdit = new();

    private int? _selectedGroupId;
    private int? _selectedGroupIdForIndex;

    private string _groupSearch = string.Empty;
    private string _indexSearch = string.Empty;
    private string _statusFilter = "ALL";

    private bool _showGroupModal;
    private bool _showIndexModal;

    private string _groupModalTitle = string.Empty;
    private string _indexModalTitle = string.Empty;

    private IEnumerable<EscIndexGroup> FilteredGroups
    {
        get
        {
            var query = _groups.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_groupSearch))
            {
                query = query.Where(x =>
                    Contains(x.GroupCode, _groupSearch) ||
                    Contains(x.GroupName, _groupSearch) ||
                    Contains(x.GroupNameEn, _groupSearch) ||
                    Contains(x.Description, _groupSearch));
            }

            return query
                .OrderBy(x => x.SortOrder)
                .ThenBy(x => x.GroupName);
        }
    }

    private IEnumerable<IndexType> FilteredIndexes
    {
        get
        {
            var query = _indexes.AsEnumerable();

            if (_selectedGroupId.HasValue)
            {
                var selectedGroup = _groups.FirstOrDefault(x => x.Id == _selectedGroupId.Value);

                if (selectedGroup != null)
                {
                    query = query.Where(x => x.GroupCode == selectedGroup.GroupCode);
                }
            }
            else
            {
                query = Enumerable.Empty<IndexType>();
            }

            if (!string.IsNullOrWhiteSpace(_indexSearch))
            {
                query = query.Where(x =>
                    Contains(x.IndexCode, _indexSearch) ||
                    Contains(x.IndexName, _indexSearch) ||
                    Contains(x.IndexNameEn, _indexSearch) ||
                    Contains(x.DataSource, _indexSearch));
            }

            if (_statusFilter == "ACTIVE")
            {
                query = query.Where(x => x.IsActive);
            }
            else if (_statusFilter == "INACTIVE")
            {
                query = query.Where(x => !x.IsActive);
            }

            return query
                .OrderBy(x => x.SortOrder)
                .ThenBy(x => x.IndexName);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _loading = true;
            ClearMessage();

            var groupTask = IndexService.GetIndexGroupsAsync(includeInactive: true);
            var indexTask = IndexService.GetIndexTypesAsync(includeInactive: true);

            await Task.WhenAll(groupTask, indexTask);

            _groups = groupTask.Result ?? new List<EscIndexGroup>();
            _indexes = indexTask.Result ?? new List<IndexType>();

            if (_selectedGroupId.HasValue && !_groups.Any(x => x.Id == _selectedGroupId.Value))
            {
                _selectedGroupId = null;
            }

            if (!_selectedGroupId.HasValue && _groups.Any())
            {
                _selectedGroupId = _groups
                    .OrderBy(x => x.SortOrder)
                    .ThenBy(x => x.GroupName)
                    .First()
                    .Id;
            }
        }
        catch (Exception ex)
        {
            ShowMessage(Text["데이터를 불러오지 못했습니다.|Failed to load data."] + " " + ex.Message, true);
        }
        finally
        {
            _loading = false;
        }
    }

    private void SelectGroup(EscIndexGroup group)
    {
        _selectedGroupId = group.Id;
        _indexSearch = string.Empty;
    }

    private void CreateGroup()
    {
        _groupEdit = new EscIndexGroup
        {
            Guid = Guid.NewGuid(),
            GroupCode = GenerateGroupCode(),
            GroupName = string.Empty,
            GroupNameEn = string.Empty,
            Description = string.Empty,
            IconClass = "fa-solid fa-layer-group",
            SortOrder = GetNextGroupSortOrder(),
            IsActive = true
        };

        _groupModalTitle = Text["새 그룹 등록|Create New Group"];
        _showGroupModal = true;
    }

    private void EditGroup(EscIndexGroup group)
    {
        _groupEdit = CloneGroup(group);
        _groupModalTitle = Text["그룹 수정|Edit Group"];
        _showGroupModal = true;
    }

    private void CloseGroupModal()
    {
        _showGroupModal = false;
        _groupEdit = new EscIndexGroup();
    }

    private async Task SaveGroupAsync()
    {
        if (_saving)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_groupEdit.GroupCode))
        {
            ShowMessage(Text["그룹 코드를 입력하세요.|Please enter group code."], true);
            return;
        }

        if (string.IsNullOrWhiteSpace(_groupEdit.GroupName))
        {
            ShowMessage(Text["그룹명을 입력하세요.|Please enter group name."], true);
            return;
        }

        try
        {
            _saving = true;

            _groupEdit.GroupCode = NormalizeCode(_groupEdit.GroupCode);
            _groupEdit.GroupName = _groupEdit.GroupName?.Trim() ?? string.Empty;
            _groupEdit.GroupNameEn = _groupEdit.GroupNameEn?.Trim() ?? string.Empty;
            _groupEdit.Description = _groupEdit.Description?.Trim() ?? string.Empty;
            _groupEdit.IconClass = string.IsNullOrWhiteSpace(_groupEdit.IconClass)
                ? "fa-solid fa-layer-group"
                : _groupEdit.IconClass.Trim();

            var result = await IndexService.SaveIndexGroupAsync(_groupEdit);

            if (!result.Success)
            {
                ShowMessage(result.Message, true);
                return;
            }

            var savedCode = _groupEdit.GroupCode;

            CloseGroupModal();

            await LoadDataAsync();

            var savedGroup = _groups.FirstOrDefault(x => x.GroupCode == savedCode);
            if (savedGroup != null)
            {
                _selectedGroupId = savedGroup.Id;
            }

            ShowMessage(Text["그룹이 저장되었습니다.|Group saved successfully."], false);
        }
        catch (Exception ex)
        {
            ShowMessage(Text["그룹 저장 중 오류가 발생했습니다.|Error while saving group."] + " " + ex.Message, true);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteGroupAsync(EscIndexGroup group)
    {
        if (group.Id <= 0 || _saving)
        {
            return;
        }

        var confirm = await ConfirmAsync(Text["이 그룹을 삭제하시겠습니까? 연결된 지수가 있으면 비활성 처리됩니다.|Delete this group? If it has linked indexes, it will be deactivated."]);

        if (!confirm)
        {
            return;
        }

        try
        {
            _saving = true;

            var result = await IndexService.DeleteGroupAsync(group.Id);

            if (!result.Success)
            {
                ShowMessage(result.Message, true);
                return;
            }

            CloseGroupModal();
            _selectedGroupId = null;

            await LoadDataAsync();

            ShowMessage(Text["그룹이 삭제 또는 비활성 처리되었습니다.|Group deleted or deactivated successfully."], false);
        }
        catch (Exception ex)
        {
            ShowMessage(Text["그룹 삭제 중 오류가 발생했습니다.|Error while deleting group."] + " " + ex.Message, true);
        }
        finally
        {
            _saving = false;
        }
    }

    private void CreateIndex()
    {
        var selectedGroup = _selectedGroupId.HasValue
            ? _groups.FirstOrDefault(x => x.Id == _selectedGroupId.Value)
            : _groups.Where(x => x.IsActive).OrderBy(x => x.SortOrder).FirstOrDefault();

        if (selectedGroup == null)
        {
            ShowMessage(Text["먼저 그룹을 생성하거나 선택하세요.|Please create or select a group first."], true);
            return;
        }

        _selectedGroupIdForIndex = selectedGroup.Id;

        _indexEdit = new IndexType
        {
            Guid = Guid.NewGuid(),
            IndexGroupId = selectedGroup.Id,
            GroupCode = selectedGroup.GroupCode,
            IndexCode = GenerateIndexCode(selectedGroup),
            IndexName = string.Empty,
            IndexNameEn = string.Empty,
            Type = IndexValueTypeValue,
            Unit = string.Empty,
            DataSource = string.Empty,
            UpdateFreq = "MONTHLY",
            IsPpiType = false,
            SortOrder = GetNextIndexSortOrder(selectedGroup.GroupCode),
            IsActive = true
        };

        _indexModalTitle = Text["새 지수 등록|Create New Index"];
        _showIndexModal = true;
    }

    private void EditIndex(IndexType item)
    {
        _indexEdit = CloneIndex(item);

        var group = _groups.FirstOrDefault(x => x.Id == item.IndexGroupId)
            ?? _groups.FirstOrDefault(x => x.GroupCode == item.GroupCode);

        _selectedGroupIdForIndex = group?.Id;

        _indexModalTitle = Text["지수 수정|Edit Index"];
        _showIndexModal = true;
    }

    private void CloseIndexModal()
    {
        _showIndexModal = false;
        _indexEdit = new IndexType();
        _selectedGroupIdForIndex = null;
    }

    private async Task SaveIndexAsync()
    {
        if (_saving)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_indexEdit.IndexCode))
        {
            ShowMessage(Text["지수 코드를 입력하세요.|Please enter index code."], true);
            return;
        }

        if (string.IsNullOrWhiteSpace(_indexEdit.IndexName))
        {
            ShowMessage(Text["지수명을 입력하세요.|Please enter index name."], true);
            return;
        }

        var group = _groups.FirstOrDefault(x => x.Id == _selectedGroupIdForIndex);

        if (group == null)
        {
            ShowMessage(Text["그룹을 선택하세요.|Please select a group."], true);
            return;
        }

        try
        {
            _saving = true;

            _indexEdit.IndexCode = NormalizeCode(_indexEdit.IndexCode);
            _indexEdit.IndexName = _indexEdit.IndexName?.Trim() ?? string.Empty;
            _indexEdit.IndexNameEn = _indexEdit.IndexNameEn?.Trim() ?? string.Empty;
            _indexEdit.Type = string.IsNullOrWhiteSpace(_indexEdit.Type)
                ? IndexValueTypeValue
                : _indexEdit.Type.Trim();

            _indexEdit.Unit = _indexEdit.Unit?.Trim() ?? string.Empty;
            _indexEdit.DataSource = _indexEdit.DataSource?.Trim() ?? string.Empty;
            _indexEdit.UpdateFreq = string.IsNullOrWhiteSpace(_indexEdit.UpdateFreq)
                ? "MONTHLY"
                : _indexEdit.UpdateFreq.Trim();

            _indexEdit.IndexGroupId = group.Id;
            _indexEdit.GroupCode = group.GroupCode;

            var result = await IndexService.SaveIndexTypeAsync(_indexEdit);

            if (!result.Success)
            {
                ShowMessage(result.Message, true);
                return;
            }

            _selectedGroupId = group.Id;

            CloseIndexModal();

            await LoadDataAsync();

            ShowMessage(Text["지수가 저장되었습니다.|Index saved successfully."], false);
        }
        catch (Exception ex)
        {
            ShowMessage(Text["지수 저장 중 오류가 발생했습니다.|Error while saving index."] + " " + ex.Message, true);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ToggleIndexAsync(IndexType item)
    {
        if (_saving)
        {
            return;
        }

        try
        {
            _saving = true;

            var result = await IndexService.ToggleActiveAsync(item.Id);

            if (!result.Success)
            {
                ShowMessage(result.Message, true);
                return;
            }

            await LoadDataAsync();

            ShowMessage(Text["상태가 변경되었습니다.|Status changed successfully."], false);
        }
        catch (Exception ex)
        {
            ShowMessage(Text["상태 변경 중 오류가 발생했습니다.|Error while changing status."] + " " + ex.Message, true);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteIndexAsync(IndexType item)
    {
        if (item.Id <= 0 || _saving)
        {
            return;
        }

        var confirm = await ConfirmAsync(Text["이 지수를 삭제하시겠습니까? 월별 데이터가 있으면 비활성 처리됩니다.|Delete this index? If it has monthly data, it will be deactivated."]);

        if (!confirm)
        {
            return;
        }

        try
        {
            _saving = true;

            var result = await IndexService.DeleteIndexTypeAsync(item.Id);

            if (!result.Success)
            {
                ShowMessage(result.Message, true);
                return;
            }

            CloseIndexModal();

            await LoadDataAsync();

            ShowMessage(Text["지수가 삭제 또는 비활성 처리되었습니다.|Index deleted or deactivated successfully."], false);
        }
        catch (Exception ex)
        {
            ShowMessage(Text["지수 삭제 중 오류가 발생했습니다.|Error while deleting index."] + " " + ex.Message, true);
        }
        finally
        {
            _saving = false;
        }
    }

    private void OnGroupSearchChanged(ChangeEventArgs e)
    {
        _groupSearch = e.Value?.ToString() ?? string.Empty;
    }

    private void OnIndexSearchChanged(ChangeEventArgs e)
    {
        _indexSearch = e.Value?.ToString() ?? string.Empty;
    }

    private string GetSelectedGroupTitle()
    {
        var group = _groups.FirstOrDefault(x => x.Id == _selectedGroupId);

        if (group == null)
        {
            return Text["그룹을 선택하세요.|Please select a group."];
        }

        return $"{GetGroupDisplayName(group)} · {group.GroupCode}";
    }

    private string GetGroupDisplayName(EscIndexGroup group)
    {
        if (Text.IsKorean)
        {
            return string.IsNullOrWhiteSpace(group.GroupName) ? group.GroupCode : group.GroupName;
        }

        return string.IsNullOrWhiteSpace(group.GroupNameEn) ? group.GroupName : group.GroupNameEn;
    }

    private string GetIndexDisplayName(IndexType item)
    {
        if (Text.IsKorean)
        {
            return string.IsNullOrWhiteSpace(item.IndexName) ? item.IndexCode : item.IndexName;
        }

        return string.IsNullOrWhiteSpace(item.IndexNameEn) ? item.IndexName : item.IndexNameEn;
    }

    private string GetGroupNameByCode(string groupCode)
    {
        var group = _groups.FirstOrDefault(x => x.GroupCode == groupCode);

        return group == null ? groupCode : GetGroupDisplayName(group);
    }

    private string GetTypeText(string type)
    {
        if (string.Equals(type, IndexValueTypeValue, StringComparison.OrdinalIgnoreCase))
        {
            return Text["값형|Value"];
        }

        if (string.Equals(type, IndexValueTypeRate, StringComparison.OrdinalIgnoreCase))
        {
            return Text["요율형|Rate"];
        }

        if (string.Equals(type, IndexValueTypeUnitPrice, StringComparison.OrdinalIgnoreCase))
        {
            return Text["단가형|Unit Price"];
        }

        return type;
    }

    private static bool Contains(string source, string keyword)
    {
        return !string.IsNullOrWhiteSpace(source)
            && source.Contains(keyword ?? string.Empty, StringComparison.OrdinalIgnoreCase);
    }

    private static string NormalizeCode(string value)
    {
        return (value ?? string.Empty)
            .Trim()
            .Replace(" ", "_")
            .Replace("-", "_")
            .ToUpperInvariant();
    }

    private string GenerateGroupCode()
    {
        var next = _groups.Count + 1;

        string code;

        do
        {
            code = $"GROUP_{next:D2}";
            next++;
        }
        while (_groups.Any(x => string.Equals(x.GroupCode, code, StringComparison.OrdinalIgnoreCase)));

        return code;
    }

    private string GenerateIndexCode(EscIndexGroup group)
    {
        var prefix = string.IsNullOrWhiteSpace(group.GroupCode)
            ? "IDX"
            : group.GroupCode;

        var next = _indexes.Count(x => x.GroupCode == group.GroupCode) + 1;

        string code;

        do
        {
            code = $"{prefix}_{next:D3}";
            next++;
        }
        while (_indexes.Any(x => string.Equals(x.IndexCode, code, StringComparison.OrdinalIgnoreCase)));

        return code;
    }

    private int GetNextGroupSortOrder()
    {
        return _groups.Any() ? _groups.Max(x => x.SortOrder) + 10 : 10;
    }

    private int GetNextIndexSortOrder(string groupCode)
    {
        var list = _indexes.Where(x => x.GroupCode == groupCode).ToList();

        return list.Any() ? list.Max(x => x.SortOrder) + 10 : 10;
    }

    private static string GetIcon(string icon)
    {
        return string.IsNullOrWhiteSpace(icon) ? "fa-solid fa-layer-group" : icon;
    }

