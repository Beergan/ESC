    .esc-alert { margin-bottom: 14px; padding: 12px 14px; border-radius: 14px; font-size: 13px; font-weight: 800; }
    .esc-alert.success { background: #ecfdf3; color: #16803c; border: 1px solid #bbf7d0; }
    .esc-alert.error { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
    .floating-save { position: fixed; left: 24px; right: 24px; bottom: 18px; z-index: 1200; background: #12345a; color: #fff; border-radius: 18px; padding: 14px 18px; box-shadow: 0 18px 42px rgba(15, 23, 42, .24); display: flex; justify-content: space-between; align-items: center; gap: 14px; font-weight: 900; font-size: 13px; }
    @@media (max-width: 900px) { .esc-admin-page { padding: 18px; } .esc-page-header, .esc-month-control, .esc-card-header, .floating-save { flex-direction: column; align-items: stretch; } }
</style>

@code {
    private const string AllGroupCode = "__ALL__";

    private class MonthlyRow
    {
        public int IndexTypeId { get; set; }
        public string IndexCode { get; set; } = string.Empty;
        public string IndexName { get; set; } = string.Empty;
        public string IndexNameEn { get; set; } = string.Empty;
        public string GroupCode { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string Unit { get; set; } = string.Empty;
        public int SortOrder { get; set; }
        public decimal IndexValue { get; set; }
        public bool DataVerified { get; set; }
    }

    private bool _loading;
    private bool _saving;
    private bool _dataLoaded;

    private int _selectedYear = DateTime.Now.Year;
    private int _selectedMonth = DateTime.Now.Month;

    private string _selectedGroupCode = AllGroupCode;
    private string _message = string.Empty;
    private bool _isError;

    private List<EscIndexGroup> _groups = new();
    private List<IndexType> _indexTypes = new();
    private List<MonthlyRow> _rows = new();

    private readonly HashSet<int> _changedSet = new();

    private bool _hasChanges => _changedSet.Count > 0;

    private bool IsAllGroupSelected => _selectedGroupCode == AllGroupCode;

    private string CurrentPeriodKey => $"{_selectedYear}{_selectedMonth:D2}";

    private string DisplayPeriod => $"{_selectedYear}.{_selectedMonth:D2}";

    private IEnumerable<EscIndexGroup> ActiveGroups =>
        _groups.Where(x => x.IsActive).OrderBy(x => x.SortOrder).ThenBy(x => x.GroupName);

    private IEnumerable<MonthlyRow> FilteredRows
    {
        get
        {
            var query = _rows.AsEnumerable();

            if (!IsAllGroupSelected)
            {
                query = query.Where(x => x.GroupCode == _selectedGroupCode);
            }

            return query
                .OrderBy(x => GetGroupSortOrder(x.GroupCode))
                .ThenBy(x => x.SortOrder)
                .ThenBy(x => x.IndexName);
        }
    }

    private int _totalCount => _rows.Count;
    private int _enteredCount => _rows.Count(x => x.IndexValue != 0);
    private int _verifiedCount => _rows.Count(x => x.DataVerified);
    private int _missingCount => _rows.Count(x => x.IndexValue == 0);

    protected override async Task OnInitializedAsync()
    {
        await LoadBaseDataAsync();
    }

    private async Task LoadBaseDataAsync()
    {
        try
        {
            _loading = true;
            _message = string.Empty;

            var groupTask = IndexService.GetIndexGroupsAsync(includeInactive: false);
            var indexTask = IndexService.GetIndexTypesAsync(includeInactive: false);

            await Task.WhenAll(groupTask, indexTask);

            _groups = groupTask.Result ?? new List<EscIndexGroup>();
            _indexTypes = indexTask.Result ?? new List<IndexType>();

            await SearchPeriodAsync();
        }
        catch (Exception ex)
        {
            ShowMessage(Text["기본 데이터를 불러오지 못했습니다.|Failed to load base data."] + " " + ex.Message, true);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SearchPeriodAsync()
    {
        try
        {
            _loading = true;
            _message = string.Empty;

            var timeSeries = await IndexService.GetTimeSeriesAsync(year: _selectedYear);

            var periodData = timeSeries
                .Where(x => x.PeriodKey == CurrentPeriodKey)
                .GroupBy(x => x.IndexTypeId)
                .ToDictionary(x => x.Key, x => x.OrderByDescending(y => y.Id).First());

            _rows = _indexTypes
                .Where(x => x.IsActive)
                .OrderBy(x => GetGroupSortOrder(x.GroupCode))
                .ThenBy(x => x.SortOrder)
                .ThenBy(x => x.IndexName)
                .Select(index =>
                {
                    periodData.TryGetValue(index.Id, out var saved);

                    return new MonthlyRow
                    {
                        IndexTypeId = index.Id,
                        IndexCode = index.IndexCode,
                        IndexName = index.IndexName,
                        IndexNameEn = index.IndexNameEn,
                        GroupCode = index.GroupCode,
                        Type = index.Type,
                        Unit = index.Unit,
                        SortOrder = index.SortOrder,
                        IndexValue = saved?.IndexValue ?? 0,
                        DataVerified = saved?.DataVerified ?? false
                    };
                })
                .ToList();

            _changedSet.Clear();
            _dataLoaded = true;
        }
        catch (Exception ex)
        {
            ShowMessage(Text["월별 데이터를 조회하지 못했습니다.|Failed to search monthly data."] + " " + ex.Message, true);
        }
        finally
        {
            _loading = false;
        }
    }

    private void SelectGroup(string groupCode)
    {
        _selectedGroupCode = groupCode;
    }

    private void OnValueChanged(MonthlyRow row, ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();

        if (decimal.TryParse(raw, out var value))
        {
            row.IndexValue = value;
            _changedSet.Add(row.IndexTypeId);
            return;
        }

        ShowMessage(Text["숫자만 입력할 수 있습니다.|Only numbers are allowed."], true);
    }

    private void OnVerifyChanged(MonthlyRow row, ChangeEventArgs e)
    {
        row.DataVerified = e.Value is bool boolValue
            ? boolValue
            : bool.TryParse(e.Value?.ToString(), out var parsed) && parsed;

        _changedSet.Add(row.IndexTypeId);
    }

    private void VerifyAll()
    {
        foreach (var row in FilteredRows)
        {
            row.DataVerified = true;
            _changedSet.Add(row.IndexTypeId);
        }
    }

    private void UnverifyAll()
    {
        foreach (var row in FilteredRows)
        {
            row.DataVerified = false;
            _changedSet.Add(row.IndexTypeId);
        }
    }

    private async Task SaveAllAsync()
    {
        if (!_hasChanges)
        {
            return;
        }

        try
        {
            _saving = true;

            var entries = _rows
                .Where(x => _changedSet.Contains(x.IndexTypeId))
                .Select(x => new IndexTimeSeries
                {
                    IndexTypeId = x.IndexTypeId,
                    PeriodKey = CurrentPeriodKey,
                    Year = _selectedYear,
                    Month = _selectedMonth,
                    IndexValue = x.IndexValue,
                    DataVerified = x.DataVerified
                })
                .ToList();

            var result = await IndexService.SaveTimeSeriesBatchAsync(entries);

            if (!result.Success)
            {
                ShowMessage(result.Message, true);
                return;
            }

            _changedSet.Clear();

            ShowMessage(Text["월별 지수 데이터가 저장되었습니다.|Monthly index data saved successfully."], false);
        }
        catch (Exception ex)
        {
            ShowMessage(Text["저장 중 오류가 발생했습니다.|Error while saving."] + " " + ex.Message, true);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task CopyPreviousMonthAsync()
    {
        try
        {
            _saving = true;

            var result = await IndexService.CopyFromPreviousMonthAsync(CurrentPeriodKey);

            if (!result.Success)
            {
                ShowMessage(result.Message, true);
                return;
            }

            await SearchPeriodAsync();

            ShowMessage(Text["이전 월 데이터를 복사했습니다.|Previous month data copied successfully."], false);
        }
        catch (Exception ex)
        {
            ShowMessage(Text["이전 월 복사 중 오류가 발생했습니다.|Error while copying previous month."] + " " + ex.Message, true);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteMonthAsync()
    {
        try
        {
            _saving = true;

            var result = await IndexService.DeleteMonthAsync(CurrentPeriodKey);

            if (!result.Success)
            {
                ShowMessage(result.Message, true);
                return;
            }

            await SearchPeriodAsync();

            ShowMessage(Text["해당 월 데이터가 삭제되었습니다.|Month data deleted successfully."], false);
        }
        catch (Exception ex)
        {
            ShowMessage(Text["월 데이터 삭제 중 오류가 발생했습니다.|Error while deleting month data."] + " " + ex.Message, true);
        }
        finally
        {
            _saving = false;
        }
    }

    private string GetGroupDisplayName(EscIndexGroup group)
    {
        if (Text.IsKorean)
        {
            return string.IsNullOrWhiteSpace(group.GroupName) ? group.GroupCode : group.GroupName;
        }

        return string.IsNullOrWhiteSpace(group.GroupNameEn) ? group.GroupName : group.GroupNameEn;
    }

    private string GetGroupName(string groupCode)
    {
        var group = _groups.FirstOrDefault(x => x.GroupCode == groupCode);

        return group == null ? groupCode : GetGroupDisplayName(group);
    }

    private string GetRowDisplayName(MonthlyRow row)
    {
        if (Text.IsKorean)
        {
            return string.IsNullOrWhiteSpace(row.IndexName) ? row.IndexCode : row.IndexName;
        }

        return string.IsNullOrWhiteSpace(row.IndexNameEn) ? row.IndexName : row.IndexNameEn;
    }

    private int GetGroupSortOrder(string groupCode)
    {
        var group = _groups.FirstOrDefault(x => x.GroupCode == groupCode);

        return group?.SortOrder ?? 9999;
    }

    private static string GetIcon(string icon)
    {
        return string.IsNullOrWhiteSpace(icon) ? "fa-solid fa-layer-group" : icon;
    }

    private static string GetRowClass(MonthlyRow row)
    {
        var classes = new List<string>();

        if (row.IndexValue == 0)
        {
            classes.Add("row-missing");
        }

        if (row.DataVerified)
        {
            classes.Add("row-verified");
        }

        return string.Join(" ", classes);
    }

    private void ShowMessage(string message, bool isError)
    {
        _message = message;
        _isError = isError;
    }
}