@code {
    private List<EscFormulaSetting> _formulas = new();
    private List<EscFormulaVariable> _variables = new();
    
    private EscFormulaSetting? _selectedFormula;
    private EscFormulaSetting _editModel = new();
    
    private bool _loading = true;
    private string? _message;
    private bool _success;
    private string _focusedInput = string.Empty;
    private Dictionary<string, decimal>? _testResults;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _formulas = await FormulaService.GetFormulasAsync();
            _variables = await FormulaService.GetVariablesAsync();
            
            if (_formulas.Count > 0 && _selectedFormula == null)
            {
                SelectFormula(_formulas.First());
            }
        }
        catch (Exception ex)
        {
            ShowMessage(false, Text["데이터를 불러오는 중 오류가 발생했습니다.|Error loading data."]);
        }
        finally
        {
            _loading = false;
        }
    }

    private void SelectFormula(EscFormulaSetting formula)
    {
        _selectedFormula = formula;
        _testResults = null;
        
        // Clone for edit
        _editModel = new EscFormulaSetting
        {
            Id = formula.Id,
            Guid = formula.Guid,
            FormulaCode = formula.FormulaCode,
            FormulaName = formula.FormulaName,
            FormulaNameEn = formula.FormulaNameEn,
            VersionNo = formula.VersionNo,
            
            WeightFormula = formula.WeightFormula,
            IndexRatioFormula = formula.IndexRatioFormula,
            WeightedRatioFormula = formula.WeightedRatioFormula,
            CompositeFormula = formula.CompositeFormula,
            AdjustmentRateFormula = formula.AdjustmentRateFormula,
            ApplicableAmountFormula = formula.ApplicableAmountFormula,
            GrossAdjustmentFormula = formula.GrossAdjustmentFormula,
            AdvanceDeductionFormula = formula.AdvanceDeductionFormula,
            FinalAdjustmentFormula = formula.FinalAdjustmentFormula,
            EligibleConditionFormula = formula.EligibleConditionFormula,
            
            ThresholdRate = formula.ThresholdRate,
            ThresholdDays = formula.ThresholdDays,
            RoundingMethod = formula.RoundingMethod,
            DecimalPlaces = formula.DecimalPlaces,
            UseAdvanceDeduction = formula.UseAdvanceDeduction,
            OtherDeductionDefault = formula.OtherDeductionDefault,
            
            IsCurrent = formula.IsCurrent,
            IsActive = formula.IsActive,
            SortOrder = formula.SortOrder,
            Description = formula.Description
        };
    }

    private void CreateFormula()
    {
        _selectedFormula = new EscFormulaSetting();
        _editModel = new EscFormulaSetting
        {
            WeightFormula = "Amount / TotalCost",
            IndexRatioFormula = "CompareIndex / BaseIndex",
            WeightedRatioFormula = "Weight * IndexRatio",
            CompositeFormula = "SUM(WeightedRatio)",
            AdjustmentRateFormula = "(CompositeCoefficient - 1) * 100",
            ApplicableAmountFormula = "ContractAmount - ExcludedAmount",
            GrossAdjustmentFormula = "ApplicableAmount * AdjustmentRate / 100",
            AdvanceDeductionFormula = "AdvanceAmount / ContractAmount * GrossAdjustmentAmount",
            FinalAdjustmentFormula = "GrossAdjustmentAmount - AdvanceDeduction - OtherDeduction",
            EligibleConditionFormula = "AdjustmentRate >= ThresholdRate AND ElapsedDays >= ThresholdDays",
            ThresholdRate = 3.0m,
            ThresholdDays = 90
        };
        _testResults = null;
    }

    private void DuplicateFormula()
    {
        if (_selectedFormula == null) return;
        
        _editModel.Id = 0;
        _editModel.Guid = Guid.Empty;
        _editModel.FormulaCode = _editModel.FormulaCode + "_COPY";
        _editModel.FormulaName = _editModel.FormulaName + " (Copy)";
        _editModel.IsCurrent = false;
        
        _selectedFormula = new EscFormulaSetting();
        _testResults = null;
    }

    private async Task SaveFormulaAsync()
    {
        var res = await FormulaService.SaveFormulaAsync(_editModel);
        if (res.Success)
        {
            ShowMessage(true, res.Message);
            await LoadAsync();
            
            // Re-select the saved one
            var saved = _formulas.FirstOrDefault(x => x.FormulaCode == _editModel.FormulaCode);
            if (saved != null) SelectFormula(saved);
        }
        else
        {
            ShowMessage(false, res.Message);
        }
    }

    private async Task SetCurrentAsync(Guid guid)
    {
        if (guid == Guid.Empty) return;
        
        // Ensure user wants to change current
        var res = await FormulaService.SetActiveAsync(guid);
        if (res.Success)
        {
            ShowMessage(true, res.Message);
            await LoadAsync();
        }
        else
        {
            ShowMessage(false, res.Message);
        }
    }

    private async Task TestFormula()
    {
        // Mock variables
        var mockVars = new Dictionary<string, decimal>
        {
            { "Amount", 1500000 },
            { "TotalCost", 10000000 },
            { "BaseIndex", 100 },
            { "CompareIndex", 105.5m },
            { "ContractAmount", 12000000 },
            { "ExcludedAmt", 500000 },
            { "AdvanceAmt", 1000000 },
            { "ElapsedDays", 120 }
        };

        var res = await FormulaService.TestFormulaAsync(_editModel, mockVars);
        if (res.Success && res.Item != null)
        {
            _testResults = res.Item;
            ShowMessage(true, Text["테스트 성공|Test successful"]);
        }
        else
        {
            _testResults = null;
            ShowMessage(false, res.Message);
        }
    }

    private void SetFocusedInput(string inputName)
    {
        _focusedInput = inputName;
    }

    private void InsertToken(string token)
    {
        if (string.IsNullOrEmpty(_focusedInput)) return;

        var prop = typeof(EscFormulaSetting).GetProperty(_focusedInput);
        if (prop != null && prop.PropertyType == typeof(string))
        {
            var currentValue = prop.GetValue(_editModel) as string ?? "";
            prop.SetValue(_editModel, currentValue + token);
            StateHasChanged();
        }
    }

    private void ShowMessage(bool success, string msg)
    {
        _success = success;
        _message = msg;
        StateHasChanged();
    }
}