@page "/management/esc-formula-setting"

@inject ITextTranslator Text
@inject IEscFormulaSettingService FormulaService
@inject IJSRuntime JS


@using ESC.CONCOST.Abstract
@using ESC.CONCOST.ModuleSettingCore
@using Microsoft.AspNetCore.Components.Forms

<div class="esc-formula-page">
    <style>
        /* --- Driver.js Custom Theme --- */
        .driver-popover.driverjs-theme {
            background-color: #ffffff;
            color: #1e3a5f;
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 15px 50px rgba(30, 58, 95, 0.2);
            border: 1px solid rgba(30, 58, 95, 0.08);
            max-width: 350px;
        }

        .driver-popover.driverjs-theme .driver-popover-title {
            font-size: 18px !important;
            font-weight: 800 !important;
            color: #1e3a5f !important;
            margin-bottom: 8px !important;
            font-family: 'Inter', 'Noto Sans KR', sans-serif;
        }

        .driver-popover.driverjs-theme .driver-popover-description {
            font-size: 14px !important;
            color: #475569 !important;
            line-height: 1.6 !important;
            margin-bottom: 15px !important;
        }

        .driver-popover.driverjs-theme .driver-popover-navigation-btns {
            justify-content: flex-end;
            gap: 8px;
        }

        .driver-popover.driverjs-theme .driver-popover-navigation-btns button {
            background-color: #1e3a5f !important;
            color: #ffffff !important;
            border: none !important;
            border-radius: 8px !important;
            padding: 8px 16px !important;
            font-size: 12px !important;
            font-weight: 700 !important;
            text-shadow: none !important;
            transition: all 0.2s;
            box-shadow: 0 4px 12px rgba(30, 58, 95, 0.15);
        }

        .driver-popover.driverjs-theme .driver-popover-navigation-btns button:hover {
            background-color: #0d2137 !important;
            transform: translateY(-1px);
            box-shadow: 0 6px 15px rgba(30, 58, 95, 0.25);
        }

        .driver-popover.driverjs-theme .driver-popover-arrow {
            border-color: #ffffff !important;
        }
        
        .driver-popover.driverjs-theme .driver-popover-progress-text {
            color: #94a3b8;
            font-size: 11px;
            font-weight: 600;
        }
    </style>
    <div class="esc-formula-hero">
        <div class="esc-formula-hero-left">
            <div class="esc-formula-kicker">
                <i class="fa-solid fa-calculator"></i>
                @Text["관리자 설정|Admin Setting"]
            </div>

            <h2>@Text["ESC 계산식 설정|ESC Formula Setting"]</h2>

            <p>
                @Text["관리자가 ESC 계산식, 조정 조건, 반올림 방식, 선금공제 기준을 관리합니다. 현재 적용 계산식은 모든 사용자 계산에 자동 적용됩니다.|Admin manages ESC formulas, eligibility conditions, rounding, and advance deduction. The current formula is applied automatically to all user calculations."]
            </p>

            <div class="esc-current-box">
                <span>@Text["현재 적용 계산식|Current Applied Formula"]</span>
                <strong>@(_currentFormula?.FormulaCode ?? "-")</strong>

                @if (_currentFormula != null)
                {
                    <em>@GetFormulaDisplayName(_currentFormula)</em>
                    <em>Ver @_currentFormula.VersionNo</em>
                }
            </div>
        </div>

        <div class="esc-hero-actions">
            <button type="button"
                    class="btn esc-btn-primary"
                    data-guide="create-button"
                    @onclick="CreateFormula">
                <i class="fa-solid fa-plus"></i>
                @Text["새 계산식|New Formula"]
            </button>

            <button type="button"
                    class="btn esc-btn-outline"
                    disabled="@(_selectedFormula == null)"
                    @onclick="DuplicateFormula">
                <i class="fa-solid fa-copy"></i>
                @Text["복사 생성|Duplicate"]
            </button>

            <button type="button"
                    class="btn esc-btn-outline"
                    disabled="@(!CanSetCurrent)"
                    @onclick="SetCurrentSelectedAsync">
                <i class="fa-solid fa-star"></i>
                @Text["현재 계산식으로 설정|Set Current"]
            </button>

            <button type="button"
                    class="btn esc-btn-danger-outline"
                    disabled="@(!CanDeleteSelected)"
                    @onclick="OpenDeleteConfirm">
                <i class="fa-solid fa-trash-can"></i>
                @Text["삭제|Delete"]
            </button>

            <button type="button"
                    class="btn esc-btn-outline"
                    @onclick="LoadAsync">
                <i class="fa-solid fa-rotate"></i>
                @Text["새로고침|Refresh"]
            </button>

            <button type="button" 
                    class="btn btn-outline-info" 
                    @onclick="ShowGuide">
                <i class="fa-solid fa-circle-question"></i>
                @Text["도움말|Guide"]
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert @(_success ? "alert-success" : "alert-danger") esc-message alert-dismissible fade show">
            @_message
            <button type="button" class="btn-close" @onclick="ClearMessage"></button>
        </div>
    }

    <div class="esc-layout">
        <aside class="esc-library" data-guide="formula-list">
            <div class="esc-library-header">
                <div>
                    <h3>@Text["계산식 목록|Formula Library"]</h3>
                    <p>@Text["Current 표시가 있는 계산식이 실제 사용자 계산에 적용됩니다.|The formula marked Current is used for user calculations."]</p>
                </div>

                <span>@_formulas.Count</span>
            </div>

            @if (_loading)
            {
                <div class="esc-empty">
                    <i class="fa-solid fa-spinner fa-spin"></i>
                    <p>@Text["불러오는 중입니다...|Loading..."]</p>
                </div>
            }
            else if (_formulas.Count == 0)
            {
                <div class="esc-empty">
                    <i class="fa-regular fa-folder-open"></i>
                    <p>@Text["등록된 계산식이 없습니다.|No formulas found."]</p>
                </div>
            }
            else
            {
                <div class="esc-formula-list">
                    @foreach (var item in _formulas)
                    {
                        <button type="button"
                                class="esc-formula-item @(item.Guid == _selectedFormula?.Guid ? "active" : "") @(item.IsActive ? "" : "inactive")"
                                @onclick="() => SelectFormula(item)">
                            <div class="formula-item-top">
                                <strong>@GetFormulaDisplayName(item)</strong>

                                <div class="formula-badges">
                                    @if (item.IsCurrent)
                                    {
                                        <span class="badge-current">Current</span>
                                    }

                                    @if (item.IsDefault)
                                    {
                                        <span class="badge-default">Default</span>
                                    }

                                    @if (!item.IsActive)
                                    {
                                        <span class="badge-inactive">Inactive</span>
                                    }
                                </div>
                            </div>

                            <div class="formula-item-code">
                                <i class="fa-solid fa-code"></i>
                                @item.FormulaCode
                            </div>

                            <div class="formula-item-meta">
                                <span>Ver @item.VersionNo</span>
                                <span>@Text["정렬|Sort"] @item.SortOrder</span>
                            </div>

                            <p>@GetFormulaAdminDescription(item)</p>
                        </button>
                    }
                </div>
            }
        </aside>

        <main class="esc-workspace">
            @if (_selectedFormula == null)
            {
                <div class="esc-empty esc-empty-large">
                    <i class="fa-solid fa-hand-pointer"></i>
                    <p>@Text["계산식을 선택하거나 새로 생성하세요.|Select or create a formula."]</p>
                </div>
            }
            else
            {
                <EditForm Model="_editModel" OnValidSubmit="SaveFormulaAsync">
                    <DataAnnotationsValidator />

                    <div class="formula-status @GetStatusClass()" data-guide="formula-status">
                        <div>
                            <strong>@GetStatusTitle()</strong>
                            <p>@GetStatusDescription()</p>
                        </div>
                    </div>

                    <div class="esc-tabs">
                        <button type="button"
                                class="@GetTabClass("basic")"
                                data-guide="tab-basic"
                                @onclick='() => SetTab("basic")'>
                            <i class="fa-solid fa-circle-info"></i>
                            @Text["기본 정보|Basic"]
                        </button>

                        <button type="button"
                                class="@GetTabClass("option")"
                                data-guide="tab-option"
                                @onclick='() => SetTab("option")'>
                            <i class="fa-solid fa-sliders"></i>
                            @Text["조건/옵션|Options"]
                        </button>

                        <button type="button"
                                class="@GetTabClass("formula")"
                                data-guide="tab-formula"
                                @onclick='() => SetTab("formula")'>
                            <i class="fa-solid fa-square-root-variable"></i>
                            @Text["계산식|Formula"]
                        </button>

                        <button type="button"
                                class="@GetTabClass("test")"
                                data-guide="tab-test"
                                @onclick='() => SetTab("test")'>
                            <i class="fa-solid fa-vial"></i>
                            @Text["테스트|Test"]
                        </button>
                    </div>

                    @if (_activeTab == "basic")
                    {
                        <section class="esc-card">
                            <div class="esc-card-title">
                                <h3>@Text["기본 정보|Basic Information"]</h3>
                                <p>@Text["관리자가 구분하기 쉬운 코드와 이름을 입력합니다.|Enter a code and name that admins can easily recognize."]</p>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-4" data-guide="formula-code">
                                    <label class="esc-label">@Text["계산식 코드|Formula Code"] <b>*</b></label>
                                    <InputText class="form-control esc-input"
                                               placeholder="ESC_2026_V1"
                                               @bind-Value="_editModel.FormulaCode" />
                                    <small>@Text["예: ESC_2026_V1|Example: ESC_2026_V1"]</small>
                                </div>

                                <div class="col-md-4" data-guide="formula-name">
                                    <label class="esc-label">@Text["이름(한국어)|Name Korean"] <b>*</b></label>
                                    <InputText class="form-control esc-input"
                                               placeholder="@Text["기본 ESC 계산식|Default ESC Formula"]"
                                               @bind-Value="_editModel.FormulaName" />
                                </div>

                                <div class="col-md-4">
                                    <label class="esc-label">@Text["이름(영어)|Name English"]</label>
                                    <InputText class="form-control esc-input"
                                               placeholder="Default ESC Formula"
                                               @bind-Value="_editModel.FormulaNameEn" />
                                </div>

                                <div class="col-md-3">
                                    <label class="esc-label">@Text["버전|Version"]</label>
                                    <InputNumber class="form-control esc-input" @bind-Value="_editModel.VersionNo" />
                                </div>

                                <div class="col-md-3">
                                    <label class="esc-label">@Text["정렬 순서|Sort Order"]</label>
                                    <InputNumber class="form-control esc-input" @bind-Value="_editModel.SortOrder" />
                                </div>

                                <div class="col-md-6">
                                    <label class="esc-label">@Text["상태|Status"]</label>

                                    <div class="esc-check-grid" data-guide="formula-status-options">
                                        <label class="esc-check">
                                            <InputCheckbox @bind-Value="_editModel.IsActive" />
                                            <span>
                                                <strong>@Text["사용 가능|Active"]</strong>
                                                <small>@Text["계산식 목록에서 사용 가능한 상태입니다.|Formula can be used."]</small>
                                            </span>
                                        </label>

                                        <label class="esc-check">
                                            <InputCheckbox @bind-Value="_editModel.IsCurrent" />
                                            <span>
                                                <strong>@Text["현재 적용|Current"]</strong>
                                                <small>@Text["모든 사용자 계산에 적용됩니다.|Applied to all users."]</small>
                                            </span>
                                        </label>

                                        <label class="esc-check">
                                            <InputCheckbox @bind-Value="_editModel.IsDefault" />
                                            <span>
                                                <strong>@Text["기본값|Default"]</strong>
                                                <small>@Text["시스템 기본 계산식으로 표시합니다.|Marked as default."]</small>
                                            </span>
                                        </label>
                                    </div>
                                </div>

                                <div class="col-md-12">
                                    <label class="esc-label">@Text["설명|Description"]</label>
                                    <InputTextArea class="form-control esc-input"
                                                   rows="3"
                                                   placeholder="@Text["변경 사유나 설명을 입력하세요.|Enter reason or description."]"
                                                   @bind-Value="_editModel.Description" />
                                </div>
                            </div>
                        </section>
                    }

                    @if (_activeTab == "option")
                    {
                        <section class="esc-card">
                            <div class="esc-card-title">
                                <h3>@Text["조건 및 옵션|Conditions & Options"]</h3>
                                <p>@Text["조정 가능 여부 판단 기준과 반올림 방식을 설정합니다.|Set eligibility thresholds and rounding method."]</p>
                            </div>

                            <div class="row g-3" data-guide="condition-area">
                                <div class="col-md-3">
                                    <label class="esc-label">@Text["등락율 기준 (%)|Threshold Rate (%)"]</label>
                                    <InputNumber class="form-control esc-input" @bind-Value="_editModel.ThresholdRate" />
                                    <small>@Text["기본값 3%|Default 3%"]</small>
                                </div>

                                <div class="col-md-3">
                                    <label class="esc-label">@Text["경과일수 기준|Threshold Days"]</label>
                                    <InputNumber class="form-control esc-input" @bind-Value="_editModel.ThresholdDays" />
                                    <small>@Text["기본값 90일|Default 90 days"]</small>
                                </div>

                                <div class="col-md-3">
                                    <label class="esc-label">@Text["반올림 방식|Rounding Method"]</label>
                                    <InputSelect class="form-select esc-input" @bind-Value="_editModel.RoundingMethod">
                                        <option value="@BasicCodes.EscFormulaRounding.Round">@Text["반올림|Round"]</option>
                                        <option value="@BasicCodes.EscFormulaRounding.Floor">@Text["내림|Floor"]</option>
                                        <option value="@BasicCodes.EscFormulaRounding.Ceiling">@Text["올림|Ceiling"]</option>
                                        <option value="@BasicCodes.EscFormulaRounding.None">@Text["없음|None"]</option>
                                    </InputSelect>
                                </div>

                                <div class="col-md-3">
                                    <label class="esc-label">@Text["소수점 자릿수|Decimal Places"]</label>
                                    <InputNumber class="form-control esc-input" @bind-Value="_editModel.DecimalPlaces" />
                                </div>

                                <div class="col-md-4">
                                    <label class="esc-label">@Text["기타 공제액 기본값|Other Deduction Default"]</label>
                                    <InputNumber class="form-control esc-input" @bind-Value="_editModel.OtherDeductionDefault" />
                                </div>

                                <div class="col-md-8">
                                    <label class="esc-label">@Text["선금공제 사용 여부|Advance Deduction"]</label>

                                    <label class="esc-check wide">
                                        <InputCheckbox @bind-Value="_editModel.UseAdvanceDeduction" />
                                        <span>
                                            <strong>@Text["선금공제를 계산에 포함합니다.|Include advance deduction in calculation."]</strong>
                                            <small>@Text["체크하면 선금공제 계산식이 최종 조정금액에 반영됩니다.|If checked, advance deduction formula is applied."]</small>
                                        </span>
                                    </label>
                                </div>
                            </div>
                        </section>
                    }

                    @if (_activeTab == "formula")
                    {
                        <section class="esc-card">
                            <div class="esc-card-title">
                                <h3>@Text["계산식 작성|Formula Configuration"]</h3>
                                <p>@Text["입력칸을 클릭한 뒤 변수나 연산자를 누르면 자동으로 추가됩니다.|Click an input field, then click variables or operators to insert them."]</p>
                            </div>

                            <div class="formula-help" data-guide="formula-help">
                                <strong>@Text["관리자 안내|Admin Guide"]</strong>
                                <p>
                                    @Text["잘 모르면 기본값을 유지하세요. 수정 후 반드시 테스트 계산을 실행하세요.|If unsure, keep defaults. After editing, always run test calculation."]
                                </p>

                                <div class="formula-examples">
                                    <code>Amount / TotalCost</code>
                                    <code>CompareIndex / BaseIndex</code>
                                    <code>Weight * IndexRatio</code>
                                    <code>SUM(WeightedRatio)</code>
                                    <code>(CompositeCoefficient - 1) * 100</code>
                                </div>
                            </div>

                            <div class="formula-layout">
                                <div class="formula-sidebar">
                                    <h4>
                                        <i class="fa-solid fa-cubes"></i>
                                        @Text["변수 목록|Variables"]
                                    </h4>

                                    <div class="variable-list">
                                        @foreach (var variable in _variables)
                                        {
                                            <button type="button"
                                                    class="variable-chip"
                                                    @onclick="() => InsertToken(variable.VariableCode)">
                                                <strong>@variable.VariableCode</strong>
                                                <span>@(Text.IsKorean ? variable.VariableName : variable.VariableNameEn)</span>
                                            </button>
                                        }
                                    </div>

                                    <h4 class="mt-3">
                                        <i class="fa-solid fa-square-root-variable"></i>
                                        @Text["연산자|Operators"]
                                    </h4>

                                    <div class="operator-list">
                                        <button type="button" @onclick='() => InsertToken(" + ")'>+</button>
                                        <button type="button" @onclick='() => InsertToken(" - ")'>-</button>
                                        <button type="button" @onclick='() => InsertToken(" * ")'>*</button>
                                        <button type="button" @onclick='() => InsertToken(" / ")'>/</button>
                                        <button type="button" @onclick='() => InsertToken(" ( ")'>(</button>
                                        <button type="button" @onclick='() => InsertToken(" ) ")'>)</button>
                                        <button type="button" @onclick='() => InsertToken("SUM(WeightedRatio)")'>SUM</button>
                                        <button type="button" @onclick='() => InsertToken(" >= ")'>&gt;=</button>
                                        <button type="button" @onclick='() => InsertToken(" <= ")'>&lt;=</button>
                                        <button type="button" @onclick='() => InsertToken(" AND ")'>AND</button>
                                        <button type="button" @onclick='() => InsertToken(" OR ")'>OR</button>
                                    </div>
                                </div>

                                <div class="formula-inputs">
                                    @RenderFormulaInput(
                                        Text["1. 가중치 계산식|1. Weight Formula"],
                                        "WeightFormula",
                                        Text["각 비목 금액이 전체 금액에서 차지하는 비율입니다.|Ratio of item amount to total amount."],
                                        _editModel.WeightFormula,
                                        nameof(_editModel.WeightFormula),
                                        "weight-formula",
                                        value => _editModel.WeightFormula = value)

                                    @RenderFormulaInput(
                                        Text["2. 지수비율 계산식|2. Index Ratio Formula"],
                                        "IndexRatioFormula",
                                        Text["비교월 지수를 기준월 지수로 나눈 값입니다.|Compare index divided by base index."],
                                        _editModel.IndexRatioFormula,
                                        nameof(_editModel.IndexRatioFormula),
                                        "",
                                        value => _editModel.IndexRatioFormula = value)

                                    @RenderFormulaInput(
                                        Text["3. 가중 지수비율 계산식|3. Weighted Ratio Formula"],
                                        "WeightedRatioFormula",
                                        Text["가중치 và 지수비율을 곱한 값입니다.|Weight multiplied by index ratio."],
                                        _editModel.WeightedRatioFormula,
                                        nameof(_editModel.WeightedRatioFormula),
                                        "",
                                        value => _editModel.WeightedRatioFormula = value)

                                    @RenderFormulaInput(
                                        Text["4. 종합계수 계산식|4. Composite Formula"],
                                        "CompositeFormula",
                                        Text["모든 비목의 가중 지수비율을 합산합니다.|Sum weighted ratios of all items."],
                                        _editModel.CompositeFormula,
                                        nameof(_editModel.CompositeFormula),
                                        "",
                                        value => _editModel.CompositeFormula = value)

                                    @RenderFormulaInput(
                                        Text["5. 등락율 계산식|5. Adjustment Rate Formula"],
                                        "AdjustmentRateFormula",
                                        Text["최종 변동률 K를 계산합니다.|Calculates final adjustment rate K."],
                                        _editModel.AdjustmentRateFormula,
                                        nameof(_editModel.AdjustmentRateFormula),
                                        "adjustment-rate-formula",
                                        value => _editModel.AdjustmentRateFormula = value)

                                    @RenderFormulaInput(
                                        Text["6. 적용대가 계산식|6. Applicable Amount Formula"],
                                        "ApplicableAmountFormula",
                                        Text["계약금액에서 제외금액을 뺀 값입니다.|Contract amount minus excluded amount."],
                                        _editModel.ApplicableAmountFormula,
                                        nameof(_editModel.ApplicableAmountFormula),
                                        "",
                                        value => _editModel.ApplicableAmountFormula = value)

                                    @RenderFormulaInput(
                                        Text["7. 조정금액 계산식|7. Gross Adjustment Formula"],
                                        "GrossAdjustmentFormula",
                                        Text["선금공제 전 조정금액입니다.|Adjustment amount before advance deduction."],
                                        _editModel.GrossAdjustmentFormula,
                                        nameof(_editModel.GrossAdjustmentFormula),
                                        "",
                                        value => _editModel.GrossAdjustmentFormula = value)

                                    @RenderFormulaInput(
                                        Text["8. 선금공제 계산식|8. Advance Deduction Formula"],
                                        "AdvanceDeductionFormula",
                                        Text["선금이 있을 경우 조정금액에서 공제할 금액입니다.|Deduction amount when advance exists."],
                                        _editModel.AdvanceDeductionFormula,
                                        nameof(_editModel.AdvanceDeductionFormula),
                                        "",
                                        value => _editModel.AdvanceDeductionFormula = value)

                                    @RenderFormulaInput(
                                        Text["9. 최종 조정금액 계산식|9. Final Adjustment Formula"],
                                        "FinalAdjustmentFormula",
                                        Text["최종적으로 사용자에게 표시되는 조정금액입니다.|Final adjustment amount shown to user."],
                                        _editModel.FinalAdjustmentFormula,
                                        nameof(_editModel.FinalAdjustmentFormula),
                                        "",
                                        value => _editModel.FinalAdjustmentFormula = value)

                                    @RenderFormulaInput(
                                        Text["10. 조정 가능 조건식|10. Eligibility Condition Formula"],
                                        "EligibleConditionFormula",
                                        Text["등락율과 경과일수가 기준을 만족하는지 판단합니다.|Checks if rate and elapsed days meet thresholds."],
                                        _editModel.EligibleConditionFormula,
                                        nameof(_editModel.EligibleConditionFormula),
                                        "",
                                        value => _editModel.EligibleConditionFormula = value)
                                </div>
                            </div>
                        </section>
                    }

                    @if (_activeTab == "test")
                    {
                        <section class="esc-card">
                            <div class="esc-card-title">
                                <h3>@Text["테스트 계산|Test Calculation"]</h3>
                                <p>@Text["저장 전 샘플 값으로 계산식이 정상 동작하는지 확인합니다.|Before saving, check if the formula works with sample values."]</p>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="esc-label">Amount</label>
                                    <InputNumber class="form-control esc-input" @bind-Value="_testAmount" />
                                </div>

                                <div class="col-md-3">
                                    <label class="esc-label">TotalCost</label>
                                    <InputNumber class="form-control esc-input" @bind-Value="_testTotalCost" />
                                </div>

                                <div class="col-md-3">
                                    <label class="esc-label">BaseIndex</label>
                                    <InputNumber class="form-control esc-input" @bind-Value="_testBaseIndex" />
                                </div>

                                <div class="col-md-3">
                                    <label class="esc-label">CompareIndex</label>
                                    <InputNumber class="form-control esc-input" @bind-Value="_testCompareIndex" />
                                </div>

                                <div class="col-md-3">
                                    <label class="esc-label">ContractAmount</label>
                                    <InputNumber class="form-control esc-input" @bind-Value="_testContractAmount" />
                                </div>

                                <div class="col-md-3">
                                    <label class="esc-label">ExcludedAmount</label>
                                    <InputNumber class="form-control esc-input" @bind-Value="_testExcludedAmount" />
                                </div>

                                <div class="col-md-3">
                                    <label class="esc-label">AdvanceAmount</label>
                                    <InputNumber class="form-control esc-input" @bind-Value="_testAdvanceAmount" />
                                </div>

                                <div class="col-md-3">
                                    <label class="esc-label">ElapsedDays</label>
                                    <InputNumber class="form-control esc-input" @bind-Value="_testElapsedDays" />
                                </div>

                                <div class="col-md-12">
                                    <button type="button"
                                            class="btn esc-btn-info"
                                            data-guide="test-button"
                                            @onclick="TestFormulaAsync">
                                        <i class="fa-solid fa-vial"></i>
                                        @Text["테스트 계산 실행|Run Test Calculation"]
                                    </button>
                                </div>
                            </div>

                            @if (_testResults != null)
                            {
                                <div class="test-result-section">
                                    <h4>@Text["테스트 결과|Test Results"]</h4>

                                    <div class="test-result-grid">
                                        @foreach (var result in _testResults.Variables)
                                        {
                                            <div class="test-result-item">
                                                <small>@result.Key</small>
                                                <strong>@result.Value.ToString("N4")</strong>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </section>
                    }

                    <div class="sticky-actions">
                        <button type="button"
                                class="btn esc-btn-light"
                                @onclick="LoadAsync">
                            <i class="fa-solid fa-rotate-left"></i>
                            @Text["취소/다시 불러오기|Cancel / Reload"]
                        </button>

                        <button type="button"
                                class="btn esc-btn-info"
                                @onclick='() => SetTab("test")'>
                            <i class="fa-solid fa-vial"></i>
                            @Text["테스트로 이동|Go Test"]
                        </button>

                        <button type="submit"
                                class="btn esc-btn-success"
                                data-guide="save-button">
                            <i class="fa-solid fa-save"></i>
                            @Text["저장|Save"]
                        </button>
                    </div>
                </EditForm>
            }
        </main>
    </div>

    @if (_showDeleteConfirm)
    {
        <div class="delete-backdrop">
            <div class="delete-modal">
                <div class="delete-icon">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>

                <h4>@Text["계산식 삭제 확인|Confirm Formula Deletion"]</h4>

                <p>
                    @Text["계산식은 완전히 삭제되지 않고 비활성화됩니다. 기존 계산 기록 보호를 위한 안전한 삭제 방식입니다.|The formula will be deactivated, not permanently deleted. This protects old calculation history."]
                </p>

                <div class="delete-info">
                    <div>
                        <span>@Text["코드|Code"]</span>
                        <strong>@_editModel.FormulaCode</strong>
                    </div>

                    <div>
                        <span>@Text["이름|Name"]</span>
                        <strong>@GetFormulaDisplayName(_editModel)</strong>
                    </div>

                    <div>
                        <span>@Text["버전|Version"]</span>
                        <strong>v@_editModel.VersionNo</strong>
                    </div>
                </div>

                <div class="delete-warning">
                    <i class="fa-solid fa-circle-info"></i>
                    @Text["현재 사용 중인 계산식과 기본 계산식은 삭제할 수 없습니다.|Current and default formulas cannot be deleted."]
                </div>

                <div class="delete-actions">
                    <button type="button" class="btn esc-btn-light" @onclick="CloseDeleteConfirm">
                        @Text["취소|Cancel"]
                    </button>

                    <button type="button" class="btn esc-btn-danger" @onclick="DeleteFormulaAsync">
                        <i class="fa-solid fa-trash-can"></i>
                        @Text["삭제 처리|Delete"]
                    </button>
                </div>
            </div>
        </div>
    }
</div>

