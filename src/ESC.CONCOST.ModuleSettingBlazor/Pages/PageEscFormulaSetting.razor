@code {
    private bool _loading;
    private bool _success;
    private string? _message;

    private int _currentStep = 1;
    private string _searchKeyword = string.Empty;

    private List<EscFormulaSetting> _formulas = new();

    private EscFormulaSetting? _selectedFormula;
    private Guid? _selectedFormulaGuid;

    private EscFormulaSetting _formulaEdit = CreateDefaultFormula();

    private EscFormulaField _fieldEdit = new();
    private Guid? _selectedFieldGuid;

    private EscFormulaFieldOption _optionEdit = new();

    private Dictionary<string, string> _testValues = new();
    private decimal? _testResult;

    private List<OptionItem<string>> _optRounding = new();
    private List<OptionItem<string>> _optFieldTypes = new();

    private readonly string[] _operators =
    {
        "+", "-", "*", "/", "(", ")", "/ 100"
    };

    private List<EscFormulaSetting> FilteredFormulas =>
        string.IsNullOrWhiteSpace(_searchKeyword)
            ? _formulas
            : _formulas
                .Where(x =>
                    (!string.IsNullOrWhiteSpace(x.FormulaCode) && x.FormulaCode.Contains(_searchKeyword, StringComparison.OrdinalIgnoreCase)) ||
                    (!string.IsNullOrWhiteSpace(x.FormulaName) && x.FormulaName.Contains(_searchKeyword, StringComparison.OrdinalIgnoreCase)) ||
                    (!string.IsNullOrWhiteSpace(x.FormulaNameEn) && x.FormulaNameEn.Contains(_searchKeyword, StringComparison.OrdinalIgnoreCase)))
                .ToList();

    private string PreviewExpression
    {
        get
        {
            var expression = _formulaEdit.FormulaExpression ?? string.Empty;

            if (_selectedFormula?.Fields == null || _selectedFormula.Fields.Count == 0)
            {
                return string.IsNullOrWhiteSpace(expression)
                    ? Text["계산식을 입력하세요.|Please enter expression."]
                    : expression;
            }

            foreach (var field in _selectedFormula.Fields)
            {
                var label = Text.IsKorean ? field.LabelKo : field.LabelEn;

                if (!string.IsNullOrWhiteSpace(field.FieldKey) && !string.IsNullOrWhiteSpace(label))
                {
                    expression = System.Text.RegularExpressions.Regex.Replace(
                        expression,
                        $@"\b{System.Text.RegularExpressions.Regex.Escape(field.FieldKey)}\b",
                        label,
                        System.Text.RegularExpressions.RegexOptions.IgnoreCase
                    );
                }
            }

            return string.IsNullOrWhiteSpace(expression)
                ? Text["계산식을 입력하세요.|Please enter expression."]
                : expression;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        BuildOptions();
        await LoadAsync();
    }

    private void BuildOptions()
    {
        _optRounding = BasicCodes.EscFormulaRounding.All
            .Select(x => new OptionItem<string>
            {
                Value = x,
                Text = Text.IsKorean ? GetRoundingNameKo(x) : GetRoundingNameEn(x)
            })
            .ToList();

        _optFieldTypes = BasicCodes.EscFormulaFieldType.All
            .Select(x => new OptionItem<string>
            {
                Value = x,
                Text = Text.IsKorean
                    ? BasicCodes.EscFormulaFieldType.GetNameKo(x)
                    : BasicCodes.EscFormulaFieldType.GetNameEn(x)
            })
            .ToList();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _message = null;

        try
        {
            _formulas = await FormulaService.GetFormulasAsync();

            if (_selectedFormulaGuid.HasValue)
            {
                await SelectFormulaAsync(_selectedFormulaGuid.Value);
            }
            else if (_formulas.Count > 0)
            {
                var target = _formulas.FirstOrDefault(x => x.IsDefault) ?? _formulas.First();
                await SelectFormulaAsync(target.Guid);
            }
            else
            {
                CreateFormula();
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private void CreateFormula()
    {
        _selectedFormula = null;
        _selectedFormulaGuid = null;
        _formulaEdit = CreateDefaultFormula();
        _fieldEdit = new EscFormulaField();
        _selectedFieldGuid = null;
        _testValues.Clear();
        _testResult = null;
        _currentStep = 1;
        _message = Text["새 계산식을 작성하세요. 먼저 기본 정보를 저장해야 필드를 추가할 수 있습니다.|Create a new formula. Save basic information first before adding fields."];
        _success = true;
    }

    private void DuplicateFormula()
    {
        if (_selectedFormula == null)
        {
            CreateFormula();
            return;
        }

        _selectedFormulaGuid = null;
        _selectedFormula = null;

        _formulaEdit = CloneFormula(_formulaEdit);
        _formulaEdit.Id = 0;
        _formulaEdit.Guid = Guid.NewGuid();
        _formulaEdit.FormulaCode = $"{_formulaEdit.FormulaCode}_COPY_{DateTime.Now:HHmmss}";
        _formulaEdit.FormulaName = $"{_formulaEdit.FormulaName} Copy";
        _formulaEdit.FormulaNameEn = $"{_formulaEdit.FormulaNameEn} Copy";
        _formulaEdit.IsDefault = false;
        _formulaEdit.IsActive = true;

        _fieldEdit = new EscFormulaField();
        _selectedFieldGuid = null;
        _testValues.Clear();
        _testResult = null;
        _currentStep = 1;

        _success = true;
        _message = Text["복사본이 생성되었습니다. 저장 후 필드를 다시 구성하세요.|A copy has been created. Save it first, then configure fields."];
    }

    private async Task SelectFormulaAsync(Guid formulaGuid)
    {
        _selectedFormulaGuid = formulaGuid;
        _selectedFormula = await FormulaService.GetFormulaWithFieldsAsync(formulaGuid);

        if (_selectedFormula == null)
        {
            return;
        }

        _formulaEdit = CloneFormula(_selectedFormula);
        _testValues = BuildDefaultTestValues(_selectedFormula);
        _testResult = null;

        if (_selectedFormula.Fields.Count > 0)
        {
            SelectField(_selectedFormula.Fields.OrderBy(x => x.SortOrder).First());
        }
        else
        {
            CreateField();
        }
    }

    private async Task SaveFormulaAsync()
    {
        var savedCode = _formulaEdit.FormulaCode;

        var result = await FormulaService.SaveFormulaAsync(_formulaEdit);

        _success = result.Success;
        _message = result.Message;

        _formulas = await FormulaService.GetFormulasAsync();

        if (result.Success)
        {
            var target = _formulas.FirstOrDefault(x =>
                x.FormulaCode.Equals(savedCode, StringComparison.OrdinalIgnoreCase));

            if (target != null)
            {
                await SelectFormulaAsync(target.Guid);
            }
        }
    }

    private async Task SetDefaultAsync(Guid formulaGuid)
    {
        if (formulaGuid == Guid.Empty)
        {
            return;
        }

        var result = await FormulaService.SetDefaultAsync(formulaGuid);

        _success = result.Success;
        _message = result.Message;

        await LoadAsync();
    }

    private async Task DeleteFormulaAsync(Guid formulaGuid)
    {
        var result = await FormulaService.DeleteFormulaAsync(formulaGuid);

        _success = result.Success;
        _message = result.Message;

        await LoadAsync();
    }

    private void CreateField()
    {
        if (_selectedFormula == null)
        {
            return;
        }

        _selectedFieldGuid = null;

        _fieldEdit = new EscFormulaField
        {
            Guid = Guid.NewGuid(),
            FormulaSettingId = _selectedFormula.Id,
            FieldType = BasicCodes.EscFormulaFieldType.Decimal,
            IsRequired = true,
            UseInFormula = true,
            SortOrder = _selectedFormula.Fields.Count + 1
        };

        _optionEdit = new EscFormulaFieldOption();
    }

    private void SelectField(EscFormulaField field)
    {
        _selectedFieldGuid = field.Guid;
        _fieldEdit = CloneField(field);

        _optionEdit = new EscFormulaFieldOption
        {
            Guid = Guid.NewGuid(),
            FormulaFieldId = field.Id,
            IsActive = true,
            SortOrder = field.Options.Count + 1
        };
    }

    private async Task SaveFieldAsync()
    {
        var result = await FormulaService.SaveFieldAsync(_fieldEdit);

        _success = result.Success;
        _message = result.Message;

        if (_selectedFormulaGuid.HasValue)
        {
            await SelectFormulaAsync(_selectedFormulaGuid.Value);
        }
    }

    private async Task DeleteFieldAsync(Guid fieldGuid)
    {
        var result = await FormulaService.DeleteFieldAsync(fieldGuid);

        _success = result.Success;
        _message = result.Message;

        if (_selectedFormulaGuid.HasValue)
        {
            await SelectFormulaAsync(_selectedFormulaGuid.Value);
        }
    }

    private async Task SaveOptionAsync()
    {
        _optionEdit.FormulaFieldId = _fieldEdit.Id;

        var result = await FormulaService.SaveFieldOptionAsync(_optionEdit);

        _success = result.Success;
        _message = result.Message;

        if (_selectedFormulaGuid.HasValue)
        {
            await SelectFormulaAsync(_selectedFormulaGuid.Value);
        }
    }

    private async Task DeleteOptionAsync(Guid optionGuid)
    {
        var result = await FormulaService.DeleteFieldOptionAsync(optionGuid);

        _success = result.Success;
        _message = result.Message;

        if (_selectedFormulaGuid.HasValue)
        {
            await SelectFormulaAsync(_selectedFormulaGuid.Value);
        }
    }

    private async Task TestFormulaAsync()
    {
        if (!_selectedFormulaGuid.HasValue)
        {
            return;
        }

        var result = await FormulaService.TestFormulaAsync(_selectedFormulaGuid.Value, _testValues);

        _success = result.Success;
        _message = result.Message;

        _testResult = result.Success ? result.Item : null;
    }

    private Task OnRoundingChanged(OptionItem<string>? item)
    {
        _formulaEdit.RoundingMethod = string.IsNullOrWhiteSpace(item?.Value)
            ? BasicCodes.EscFormulaRounding.Round
            : item.Value;

        return Task.CompletedTask;
    }

    private Task OnFieldTypeChanged(OptionItem<string>? item)
    {
        _fieldEdit.FieldType = string.IsNullOrWhiteSpace(item?.Value)
            ? BasicCodes.EscFormulaFieldType.Decimal
            : item.Value;

        return Task.CompletedTask;
    }

    private void InsertToken(string token)
    {
        if (string.IsNullOrWhiteSpace(token))
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_formulaEdit.FormulaExpression))
        {
            _formulaEdit.FormulaExpression = token;
        }
        else
        {
            _formulaEdit.FormulaExpression += $" {token}";
        }
    }

    private string GetTestValue(string key)
    {
        return _testValues.TryGetValue(key, out var value) ? value : string.Empty;
    }

    private bool GetBoolTestValue(string key)
    {
        return _testValues.TryGetValue(key, out var value) && value == "1";
    }

    private void SetTestValue(string key, string value)
    {
        _testValues[key] = value;
    }

    private void GoStep(int step)
    {
        _currentStep = Math.Clamp(step, 1, 4);
    }

    private void NextStep()
    {
        _currentStep = Math.Clamp(_currentStep + 1, 1, 4);
    }

    private void PrevStep()
    {
        _currentStep = Math.Clamp(_currentStep - 1, 1, 4);
    }

    private string StepClass(int step)
    {
        if (_currentStep == step)
        {
            return "active";
        }

        if (_currentStep > step)
        {
            return "done";
        }

        return string.Empty;
    }

    private static Dictionary<string, string> BuildDefaultTestValues(EscFormulaSetting formula)
    {
        return formula.Fields
            .ToDictionary(
                x => x.FieldKey,
                x => string.IsNullOrWhiteSpace(x.DefaultValue) ? "0" : x.DefaultValue
            );
    }

    private static EscFormulaSetting CreateDefaultFormula()
    {
        return new EscFormulaSetting
        {
            Guid = Guid.NewGuid(),
            FormulaCode = $"CUSTOM_ESC_{DateTime.Now:yyyyMMddHHmmss}",
            FormulaName = "새 ESC 계산식",
            FormulaNameEn = "New ESC Formula",
            FormulaExpression = "",
            RoundingMethod = BasicCodes.EscFormulaRounding.Round,
            DecimalPlaces = 0,
            AllowNegativeResult = true,
            IsActive = true,
            SortOrder = 1
        };
    }

    private static EscFormulaSetting CloneFormula(EscFormulaSetting item)
    {
        return new EscFormulaSetting
        {
            Id = item.Id,
            Guid = item.Guid,
            FormulaCode = item.FormulaCode,
            FormulaName = item.FormulaName,
            FormulaNameEn = item.FormulaNameEn,
            Description = item.Description,
            FormulaExpression = item.FormulaExpression,
            RoundingMethod = item.RoundingMethod,
            DecimalPlaces = item.DecimalPlaces,
            AllowNegativeResult = item.AllowNegativeResult,
            IsDefault = item.IsDefault,
            IsActive = item.IsActive,
            SortOrder = item.SortOrder,
            DateCreated = item.DateCreated,
            DateModified = item.DateModified,
            UserCreated = item.UserCreated,
            UserModified = item.UserModified
        };
    }

    private static EscFormulaField CloneField(EscFormulaField item)
    {
        return new EscFormulaField
        {
            Id = item.Id,
            Guid = item.Guid,
            FormulaSettingId = item.FormulaSettingId,
            FieldKey = item.FieldKey,
            LabelKo = item.LabelKo,
            LabelEn = item.LabelEn,
            FieldType = item.FieldType,
            DefaultValue = item.DefaultValue,
            Placeholder = item.Placeholder,
            Unit = item.Unit,
            IsRequired = item.IsRequired,
            IsReadonly = item.IsReadonly,
            UseInFormula = item.UseInFormula,
            SortOrder = item.SortOrder,
            ValidationMin = item.ValidationMin,
            ValidationMax = item.ValidationMax,
            Options = item.Options.ToList()
        };
    }

    private static string ShortExpression(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        return value.Length <= 80 ? value : value.Substring(0, 80) + "...";
    }

    private static string GetRoundingNameKo(string value)
    {
        return value switch
        {
            BasicCodes.EscFormulaRounding.Round => "반올림",
            BasicCodes.EscFormulaRounding.Floor => "버림",
            BasicCodes.EscFormulaRounding.Ceiling => "올림",
            BasicCodes.EscFormulaRounding.None => "없음",
            _ => value
        };
    }

    private static string GetRoundingNameEn(string value)
    {
        return value switch
        {
            BasicCodes.EscFormulaRounding.Round => "Round",
            BasicCodes.EscFormulaRounding.Floor => "Floor",
            BasicCodes.EscFormulaRounding.Ceiling => "Ceiling",
            BasicCodes.EscFormulaRounding.None => "None",
            _ => value
        };
    }
}