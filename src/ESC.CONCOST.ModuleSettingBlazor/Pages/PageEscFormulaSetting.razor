@page "/management/esc-formula-setting"

@inject ITextTranslator Text
@inject IEscFormulaSettingService FormulaService
@inject IJSRuntime JSRuntime

@using ESC.CONCOST.Abstract
@using ESC.CONCOST.ModuleSettingCore
@using ESC.CONCOST.SharedComponents.Components
@using System.Text.Json

<div class="esc-formula-page">
    <div class="esc-formula-hero">
        <div class="esc-formula-hero-left">
            <div class="esc-formula-kicker">
                <i class="fa-solid fa-calculator"></i>
                @Text["관리자 설정|Admin Setting"]
            </div>

            <h2>@Text["ESC 계산식 설정|ESC Formula Builder"]</h2>

            <p>
                @Text["계약 금액 조정(ESC)을 위한 10단계 계산식과 임계값을 설정합니다.|Configure the 10-step formula and thresholds for ESC adjustment."]
            </p>

            <div class="esc-formula-current">
                <span>@Text["현재 선택|Current"]</span>
                <strong>@(_selectedFormula?.FormulaCode ?? "-")</strong>

                @if (_selectedFormula?.IsCurrent == true)
                {
                    <em class="esc-status esc-status-primary">Active</em>
                }
                
                @if (_selectedFormula != null)
                {
                    <em class="esc-status esc-status-success">Ver @_selectedFormula.VersionNo</em>
                }
            </div>
        </div>

        <div class="esc-formula-hero-actions">
            <button class="btn esc-btn-primary" @onclick="CreateFormula">
                <i class="fa-solid fa-plus"></i>
                @Text["새 계산식|New Formula"]
            </button>

            <button class="btn esc-btn-outline" @onclick="DuplicateFormula" disabled="@(_selectedFormula == null)">
                <i class="fa-solid fa-copy"></i>
                @Text["복사 생성|Duplicate"]
            </button>

            <button class="btn esc-btn-outline"
                    disabled="@(_selectedFormula == null || _selectedFormula.IsCurrent || !_selectedFormula.IsActive)"
                    @onclick="() => SetCurrentAsync(_selectedFormula?.Guid ?? Guid.Empty)">
                <i class="fa-solid fa-star"></i>
                @Text["활성 계산식으로 설정|Set Active"]
            </button>

            <button class="btn esc-btn-outline" @onclick="LoadAsync">
                <i class="fa-solid fa-rotate"></i>
                @Text["새로고침|Refresh"]
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert @(_success ? "alert-success" : "alert-danger") esc-formula-alert alert-dismissible fade show">
            @_message
            <button type="button" class="btn-close" @onclick="() => _message = null"></button>
        </div>
    }

    <div class="esc-formula-shell">
        <aside class="esc-formula-library">
            <div class="esc-panel-title-row">
                <div>
                    <h3>@Text["계산식 목록|Formula Library"]</h3>
                </div>
                <span class="esc-count">@_formulas.Count</span>
            </div>

            @if (_loading)
            {
                <div class="esc-empty-state">
                    <i class="fa-solid fa-spinner fa-spin"></i>
                    <span>@Text["불러오는 중입니다...|Loading..."]</span>
                </div>
            }
            else if (_formulas.Count == 0)
            {
                <div class="esc-empty-state">
                    <i class="fa-regular fa-folder-open"></i>
                    <span>@Text["등록된 계산식이 없습니다.|No formulas found."]</span>
                </div>
            }
            else
            {
                <div class="esc-formula-list">
                    @foreach (var item in _formulas)
                    {
                        <button type="button"
                                class="esc-formula-card @(item.Guid == _selectedFormula?.Guid ? "active" : "")"
                                @onclick="() => SelectFormula(item)">
                            <div class="esc-formula-card-head">
                                <div>
                                    <strong>@item.FormulaName</strong>
                                </div>
                                <div class="esc-card-badges">
                                    @if (item.IsCurrent)
                                    {
                                        <span class="esc-status esc-status-primary">Active</span>
                                    }
                                </div>
                            </div>
                            <div class="esc-formula-card-meta">
                                <span><i class="fa-solid fa-code"></i> @item.FormulaCode</span>
                                <span><i class="fa-solid fa-code-branch"></i> v@(item.VersionNo)</span>
                            </div>
                        </button>
                    }
                </div>
            }
        </aside>

        <main class="esc-formula-workspace">
            @if (_selectedFormula != null)
            {
                <EditForm Model="_editModel" OnValidSubmit="SaveFormulaAsync">
                    <DataAnnotationsValidator />

                    <div class="esc-card mb-3">
                        <div class="esc-card-header">
                            <div>
                                <h3>@Text["기본 정보|Basic Information"]</h3>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="esc-label">@Text["코드|Code"] <b>*</b></label>
                                <InputText class="form-control esc-input" @bind-Value="_editModel.FormulaCode" />
                            </div>
                            <div class="col-md-4">
                                <label class="esc-label">@Text["이름(한국어)|Name Korean"] <b>*</b></label>
                                <InputText class="form-control esc-input" @bind-Value="_editModel.FormulaName" />
                            </div>
                            <div class="col-md-4">
                                <label class="esc-label">@Text["이름(영어)|Name English"]</label>
                                <InputText class="form-control esc-input" @bind-Value="_editModel.FormulaNameEn" />
                            </div>
                        </div>
                    </div>

                    <div class="esc-card mb-3">
                        <div class="esc-card-header">
                            <div>
                                <h3>@Text["기준 설정|Thresholds & Options"]</h3>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="esc-label">@Text["등락율 임계값 (%)|Threshold Rate (%)"]</label>
                                <InputNumber class="form-control esc-input" @bind-Value="_editModel.ThresholdRate" />
                            </div>
                            <div class="col-md-3">
                                <label class="esc-label">@Text["경과 일수 임계값|Threshold Days"]</label>
                                <InputNumber class="form-control esc-input" @bind-Value="_editModel.ThresholdDays" />
                            </div>
                            <div class="col-md-3">
                                <label class="esc-label">@Text["반올림 방식|Rounding Method"]</label>
                                <InputSelect class="form-select esc-input" @bind-Value="_editModel.RoundingMethod">
                                    <option value="@BasicCodes.EscFormulaRounding.Round">@Text["반올림|Round"]</option>
                                    <option value="@BasicCodes.EscFormulaRounding.Floor">@Text["내림|Floor"]</option>
                                    <option value="@BasicCodes.EscFormulaRounding.Ceiling">@Text["올림|Ceiling"]</option>
                                    <option value="@BasicCodes.EscFormulaRounding.None">@Text["없음|None"]</option>
                                </InputSelect>
                            </div>
                            <div class="col-md-3">
                                <label class="esc-label">@Text["소수점 자릿수|Decimal Places"]</label>
                                <InputNumber class="form-control esc-input" @bind-Value="_editModel.DecimalPlaces" />
                            </div>
                            <div class="col-md-3 d-flex align-items-center mt-4">
                                <div class="form-check form-switch">
                                    <InputCheckbox class="form-check-input" id="useAdvanceDeduct" @bind-Value="_editModel.UseAdvanceDeduction" />
                                    <label class="form-check-label" for="useAdvanceDeduct">@Text["선급금 공제 사용|Use Advance Deduction"]</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="esc-label">@Text["기타 공제액 기본값|Other Deduction Default"]</label>
                                <InputNumber class="form-control esc-input" @bind-Value="_editModel.OtherDeductionDefault" />
                            </div>
                        </div>
                    </div>

                    <div class="esc-card mb-3">
                        <div class="esc-card-header">
                            <div>
                                <h3>@Text["계산식 작성|Formula Configuration"]</h3>
                            </div>
                        </div>
                        
                        <div class="esc-expression-layout">
                            <!-- Sidebar variables -->
                            <div class="esc-sidebar-variables">
                                <div class="esc-sub-card-title">
                                    <i class="fa-solid fa-cubes"></i> @Text["변수 목록|Variables"]
                                </div>
                                <div class="esc-variable-list">
                                    @foreach (var v in _variables)
                                    {
                                        <button type="button" class="esc-variable-chip" @onclick="() => InsertToken(v.VariableCode)">
                                            <strong>@v.VariableCode</strong>
                                            <span>@(Text.IsKorean ? v.VariableName : v.VariableNameEn)</span>
                                        </button>
                                    }
                                </div>
                                
                                <div class="esc-sub-card-title mt-3">
                                    <i class="fa-solid fa-square-root-variable"></i> @Text["함수 및 연산자|Functions"]
                                </div>
                                <div class="esc-operator-list">
                                    <button type="button" class="esc-operator" @onclick="@(() => InsertToken(" + "))">+</button>
                                    <button type="button" class="esc-operator" @onclick="@(() => InsertToken(" - "))">-</button>
                                    <button type="button" class="esc-operator" @onclick="@(() => InsertToken(" * "))">*</button>
                                    <button type="button" class="esc-operator" @onclick="@(() => InsertToken(" / "))">/</button>
                                    <button type="button" class="esc-operator" @onclick="@(() => InsertToken(" ( "))">(</button>
                                    <button type="button" class="esc-operator" @onclick="@(() => InsertToken(" ) "))">)</button>
                                    <button type="button" class="esc-operator" @onclick="@(() => InsertToken(" ROUND( , 0) "))">ROUND</button>
                                    <button type="button" class="esc-operator" @onclick="@(() => InsertToken(" SUM( ) "))">SUM</button>
                                    <button type="button" class="esc-operator" @onclick="@(() => InsertToken(" >= "))">&gt;=</button>
                                    <button type="button" class="esc-operator" @onclick="@(() => InsertToken(" AND "))">AND</button>
                                </div>
                            </div>
                            
                            <!-- Formula inputs -->
                            <div class="esc-formula-inputs">
                                <div class="formula-group">
                                    <h5>@Text["1. 비목 계산 (각 항목별)|1. Item Calculation"]</h5>
                                    
                                    <label class="esc-label">WeightFormula (w_i)</label>
                                    <div class="input-with-focus">
                                        <InputText class="form-control esc-input" @bind-Value="_editModel.WeightFormula" @onfocus="() => SetFocusedInput(nameof(_editModel.WeightFormula))" />
                                    </div>
                                    
                                    <label class="esc-label mt-2">IndexRatioFormula (R_i)</label>
                                    <div class="input-with-focus">
                                        <InputText class="form-control esc-input" @bind-Value="_editModel.IndexRatioFormula" @onfocus="() => SetFocusedInput(nameof(_editModel.IndexRatioFormula))" />
                                    </div>

                                    <label class="esc-label mt-2">WeightedRatioFormula (w_i * R_i)</label>
                                    <div class="input-with-focus">
                                        <InputText class="form-control esc-input" @bind-Value="_editModel.WeightedRatioFormula" @onfocus="() => SetFocusedInput(nameof(_editModel.WeightedRatioFormula))" />
                                    </div>
                                </div>
                                
                                <div class="formula-group mt-3">
                                    <h5>@Text["2. 총괄 지수 (합산)|2. Composite Aggregate"]</h5>
                                    <label class="esc-label">CompositeFormula (C)</label>
                                    <div class="input-with-focus">
                                        <InputText class="form-control esc-input" @bind-Value="_editModel.CompositeFormula" @onfocus="() => SetFocusedInput(nameof(_editModel.CompositeFormula))" />
                                    </div>
                                </div>

                                <div class="formula-group mt-3">
                                    <h5>@Text["3. 대상 금액 및 변동율|3. Amount & Rate"]</h5>
                                    <label class="esc-label">AdjustmentRateFormula (K)</label>
                                    <div class="input-with-focus">
                                        <InputText class="form-control esc-input" @bind-Value="_editModel.AdjustmentRateFormula" @onfocus="() => SetFocusedInput(nameof(_editModel.AdjustmentRateFormula))" />
                                    </div>
                                    <label class="esc-label mt-2">ApplicableAmountFormula (D)</label>
                                    <div class="input-with-focus">
                                        <InputText class="form-control esc-input" @bind-Value="_editModel.ApplicableAmountFormula" @onfocus="() => SetFocusedInput(nameof(_editModel.ApplicableAmountFormula))" />
                                    </div>
                                </div>

                                <div class="formula-group mt-3">
                                    <h5>@Text["4. 조정 금액 산출|4. Final Adjustment"]</h5>
                                    <label class="esc-label">GrossAdjustmentFormula (G)</label>
                                    <div class="input-with-focus">
                                        <InputText class="form-control esc-input" @bind-Value="_editModel.GrossAdjustmentFormula" @onfocus="() => SetFocusedInput(nameof(_editModel.GrossAdjustmentFormula))" />
                                    </div>
                                    <label class="esc-label mt-2">AdvanceDeductionFormula (F)</label>
                                    <div class="input-with-focus">
                                        <InputText class="form-control esc-input" @bind-Value="_editModel.AdvanceDeductionFormula" @onfocus="() => SetFocusedInput(nameof(_editModel.AdvanceDeductionFormula))" />
                                    </div>
                                    <label class="esc-label mt-2">FinalAdjustmentFormula</label>
                                    <div class="input-with-focus">
                                        <InputText class="form-control esc-input" @bind-Value="_editModel.FinalAdjustmentFormula" @onfocus="() => SetFocusedInput(nameof(_editModel.FinalAdjustmentFormula))" />
                                    </div>
                                </div>

                                <div class="formula-group mt-3">
                                    <h5>@Text["5. 조건식|5. Eligibility Condition"]</h5>
                                    <label class="esc-label">EligibleConditionFormula (1 or 0)</label>
                                    <div class="input-with-focus">
                                        <InputText class="form-control esc-input" @bind-Value="_editModel.EligibleConditionFormula" @onfocus="() => SetFocusedInput(nameof(_editModel.EligibleConditionFormula))" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="esc-sticky-actions">
                            <button type="button" class="btn esc-btn-info" @onclick="TestFormula">
                                <i class="fa-solid fa-vial"></i> @Text["테스트 계산|Test Calculation"]
                            </button>
                            <button type="submit" class="btn esc-btn-success">
                                <i class="fa-solid fa-save"></i> @Text["저장|Save"]
                            </button>
                        </div>
                    </div>
                </EditForm>
                
                @if (_testResults != null)
                {
                    <div class="esc-card mb-3">
                        <div class="esc-card-header">
                            <h3><i class="fa-solid fa-chart-simple"></i> @Text["테스트 결과|Test Results"]</h3>
                        </div>
                        <div class="row">
                            @foreach(var res in _testResults)
                            {
                                <div class="col-md-4 mb-2">
                                    <div class="esc-test-result-item">
                                        <small>@res.Key</small>
                                        <strong>@res.Value.ToString("N4")</strong>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="esc-empty-state">
                    <i class="fa-solid fa-hand-pointer"></i>
                    <span>@Text["계산식을 선택하거나 새로 생성하세요.|Select or create a formula."]</span>
                </div>
            }
        </main>
    </div>
</div>

<style>
    .esc-formula-page { padding: 24px 32px; background: #f4f7fb; min-height: calc(100vh - 80px); color: #102a4c; }
    .esc-formula-hero { display: flex; justify-content: space-between; align-items: flex-start; gap: 20px; background: linear-gradient(135deg, #102a4c, #1d4ed8); color: #fff; border-radius: 22px; padding: 24px; box-shadow: 0 16px 36px rgba(15, 23, 42, .16); margin-bottom: 18px; }
    .esc-formula-kicker { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.14); padding: 7px 12px; border-radius: 999px; font-weight: 800; margin-bottom: 10px; }
    .esc-formula-hero h2 { margin: 0; font-size: 2rem; font-weight: 900; }
    .esc-formula-hero p { margin: 8px 0 0; color: rgba(255,255,255,.82); font-weight: 600; }
    .esc-formula-current { margin-top: 16px; display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
    .esc-formula-current span { color: rgba(255,255,255,.75); font-weight: 700; }
    .esc-formula-current strong { background: rgba(255,255,255,.16); padding: 5px 10px; border-radius: 10px; }
    .esc-status { padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    .esc-status-primary { background: rgba(37, 99, 235, 0.15); color: #2563eb; border: 1px solid rgba(37, 99, 235, 0.3); }
    .esc-status-success { background: rgba(16, 185, 129, 0.15); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3); }
    .esc-formula-hero-actions { display: flex; gap: 10px; flex-wrap: wrap; }
    .esc-btn-primary { background: #ff6b00; border: none; color: white; padding: 10px 20px; font-weight: 700; border-radius: 12px; transition: all 0.2s; box-shadow: 0 4px 12px rgba(255, 107, 0, 0.3); }
    .esc-btn-primary:hover { background: #e66000; transform: translateY(-2px); box-shadow: 0 6px 16px rgba(255, 107, 0, 0.4); color: white; }
    .esc-btn-outline { background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2); color: white; padding: 10px 20px; font-weight: 700; border-radius: 12px; transition: all 0.2s; backdrop-filter: blur(8px); }
    .esc-btn-outline:hover:not(:disabled) { background: rgba(255,255,255,.2); border-color: rgba(255,255,255,.4); }
    .esc-btn-outline:disabled { opacity: 0.5; cursor: not-allowed; }
    .esc-btn-success { background: #10b981; border: none; color: white; padding: 10px 24px; font-weight: 700; border-radius: 10px; transition: all 0.2s; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3); }
    .esc-btn-success:hover { background: #059669; transform: translateY(-2px); box-shadow: 0 6px 16px rgba(16, 185, 129, 0.4); color: white; }
    .esc-btn-info { background: #3b82f6; border: none; color: white; padding: 10px 24px; font-weight: 700; border-radius: 10px; transition: all 0.2s; box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3); }
    .esc-btn-info:hover { background: #2563eb; transform: translateY(-2px); color: white; }
    
    .esc-formula-shell { display: grid; grid-template-columns: 320px 1fr; gap: 24px; align-items: start; }
    .esc-formula-library { background: white; border-radius: 16px; padding: 20px; box-shadow: 0 4px 20px rgba(15, 23, 42, .04); display: flex; flex-direction: column; gap: 16px; max-height: calc(100vh - 120px); overflow-y: auto; }
    .esc-panel-title-row { display: flex; justify-content: space-between; align-items: center; }
    .esc-panel-title-row h3 { margin: 0; font-size: 1.1rem; font-weight: 800; color: #1e293b; }
    .esc-count { background: #e2e8f0; color: #475569; padding: 2px 10px; border-radius: 999px; font-size: 0.8rem; font-weight: 800; }
    .esc-empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 20px; background: #f8fafc; border-radius: 12px; border: 2px dashed #cbd5e1; color: #64748b; gap: 12px; text-align: center; }
    .esc-empty-state i { font-size: 2rem; color: #94a3b8; }
    
    .esc-formula-list { display: flex; flex-direction: column; gap: 12px; }
    .esc-formula-card { background: white; border: 1px solid #e2e8f0; border-radius: 12px; padding: 16px; text-align: left; cursor: pointer; transition: all 0.2s; display: flex; flex-direction: column; gap: 8px; width: 100%; box-shadow: 0 2px 8px rgba(0,0,0,0.02); }
    .esc-formula-card:hover { border-color: #3b82f6; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(59, 130, 246, 0.1); }
    .esc-formula-card.active { border-color: #2563eb; background: #eff6ff; box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.2); }
    .esc-formula-card-head { display: flex; justify-content: space-between; align-items: flex-start; }
    .esc-formula-card-head strong { display: block; font-size: 1rem; color: #0f172a; margin-bottom: 2px; }
    .esc-card-badges { display: flex; gap: 6px; }
    .esc-formula-card-meta { display: flex; gap: 12px; font-size: 0.8rem; color: #64748b; font-family: 'JetBrains Mono', monospace; }
    
    .esc-formula-workspace { display: flex; flex-direction: column; gap: 20px; }
    .esc-card { background: white; border-radius: 16px; padding: 24px; box-shadow: 0 4px 20px rgba(15, 23, 42, .04); }
    .esc-card-header { margin-bottom: 20px; border-bottom: 1px solid #e2e8f0; padding-bottom: 12px; }
    .esc-card-header h3 { margin: 0; font-size: 1.25rem; font-weight: 800; color: #0f172a; }
    
    .esc-label { display: block; font-size: 0.85rem; font-weight: 700; color: #475569; margin-bottom: 6px; }
    .esc-label b { color: #ef4444; }
    .esc-input { border: 1px solid #cbd5e1; border-radius: 10px; padding: 10px 14px; font-size: 0.95rem; font-family: 'JetBrains Mono', monospace; transition: border-color 0.2s, box-shadow 0.2s; }
    .esc-input:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15); outline: none; }
    
    .esc-expression-layout { display: grid; grid-template-columns: 280px 1fr; gap: 24px; margin-top: 10px; }
    .esc-sidebar-variables { background: #f8fafc; border-radius: 12px; padding: 16px; border: 1px solid #e2e8f0; }
    .esc-sub-card-title { font-size: 0.9rem; font-weight: 800; color: #334155; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
    
    .esc-variable-list { display: flex; flex-direction: column; gap: 8px; max-height: 400px; overflow-y: auto; padding-right: 5px; }
    .esc-variable-chip { display: flex; flex-direction: column; align-items: flex-start; background: white; border: 1px solid #cbd5e1; padding: 8px 12px; border-radius: 8px; cursor: pointer; transition: all 0.2s; width: 100%; text-align: left; }
    .esc-variable-chip:hover { border-color: #ff6b00; background: #fffaf5; }
    .esc-variable-chip strong { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: #1e293b; }
    .esc-variable-chip span { font-size: 0.75rem; color: #64748b; margin-top: 2px; }
    
    .esc-operator-list { display: flex; flex-wrap: wrap; gap: 6px; }
    .esc-operator { background: white; border: 1px solid #cbd5e1; border-radius: 6px; padding: 6px 10px; font-family: 'JetBrains Mono', monospace; font-weight: 700; color: #334155; cursor: pointer; transition: all 0.1s; }
    .esc-operator:hover { border-color: #3b82f6; color: #3b82f6; background: #eff6ff; }
    
    .esc-formula-inputs { display: flex; flex-direction: column; gap: 20px; }
    .formula-group { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 16px; }
