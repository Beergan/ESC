    private void ShowMessage(bool success, string message)
    {
        _success = success;
        _message = message;
        StateHasChanged();
    }

    private void ClearMessage()
    {
        _message = null;
    }

    private async Task ShowGuide()
    {
        var lang = Text.CurrentLang ?? "ko";
        if (_selectedFormula == null)
            await JS.InvokeVoidAsync("escFormulaGuide.startQuickGuide", lang);
        else
            await JS.InvokeVoidAsync("escFormulaGuide.startCreateFormulaGuide", lang);
    }

    private RenderFragment RenderFormulaInput(
        string label,
        string code,
        string help,
        string value,
        string focusName,
        string dataGuide,
        Action<string> onValueChanged) => builder =>
    {
        var seq = 0;

        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "formula-input-block");
        if (!string.IsNullOrEmpty(dataGuide))
            builder.AddAttribute(seq++, "data-guide", dataGuide);

        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "formula-input-head");

        builder.OpenElement(seq++, "label");
        builder.AddAttribute(seq++, "class", "esc-label");
        builder.AddContent(seq++, label);
        builder.CloseElement();

        builder.OpenElement(seq++, "span");
        builder.AddContent(seq++, code);
        builder.CloseElement();

        builder.CloseElement();

        builder.OpenElement(seq++, "input");
        builder.AddAttribute(seq++, "class", "form-control esc-input");
        builder.AddAttribute(seq++, "value", value);
        builder.AddAttribute(seq++, "onfocus", EventCallback.Factory.Create(this, () => SetFocusedInput(focusName)));
        builder.AddAttribute(seq++, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, e =>
        {
            onValueChanged(e.Value?.ToString() ?? string.Empty);
        }));
        builder.CloseElement();

        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "formula-help-text");
        builder.AddContent(seq++, help);
        builder.CloseElement();

        builder.CloseElement();
    };
}