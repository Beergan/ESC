@page "/management/esc-formula-setting"

@inject ITextTranslator Text
@inject IEscFormulaSettingService FormulaService

@using ESC.CONCOST.Abstract
@using ESC.CONCOST.ModuleSettingCore
@using ESC.CONCOST.SharedComponents.Components

<div class="esc-formula-page">
    <div class="esc-formula-hero">
        <div class="esc-formula-hero-left">
            <div class="esc-formula-kicker">
                <i class="fa-solid fa-calculator"></i>
                @Text["관리자 설정|Admin Setting"]
            </div>

            <h2>@Text["ESC 계산식 설정|ESC Formula Builder"]</h2>

            <p>
                @Text["관리자가 계산식, 입력 필드, 테스트 값을 순서대로 구성할 수 있습니다.|Admin can configure formulas, input fields and test values step by step."]
            </p>

            <div class="esc-formula-current">
                <span>@Text["현재 선택|Current"]</span>
                <strong>@(_selectedFormula?.FormulaCode ?? "-")</strong>

                @if (_selectedFormula?.IsDefault == true)
                {
                    <em class="esc-status esc-status-primary">Default</em>
                }

                @if (_selectedFormula?.IsActive == true)
                {
                    <em class="esc-status esc-status-success">Active</em>
                }
                else if (_selectedFormula != null)
                {
                    <em class="esc-status esc-status-muted">Inactive</em>
                }
            </div>
        </div>

        <div class="esc-formula-hero-actions">
            <button class="btn esc-btn-primary" @onclick="CreateFormula">
                <i class="fa-solid fa-plus"></i>
                @Text["새 계산식|New Formula"]
            </button>

            <button class="btn esc-btn-outline" @onclick="DuplicateFormula">
                <i class="fa-solid fa-copy"></i>
                @Text["복사 생성|Duplicate"]
            </button>

            <button class="btn esc-btn-outline"
                    disabled="@(_selectedFormula == null || _selectedFormula.IsDefault || !_selectedFormula.IsActive)"
                    @onclick="() => SetDefaultAsync(_selectedFormulaGuid ?? Guid.Empty)">
                <i class="fa-solid fa-star"></i>
                @Text["기본값 설정|Set Default"]
            </button>

            <button class="btn esc-btn-outline" @onclick="LoadAsync">
                <i class="fa-solid fa-rotate"></i>
                @Text["새로고침|Refresh"]
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert @(_success ? "alert-success" : "alert-danger") esc-formula-alert">
            @_message
        </div>
    }

    <div class="esc-formula-shell">
        <aside class="esc-formula-library">
            <div class="esc-panel-title-row">
                <div>
                    <h3>@Text["계산식 목록|Formula Library"]</h3>
                    <p>@Text["등록된 계산식을 선택하세요.|Select a formula."]</p>
                </div>
                <span class="esc-count">@_formulas.Count</span>
            </div>

            <div class="esc-search-box">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input class="form-control"
                       placeholder="@Text["코드/이름 검색|Search code/name"]"
                       @bind="_searchKeyword"
                       @bind:event="oninput" />
            </div>

            @if (_loading)
            {
                <div class="esc-empty-state">
                    <i class="fa-solid fa-spinner fa-spin"></i>
                    <span>@Text["불러오는 중입니다...|Loading..."]</span>
                </div>
            }
            else if (FilteredFormulas.Count == 0)
            {
                <div class="esc-empty-state">
                    <i class="fa-regular fa-folder-open"></i>
                    <span>@Text["등록된 계산식이 없습니다.|No formulas found."]</span>
                </div>
            }
            else
            {
                <div class="esc-formula-list">
                    @foreach (var item in FilteredFormulas)
                    {
                        <button type="button"
                                class="esc-formula-card @(item.Guid == _selectedFormulaGuid ? "active" : "")"
                                @onclick="() => SelectFormulaAsync(item.Guid)">
                            <div class="esc-formula-card-head">
                                <div>
                                    <strong>@item.FormulaName</strong>
                                    <small>@item.FormulaNameEn</small>
                                </div>

                                <div class="esc-card-badges">
                                    @if (item.IsDefault)
                                    {
                                        <span class="esc-status esc-status-primary">Default</span>
                                    }

                                    @if (item.IsActive)
                                    {
                                        <span class="esc-status esc-status-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="esc-status esc-status-muted">Inactive</span>
                                    }
                                </div>
                            </div>

                            <div class="esc-formula-card-meta">
                                <span><i class="fa-solid fa-code"></i> @item.FormulaCode</span>
                                <span><i class="fa-solid fa-arrow-down-1-9"></i> @item.SortOrder</span>
                            </div>

                            <div class="esc-formula-card-expression">
                                @ShortExpression(item.FormulaExpression)
                            </div>
                        </button>
                    }
                </div>
            }
        </aside>

        <main class="esc-formula-workspace">
            <div class="esc-stepper">
                <button class="esc-step @StepClass(1)" @onclick="() => GoStep(1)">
                    <span>1</span>
                    <div>
                        <strong>@Text["기본 정보|Basic Info"]</strong>
                        <small>@Text["계산식 이름/옵션|Name & options"]</small>
                    </div>
                </button>

                <button class="esc-step @StepClass(2)" @onclick="() => GoStep(2)">
                    <span>2</span>
                    <div>
                        <strong>@Text["입력 필드|Input Fields"]</strong>
                        <small>@Text["변수/타입 설정|Variables & types"]</small>
                    </div>
                </button>

                <button class="esc-step @StepClass(3)" @onclick="() => GoStep(3)">
                    <span>3</span>
                    <div>
                        <strong>@Text["계산식 작성|Expression"]</strong>
                        <small>@Text["변수로 공식 작성|Build formula"]</small>
                    </div>
                </button>

                <button class="esc-step @StepClass(4)" @onclick="() => GoStep(4)">
                    <span>4</span>
                    <div>
                        <strong>@Text["테스트 및 적용|Test & Apply"]</strong>
                        <small>@Text["결과 확인|Verify result"]</small>
                    </div>
                </button>
            </div>

            @if (_currentStep == 1)
            {
                <EditForm Model="_formulaEdit" OnValidSubmit="SaveFormulaAsync">
                    <DataAnnotationsValidator />

                    <section class="esc-card">
                        <div class="esc-card-header">
                            <div>
                                <h3>@Text["1. 기본 정보|1. Basic Information"]</h3>
                                <p>@Text["계산식의 기본 이름, 코드, 반올림 방식을 설정합니다.|Set formula name, code and rounding options."]</p>
                            </div>
                        </div>

                        @if (_formulaEdit.IsDefault)
                        {
                            <div class="esc-warning-box">
                                <i class="fa-solid fa-triangle-exclamation"></i>
                                <span>
                                    @Text["현재 기본 계산식입니다. 수정 시 신규 계산 결과에 영향을 줄 수 있습니다.|This is the default formula. Changes may affect new calculations."]
                                </span>
                            </div>
                        }

                        <div class="row g-3">
                            <div class="col-lg-6">
                                <label class="esc-label">@Text["계산식 코드|Formula Code"] <b>*</b></label>
                                <InputText class="form-control esc-input" @bind-Value="_formulaEdit.FormulaCode" />
                                <div class="esc-help">
                                    @Text["영문, 숫자, 밑줄만 권장합니다. 예: DEFAULT_ESC|Use letters, numbers and underscore. Example: DEFAULT_ESC"]
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <label class="esc-label">@Text["정렬 순서|Sort Order"]</label>
                                <InputNumber class="form-control esc-input" @bind-Value="_formulaEdit.SortOrder" />
                            </div>

                            <div class="col-lg-6">
                                <label class="esc-label">@Text["이름(한국어)|Name Korean"] <b>*</b></label>
                                <InputText class="form-control esc-input" @bind-Value="_formulaEdit.FormulaName" />
                            </div>

                            <div class="col-lg-6">
                                <label class="esc-label">@Text["이름(영어)|Name English"]</label>
                                <InputText class="form-control esc-input" @bind-Value="_formulaEdit.FormulaNameEn" />
                            </div>

                            <div class="col-lg-6">
                                <label class="esc-label">@Text["반올림 방식|Rounding Method"]</label>
                                <DropdownSelect TItem="OptionItem<string>"
                                                DataSource="@_optRounding"
                                                Value="@(_optRounding.FirstOrDefault(x => x.Value == _formulaEdit.RoundingMethod))"
                                                ValueChanged="OnRoundingChanged"
                                                TextSelector="x => x.Text"
                                                Placeholder="@Text["반올림 방식 선택|Select Rounding"]"
                                                IconClass="fa-solid fa-divide"
                                                WrapperClass="w-100" />
                            </div>

                            <div class="col-lg-6">
                                <label class="esc-label">@Text["소수점 자릿수|Decimal Places"]</label>
                                <InputNumber class="form-control esc-input" @bind-Value="_formulaEdit.DecimalPlaces" />
                            </div>

                            <div class="col-12">
                                <label class="esc-label">@Text["설명|Description"]</label>
                                <InputTextArea class="form-control esc-input" rows="3" @bind-Value="_formulaEdit.Description" />
                            </div>
                        </div>

                        <div class="esc-option-grid">
                            <label class="esc-option-card">
                                <InputCheckbox @bind-Value="_formulaEdit.AllowNegativeResult" />
                                <span>@Text["음수 결과 허용|Allow Negative Result"]</span>
                            </label>

                            <label class="esc-option-card">
                                <InputCheckbox @bind-Value="_formulaEdit.IsActive" />
                                <span>@Text["활성화|Active"]</span>
                            </label>
                        </div>

                        <div class="esc-sticky-actions">
                            <button type="submit" class="btn esc-btn-success">
                                <i class="fa-solid fa-save"></i>
                                @Text["저장|Save"]
                            </button>

                            <button type="button" class="btn esc-btn-primary" @onclick="NextStep">
                                @Text["다음: 입력 필드|Next: Fields"]
                                <i class="fa-solid fa-arrow-right"></i>
                            </button>
                        </div>
                    </section>
                </EditForm>
            }
            else if (_currentStep == 2)
            {
                <section class="esc-card">
                    <div class="esc-card-header">
                        <div>
                            <h3>@Text["2. 입력 필드 설정|2. Input Field Settings"]</h3>
                            <p>@Text["계산식에서 사용할 변수와 입력 타입을 관리합니다.|Manage variables and input types used by the formula."]</p>
                        </div>

                        <button class="btn esc-btn-primary" @onclick="CreateField" disabled="@(_selectedFormula == null)">
                            <i class="fa-solid fa-plus"></i>
                            @Text["필드 추가|Add Field"]
                        </button>
                    </div>

                    @if (_selectedFormula == null)
                    {
                        <div class="esc-empty-state compact">
                            <i class="fa-solid fa-circle-info"></i>
                            <span>@Text["먼저 계산식을 저장하세요.|Please save the formula first."]</span>
                        </div>
                    }
                    else
                    {
                        <div class="esc-field-grid">
                            <div class="esc-field-table-wrap">
                                @if (_selectedFormula.Fields.Count == 0)
                                {
                                    <div class="esc-empty-state compact">
                                        <i class="fa-regular fa-folder-open"></i>
                                        <span>@Text["등록된 필드가 없습니다.|No fields found."]</span>
                                    </div>
                                }
                                else
                                {
                                    <table class="esc-table">
                                        <thead>
                                            <tr>
                                                <th>@Text["순서|Sort"]</th>
                                                <th>@Text["필드명|Field"]</th>
                                                <th>FieldKey</th>
                                                <th>@Text["타입|Type"]</th>
                                                <th>@Text["필수|Required"]</th>
                                                <th>@Text["사용|Use"]</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var field in _selectedFormula.Fields.OrderBy(x => x.SortOrder))
                                            {
                                                <tr class="@(field.Guid == _selectedFieldGuid ? "selected" : "")"
                                                    @onclick="() => SelectField(field)">
                                                    <td>@field.SortOrder</td>
                                                    <td>
                                                        <strong>@(Text.IsKorean ? field.LabelKo : field.LabelEn)</strong>
                                                        <small>@field.Unit</small>
                                                    </td>
                                                    <td><code>@field.FieldKey</code></td>
                                                    <td><span class="esc-field-type">@field.FieldType</span></td>
                                                    <td>@(field.IsRequired ? "Yes" : "No")</td>
                                                    <td>@(field.UseInFormula ? "Yes" : "No")</td>
                                                    <td>
                                                        <button class="btn esc-icon-danger"
                                                                @onclick:stopPropagation="true"
                                                                @onclick="() => DeleteFieldAsync(field.Guid)">
                                                            <i class="fa-solid fa-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            </div>

                            <div class="esc-field-editor">
                                <div class="esc-sub-card-title">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                    @Text["필드 편집|Field Editor"]
                                </div>

                                <EditForm Model="_fieldEdit" OnValidSubmit="SaveFieldAsync">
                                    <DataAnnotationsValidator />

                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label class="esc-label">FieldKey <b>*</b></label>
                                            <InputText class="form-control esc-input" @bind-Value="_fieldEdit.FieldKey" />
                                            <div class="esc-help">
                                                @Text["예: ContractAmount, AdjustmentRate|Example: ContractAmount, AdjustmentRate"]
                                            </div>
                                        </div>

                                        <div class="col-12">
                                            <label class="esc-label">@Text["필드 타입|Field Type"]</label>
                                            <DropdownSelect TItem="OptionItem<string>"
                                                            DataSource="@_optFieldTypes"
                                                            Value="@(_optFieldTypes.FirstOrDefault(x => x.Value == _fieldEdit.FieldType))"
                                                            ValueChanged="OnFieldTypeChanged"
                                                            TextSelector="x => x.Text"
                                                            Placeholder="@Text["필드 타입 선택|Select Field Type"]"
                                                            IconClass="fa-solid fa-list"
                                                            WrapperClass="w-100" />
                                        </div>

                                        <div class="col-md-6">
                                            <label class="esc-label">@Text["라벨(한국어)|Label Korean"]</label>
                                            <InputText class="form-control esc-input" @bind-Value="_fieldEdit.LabelKo" />
                                        </div>

                                        <div class="col-md-6">
                                            <label class="esc-label">@Text["라벨(영어)|Label English"]</label>
                                            <InputText class="form-control esc-input" @bind-Value="_fieldEdit.LabelEn" />
                                        </div>

                                        <div class="col-md-4">
                                            <label class="esc-label">@Text["기본값|Default"]</label>
                                            <InputText class="form-control esc-input" @bind-Value="_fieldEdit.DefaultValue" />
                                        </div>

                                        <div class="col-md-4">
                                            <label class="esc-label">@Text["단위|Unit"]</label>
                                            <InputText class="form-control esc-input" @bind-Value="_fieldEdit.Unit" />
                                        </div>

                                        <div class="col-md-4">
                                            <label class="esc-label">@Text["정렬|Sort"]</label>
                                            <InputNumber class="form-control esc-input" @bind-Value="_fieldEdit.SortOrder" />
                                        </div>

                                        <div class="col-md-6">
                                            <label class="esc-label">@Text["최소값|Min"]</label>
                                            <InputNumber class="form-control esc-input" @bind-Value="_fieldEdit.ValidationMin" />
                                        </div>

                                        <div class="col-md-6">
                                            <label class="esc-label">@Text["최대값|Max"]</label>
                                            <InputNumber class="form-control esc-input" @bind-Value="_fieldEdit.ValidationMax" />
                                        </div>
                                    </div>

                                    <div class="esc-option-grid mini">
                                        <label class="esc-option-card">
                                            <InputCheckbox @bind-Value="_fieldEdit.IsRequired" />
                                            <span>@Text["필수|Required"]</span>
                                        </label>

                                        <label class="esc-option-card">
                                            <InputCheckbox @bind-Value="_fieldEdit.IsReadonly" />
                                            <span>@Text["읽기 전용|Readonly"]</span>
                                        </label>

                                        <label class="esc-option-card">
                                            <InputCheckbox @bind-Value="_fieldEdit.UseInFormula" />
                                            <span>@Text["계산식 사용|Use In Formula"]</span>
                                        </label>
                                    </div>

                                    <div class="esc-inline-actions">
                                        <button type="submit" class="btn esc-btn-success w-100">
                                            <i class="fa-solid fa-save"></i>
                                            @Text["필드 저장|Save Field"]
                                        </button>
                                    </div>
                                </EditForm>

                                @if (_fieldEdit.FieldType == BasicCodes.EscFormulaFieldType.Select && _fieldEdit.Id > 0)
                                {
                                    <div class="esc-option-editor">
                                        <div class="esc-sub-card-title">
                                            <i class="fa-solid fa-square-check"></i>
                                            @Text["선택 옵션|Select Options"]
                                        </div>

                                        <div class="row g-2">
                                            <div class="col-6">
                                                <InputText class="form-control esc-input" placeholder="Value" @bind-Value="_optionEdit.OptionValue" />
                                            </div>
                                            <div class="col-6">
                                                <InputNumber class="form-control esc-input" placeholder="Sort" @bind-Value="_optionEdit.SortOrder" />
                                            </div>
                                            <div class="col-6">
                                                <InputText class="form-control esc-input" placeholder="Text Ko" @bind-Value="_optionEdit.OptionTextKo" />
                                            </div>
                                            <div class="col-6">
                                                <InputText class="form-control esc-input" placeholder="Text En" @bind-Value="_optionEdit.OptionTextEn" />
                                            </div>
                                            <div class="col-12">
                                                <button class="btn esc-btn-primary w-100" @onclick="SaveOptionAsync">
                                                    <i class="fa-solid fa-plus"></i>
                                                    @Text["옵션 저장|Save Option"]
                                                </button>
                                            </div>
                                        </div>

                                        <div class="esc-option-list">
                                            @foreach (var option in _fieldEdit.Options.OrderBy(x => x.SortOrder))
                                            {
                                                <div class="esc-option-row">
                                                    <div>
                                                        <strong>@option.OptionValue</strong>
                                                        <span>@option.OptionTextKo</span>
                                                        <small>@option.OptionTextEn</small>
                                                    </div>

                                                    <button class="btn esc-icon-danger" @onclick="() => DeleteOptionAsync(option.Guid)">
                                                        <i class="fa-solid fa-trash"></i>
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="esc-sticky-actions">
                            <button class="btn esc-btn-outline" @onclick="PrevStep">
                                <i class="fa-solid fa-arrow-left"></i>
                                @Text["이전|Previous"]
                            </button>

                            <button class="btn esc-btn-primary" @onclick="NextStep">
                                @Text["다음: 계산식 작성|Next: Expression"]
                                <i class="fa-solid fa-arrow-right"></i>
                            </button>
                        </div>
                    }
                </section>
            }
            else if (_currentStep == 3)
            {
                <EditForm Model="_formulaEdit" OnValidSubmit="SaveFormulaAsync">
                    <DataAnnotationsValidator />

                    <section class="esc-card">
                        <div class="esc-card-header">
                            <div>
                                <h3>@Text["3. 계산식 작성|3. Formula Expression"]</h3>
                                <p>@Text["입력 필드의 FieldKey를 사용하여 계산식을 작성합니다.|Build the formula by using FieldKeys from input fields."]</p>
                            </div>
                        </div>

                        <div class="esc-expression-layout">
                            <div>
                                <div class="esc-sub-card-title">
                                    <i class="fa-solid fa-cubes"></i>
                                    @Text["사용 가능한 변수|Available Variables"]
                                </div>

                                @if (_selectedFormula?.Fields.Count > 0)
                                {
                                    <div class="esc-variable-list">
                                        @foreach (var field in _selectedFormula.Fields.Where(x => x.UseInFormula).OrderBy(x => x.SortOrder))
                                        {
                                            <button type="button"
                                                    class="esc-variable-chip"
                                                    @onclick="() => InsertToken(field.FieldKey)">
                                                <strong>@field.FieldKey</strong>
                                                <span>@(Text.IsKorean ? field.LabelKo : field.LabelEn)</span>
                                            </button>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="esc-empty-state compact">
                                        @Text["먼저 입력 필드를 생성하세요.|Create fields first."]
                                    </div>
                                }

                                <div class="esc-sub-card-title mt-3">
                                    <i class="fa-solid fa-plus-minus"></i>
                                    @Text["빠른 연산자|Quick Operators"]
                                </div>

                                <div class="esc-operator-list">
                                    @foreach (var op in _operators)
                                    {
                                        <button type="button" class="esc-operator" @onclick="() => InsertToken(op)">
                                            @op
                                        </button>
                                    }
                                </div>
                            </div>

                            <div>
                                <label class="esc-label">@Text["계산식|Expression"]</label>
                                <InputTextArea class="form-control esc-expression"
                                               rows="8"
                                               spellcheck="false"
                                               @bind-Value="_formulaEdit.FormulaExpression" />

                                <div class="esc-preview-box">
                                    <div class="esc-sub-card-title">
                                        <i class="fa-solid fa-eye"></i>
                                        @Text["미리보기|Preview"]
                                    </div>
                                    <div class="esc-preview-expression">
                                        @PreviewExpression
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="esc-sticky-actions">
                            <button type="button" class="btn esc-btn-outline" @onclick="PrevStep">
                                <i class="fa-solid fa-arrow-left"></i>
                                @Text["이전|Previous"]
                            </button>

                            <button type="submit" class="btn esc-btn-success">
                                <i class="fa-solid fa-save"></i>
                                @Text["계산식 저장|Save Expression"]
                            </button>

                            <button type="button" class="btn esc-btn-primary" @onclick="NextStep">
                                @Text["다음: 테스트|Next: Test"]
                                <i class="fa-solid fa-arrow-right"></i>
                            </button>
                        </div>
                    </section>
                </EditForm>
            }
            else if (_currentStep == 4)
            {
                <section class="esc-card">
                    <div class="esc-card-header">
                        <div>
                            <h3>@Text["4. 테스트 및 적용|4. Test & Apply"]</h3>
                            <p>@Text["실제 값으로 계산식을 테스트하고 기본값으로 적용할 수 있습니다.|Test the formula with sample values and apply it as default."]</p>
                        </div>
                    </div>

                    @if (_selectedFormula?.Fields.Count > 0)
                    {
                        <div class="esc-test-layout">
                            <div class="esc-test-inputs">
                                <div class="esc-sub-card-title">
                                    <i class="fa-solid fa-keyboard"></i>
                                    @Text["테스트 입력값|Test Inputs"]
                                </div>

                                <div class="esc-test-grid">
                                    @foreach (var field in _selectedFormula.Fields.OrderBy(x => x.SortOrder))
                                    {
                                        <div>
                                            <label class="esc-label">
                                                @(Text.IsKorean ? field.LabelKo : field.LabelEn)
                                                @if (field.IsRequired)
                                                {
                                                    <b>*</b>
                                                }
                                            </label>

                                            @if (field.FieldType == BasicCodes.EscFormulaFieldType.Boolean)
                                            {
                                                <label class="esc-option-card single">
                                                    <input type="checkbox"
                                                           checked="@GetBoolTestValue(field.FieldKey)"
                                                          @onchange="e => SetTestValue(field.FieldKey, e.Value is bool checkedValue && checkedValue ? '1'.ToString() : '0'.ToString())" />
                                                    <span>@Text["사용|Use"]</span>
                                                </label>
                                            }
                                            else if (field.FieldType == BasicCodes.EscFormulaFieldType.Select)
                                            {
                                                <select class="form-select esc-input"
                                                        value="@GetTestValue(field.FieldKey)"
                                                        @onchange="e => SetTestValue(field.FieldKey, e.Value?.ToString() ?? string.Empty)">
                                                    <option value="">@Text["선택|Select"]</option>
                                                    @foreach (var option in field.Options.Where(x => x.IsActive).OrderBy(x => x.SortOrder))
                                                    {
                                                        <option value="@option.OptionValue">
                                                            @(Text.IsKorean ? option.OptionTextKo : option.OptionTextEn)
                                                        </option>
                                                    }
                                                </select>
                                            }
                                            else
                                            {
                                                <input class="form-control esc-input"
                                                       value="@GetTestValue(field.FieldKey)"
                                                       placeholder="@field.Placeholder"
                                                       @onchange="e => SetTestValue(field.FieldKey, e.Value?.ToString() ?? string.Empty)" />
                                            }

                                            @if (!string.IsNullOrWhiteSpace(field.Unit))
                                            {
                                                <div class="esc-help">@field.Unit</div>
                                            }
                                        </div>
                                    }
                                </div>

                                <button class="btn esc-btn-primary w-100 mt-3" @onclick="TestFormulaAsync">
                                    <i class="fa-solid fa-play"></i>
                                    @Text["계산 테스트|Test Formula"]
                                </button>
                            </div>

                            <div class="esc-test-result">
                                <div class="esc-sub-card-title">
                                    <i class="fa-solid fa-chart-simple"></i>
                                    @Text["결과|Result"]
                                </div>

                                <div class="esc-result-expression">
                                    @PreviewExpression
                                </div>

                                @if (_testResult.HasValue)
                                {
                                    <div class="esc-result-success">
                                        <span>@Text["계산 결과|Calculation Result"]</span>
                                        <strong>@_testResult.Value.ToString("N0")</strong>
                                    </div>
                                }
                                else
                                {
                                    <div class="esc-empty-state compact">
                                        <i class="fa-solid fa-vial"></i>
                                        <span>@Text["테스트를 실행하세요.|Run the test."]</span>
                                    </div>
                                }

                                <button class="btn esc-btn-success w-100"
                                        disabled="@(_selectedFormula == null || _selectedFormula.IsDefault || !_selectedFormula.IsActive)"
                                        @onclick="() => SetDefaultAsync(_selectedFormulaGuid ?? Guid.Empty)">
                                    <i class="fa-solid fa-star"></i>
                                    @Text["기본값으로 설정|Set as Default"]
                                </button>
                            </div>
                        </div>

                        <div class="esc-sticky-actions">
                            <button class="btn esc-btn-outline" @onclick="PrevStep">
                                <i class="fa-solid fa-arrow-left"></i>
                                @Text["이전|Previous"]
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="esc-empty-state compact">
                            <i class="fa-solid fa-circle-info"></i>
                            <span>@Text["테스트할 필드가 없습니다.|There are no fields to test."]</span>
                        </div>
                    }
                </section>
            }
        </main>
    </div>
</div>

