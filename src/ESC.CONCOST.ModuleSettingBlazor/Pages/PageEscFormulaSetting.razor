    private bool _showDeleteConfirm;

    private string? _message;
    private string _focusedInput = string.Empty;
    private string _activeTab = "basic";

    private FormulaTestResultDto? _testResults;

    private decimal _testAmount = 1_500_000m;
    private decimal _testTotalCost = 10_000_000m;
    private decimal _testBaseIndex = 100m;
    private decimal _testCompareIndex = 105.5m;
    private decimal _testContractAmount = 12_000_000m;
    private decimal _testExcludedAmount = 500_000m;
    private decimal _testAdvanceAmount = 1_000_000m;
    private decimal _testElapsedDays = 120m;

    private bool CanSetCurrent
    {
        get
        {
            if (_selectedFormula == null)
            {
                return false;
            }

            if (_selectedFormula.Guid == Guid.Empty)
            {
                return false;
            }

            if (_selectedFormula.IsCurrent)
            {
                return false;
            }

            if (!_selectedFormula.IsActive)
            {
                return false;
            }

            return true;
        }
    }

    private bool CanDeleteSelected
    {
        get
        {
            if (_selectedFormula == null)
            {
                return false;
            }

            if (_selectedFormula.Guid == Guid.Empty)
            {
                return false;
            }

            if (_selectedFormula.IsCurrent)
            {
                return false;
            }

            if (_selectedFormula.IsDefault)
            {
                return false;
            }

            if (!_selectedFormula.IsActive)
            {
                return false;
            }

            return true;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _message = null;

        try
        {
            _formulas = await FormulaService.GetListAsync();
            _variables = await FormulaService.GetVariablesAsync();

            _currentFormula = _formulas.FirstOrDefault(x => x.IsCurrent);

            if (_formulas.Count == 0)
            {
                _selectedFormula = null;
                _editModel = new EscFormulaSetting();
                _testResults = null;
                return;
            }

            var selectedGuid = _selectedFormula?.Guid ?? Guid.Empty;

            var selected =
                _formulas.FirstOrDefault(x => x.Guid == selectedGuid)
                ?? _currentFormula
                ?? _formulas.FirstOrDefault();

            if (selected != null)
            {
                SelectFormula(selected);
            }
        }
        catch
        {
            ShowMessage(false, Text["데이터를 불러오는 중 오류가 발생했습니다.|Error loading data."]);
        }
        finally
        {
            _loading = false;
        }
    }

    private void SelectFormula(EscFormulaSetting formula)
    {
        _selectedFormula = formula;
        _editModel = CloneFormula(formula);
        _testResults = null;
    }

    private void CreateFormula()
    {
        var nextVersion = _formulas.Count == 0
            ? 1
            : _formulas.Max(x => x.VersionNo) + 1;

        _selectedFormula = new EscFormulaSetting();

        _editModel = CreateDefaultFormula();
        _editModel.Id = 0;
        _editModel.Guid = Guid.Empty;
        _editModel.VersionNo = nextVersion;
        _editModel.FormulaCode = $"ESC_V{nextVersion}";
        _editModel.FormulaName = $"ESC 계산식 v{nextVersion}";
        _editModel.FormulaNameEn = $"ESC Formula v{nextVersion}";
        _editModel.IsCurrent = false;
        _editModel.IsDefault = false;
        _editModel.IsActive = true;

        _activeTab = "basic";
        _testResults = null;
        _message = null;
    }

    private void DuplicateFormula()
    {
        if (_selectedFormula == null)
        {
            return;
        }

        var source = CloneFormula(_editModel);

        source.Id = 0;
        source.Guid = Guid.Empty;
        source.FormulaCode = string.IsNullOrWhiteSpace(source.FormulaCode)
            ? "ESC_COPY"
            : source.FormulaCode.Trim() + "_COPY";

        source.FormulaName = string.IsNullOrWhiteSpace(source.FormulaName)
            ? "ESC 계산식 복사본"
            : source.FormulaName.Trim() + " 복사본";

        source.FormulaNameEn = string.IsNullOrWhiteSpace(source.FormulaNameEn)
            ? "ESC Formula Copy"
            : source.FormulaNameEn.Trim() + " Copy";

        source.IsCurrent = false;
        source.IsDefault = false;
        source.IsActive = true;
        source.VersionNo = source.VersionNo <= 0 ? 1 : source.VersionNo + 1;

        _selectedFormula = new EscFormulaSetting();
        _editModel = source;
        _activeTab = "basic";
        _testResults = null;

        ShowMessage(true, Text["복사본이 생성되었습니다. 저장해야 목록에 반영됩니다.|A copy has been created. Save it to apply to the list."]);
    }

    private async Task SaveFormulaAsync()
    {
        NormalizeEditModelBeforeSave();

        var result = await FormulaService.SaveAsync(_editModel, "Saved via UI");

        if (!result.Success)
        {
            ShowMessage(false, result.Message);
            return;
        }

        ShowMessage(true, result.Message);

        var savedCode = _editModel.FormulaCode;

        await LoadAsync();

        var saved = _formulas.FirstOrDefault(x => x.FormulaCode == savedCode);

        if (saved != null)
        {
            SelectFormula(saved);
        }
    }

    private async Task SetCurrentSelectedAsync()
    {
        if (_selectedFormula == null)
        {
            return;
        }

        if (_selectedFormula.Guid == Guid.Empty)
        {
            return;
        }

        var result = await FormulaService.SetCurrentAsync(_selectedFormula.Guid);

        if (!result.Success)
        {
            ShowMessage(false, result.Message);
            return;
        }

        ShowMessage(true, result.Message);

        await LoadAsync();
    }

    private void OpenDeleteConfirm()
    {
        if (!CanDeleteSelected)
        {
            ShowMessage(false, Text["현재 사용 중이거나 기본 계산식은 삭제할 수 없습니다.|Current or default formula cannot be deleted."]);
            return;
        }

        _showDeleteConfirm = true;
    }

    private void CloseDeleteConfirm()
    {
        _showDeleteConfirm = false;
    }

    private async Task DeleteFormulaAsync()
    {
        if (!CanDeleteSelected || _selectedFormula == null)
        {
            CloseDeleteConfirm();
            ShowMessage(false, Text["삭제할 수 없는 계산식입니다.|This formula cannot be deleted."]);
            return;
        }

        var result = await FormulaService.DeleteAsync(_selectedFormula.Guid, "Deleted via UI");

        if (!result.Success)
        {
            ShowMessage(false, result.Message);
            return;
        }

        _showDeleteConfirm = false;

        ShowMessage(true, result.Message);

        await LoadAsync();
    }

    private async Task TestFormulaAsync()
    {
        var mockVars = new FormulaTestInputDto()
        {
            Amount = _testAmount,
            TotalCost = _testTotalCost,
            BaseIndex = _testBaseIndex,
            CompareIndex = _testCompareIndex,
            ContractAmount = _testContractAmount,
            ExcludedAmount = _testExcludedAmount,
            AdvanceAmount = _testAdvanceAmount,
            OtherDeduction = _editModel.OtherDeductionDefault,
            ElapsedDays = _testElapsedDays,
        };

        var result = await FormulaService.TestFormulaAsync(_editModel, mockVars);

        if (result.Success && result.Item != null)
        {
            _testResults = result.Item;
            ShowMessage(true, Text["테스트 계산이 완료되었습니다.|Test calculation completed."]);
        }
        else
        {
            _testResults = null;
            ShowMessage(false, result.Message);
        }
    }

    private void InsertToken(string token)
    {
        if (string.IsNullOrWhiteSpace(_focusedInput))
        {
            ShowMessage(false, Text["먼저 수식 입력칸을 클릭하세요.|Please click a formula input first."]);
            return;
        }

        var prop = typeof(EscFormulaSetting).GetProperty(_focusedInput);

        if (prop == null || prop.PropertyType != typeof(string))
        {
            return;
        }

        var currentValue = prop.GetValue(_editModel) as string ?? string.Empty;

        if (!string.IsNullOrWhiteSpace(currentValue) && !currentValue.EndsWith(" "))
        {
            currentValue += " ";
        }

        prop.SetValue(_editModel, currentValue + token);

        StateHasChanged();
    }

    private void SetFocusedInput(string inputName)
    {
        _focusedInput = inputName;
    }

    private void SetTab(string tab)
    {
        _activeTab = tab;
    }

    private string GetTabClass(string tab)
    {
        return _activeTab == tab ? "active" : string.Empty;
    }

    private string GetFormulaDisplayName(EscFormulaSetting formula)
    {
        if (Text.IsKorean)
        {
            return string.IsNullOrWhiteSpace(formula.FormulaName)
                ? formula.FormulaCode
                : formula.FormulaName;
        }

        return string.IsNullOrWhiteSpace(formula.FormulaNameEn)
            ? formula.FormulaName
            : formula.FormulaNameEn;
    }

    private string GetFormulaAdminDescription(EscFormulaSetting formula)
    {
        if (formula.IsCurrent)
        {
            return Text["현재 모든 사용자 계산에 적용 중입니다.|Currently applied to all user calculations."];
        }

        if (!formula.IsActive)
        {
            return Text["삭제 또는 비활성 처리된 계산식입니다.|Deleted or inactive formula."];
        }

        return Text["저장되어 있지만 아직 사용자 계산에 적용되지 않았습니다.|Saved but not applied to user calculations yet."];
    }

    private string GetStatusClass()
    {
        if (_editModel.IsCurrent)
        {
            return "current";
        }

        if (!_editModel.IsActive)
        {
            return "inactive";
        }

        return "ready";
    }

    private string GetStatusTitle()
    {
        if (_editModel.IsCurrent)
        {
            return Text["현재 적용 중인 계산식|Currently Applied Formula"];
        }

        if (!_editModel.IsActive)
        {
            return Text["비활성 계산식|Inactive Formula"];
        }

        return Text["저장 가능한 계산식|Editable Formula"];
    }

    private string GetStatusDescription()
    {
        if (_editModel.IsCurrent)
        {
            return Text["이 계산식은 현재 모든 사용자 계산에 자동 적용됩니다.|This formula is automatically applied to all user calculations."];
        }

        if (!_editModel.IsActive)
        {
            return Text["이 계산식은 사용자 계산에 사용되지 않습니다.|This formula is not used for user calculations."];
        }

        return Text["저장 후 현재 계산식으로 설정하면 사용자 계산에 적용됩니다.|After saving, set it as current to apply it to user calculations."];
    }

    private void NormalizeEditModelBeforeSave()
    {
        _editModel.FormulaCode = _editModel.FormulaCode?.Trim() ?? string.Empty;
        _editModel.FormulaName = _editModel.FormulaName?.Trim() ?? string.Empty;
        _editModel.FormulaNameEn = _editModel.FormulaNameEn?.Trim() ?? string.Empty;

        _editModel.WeightFormula = _editModel.WeightFormula?.Trim() ?? string.Empty;
        _editModel.IndexRatioFormula = _editModel.IndexRatioFormula?.Trim() ?? string.Empty;
        _editModel.WeightedRatioFormula = _editModel.WeightedRatioFormula?.Trim() ?? string.Empty;
        _editModel.CompositeFormula = _editModel.CompositeFormula?.Trim() ?? string.Empty;
        _editModel.AdjustmentRateFormula = _editModel.AdjustmentRateFormula?.Trim() ?? string.Empty;
        _editModel.ApplicableAmountFormula = _editModel.ApplicableAmountFormula?.Trim() ?? string.Empty;
        _editModel.GrossAdjustmentFormula = _editModel.GrossAdjustmentFormula?.Trim() ?? string.Empty;
        _editModel.AdvanceDeductionFormula = _editModel.AdvanceDeductionFormula?.Trim() ?? string.Empty;
        _editModel.FinalAdjustmentFormula = _editModel.FinalAdjustmentFormula?.Trim() ?? string.Empty;
        _editModel.EligibleConditionFormula = _editModel.EligibleConditionFormula?.Trim() ?? string.Empty;

        if (_editModel.VersionNo <= 0)
        {
            _editModel.VersionNo = 1;
        }

        if (_editModel.ThresholdRate <= 0)
        {
            _editModel.ThresholdRate = 3m;
        }

        if (_editModel.ThresholdDays <= 0)
        {
            _editModel.ThresholdDays = 90;
        }

        if (_editModel.DecimalPlaces < 0)
        {
            _editModel.DecimalPlaces = 0;
        }

        if (string.IsNullOrWhiteSpace(_editModel.RoundingMethod))
        {
            _editModel.RoundingMethod = BasicCodes.EscFormulaRounding.Round;
        }
    }

    private static EscFormulaSetting CloneFormula(EscFormulaSetting formula)
    {
        return new EscFormulaSetting
        {
            Id = formula.Id,
            Guid = formula.Guid,

            FormulaCode = formula.FormulaCode,
            FormulaName = formula.FormulaName,
            FormulaNameEn = formula.FormulaNameEn,
            VersionNo = formula.VersionNo,

            WeightFormula = formula.WeightFormula,
            IndexRatioFormula = formula.IndexRatioFormula,
            WeightedRatioFormula = formula.WeightedRatioFormula,
            CompositeFormula = formula.CompositeFormula,
            AdjustmentRateFormula = formula.AdjustmentRateFormula,
            ApplicableAmountFormula = formula.ApplicableAmountFormula,
            GrossAdjustmentFormula = formula.GrossAdjustmentFormula,
            AdvanceDeductionFormula = formula.AdvanceDeductionFormula,
            FinalAdjustmentFormula = formula.FinalAdjustmentFormula,
            EligibleConditionFormula = formula.EligibleConditionFormula,

            ThresholdRate = formula.ThresholdRate,
            ThresholdDays = formula.ThresholdDays,
            RoundingMethod = formula.RoundingMethod,
            DecimalPlaces = formula.DecimalPlaces,
            UseAdvanceDeduction = formula.UseAdvanceDeduction,
            OtherDeductionDefault = formula.OtherDeductionDefault,

            IsDefault = formula.IsDefault,
            IsActive = formula.IsActive,
            IsCurrent = formula.IsCurrent,
            SortOrder = formula.SortOrder,
            Description = formula.Description
        };
    }

