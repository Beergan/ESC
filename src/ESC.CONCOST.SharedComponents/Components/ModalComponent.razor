@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@inject ITextTranslator Text

@if (_isVisible)
{
    <div class="modal-backdrop @(_isRendered ? "show" : "")"
         @onclick="HandleBackdropClick">
    </div>

    <div class="modal @(_isRendered ? "show" : "") @(Centered ? "modal-centered" : "")"
         tabindex="-1"
         role="dialog"
         aria-modal="true">
        <div class="modal-dialog @SizeClass @(Scrollable ? "modal-dialog-scrollable" : "")"
             role="document"
             @onclick:stopPropagation="true">
            <div class="modal-content">
                @if (ShowHeader)
                {
                    <div class="modal-header @HeaderClass">
                        <h5 class="modal-title">
                            @if (!string.IsNullOrWhiteSpace(Icon))
                            {
                                <i class="@Icon me-2"></i>
                            }

                            @Title
                        </h5>

                        @if (ShowCloseButton)
                        {
                            <button type="button"
                                    class="btn-close"
                                    aria-label="Close"
                                    @onclick="Close">
                            </button>
                        }
                    </div>
                }

                <div class="modal-body @BodyClass">
                    @ChildContent
                </div>

                @if (ShowFooter)
                {
                    <div class="modal-footer @FooterClass">
                        @if (ShowCancelButton)
                        {
                            <button type="button"
                                    class="btn @CancelButtonClass"
                                    disabled="@IsSubmitting"
                                    @onclick="Cancel">
                                @if (!string.IsNullOrWhiteSpace(CancelButtonIcon))
                                {
                                    <i class="@CancelButtonIcon"></i>
                                }

                                @CancelButtonText
                            </button>
                        }

                        @if (ShowConfirmButton)
                        {
                            <button type="button"
                                    class="btn @ConfirmButtonClass"
                                    disabled="@(IsSubmitting || DisableConfirm)"
                                    @onclick="Confirm">
                                @if (IsSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else if (!string.IsNullOrWhiteSpace(ConfirmButtonIcon))
                                {
                                    <i class="@ConfirmButtonIcon"></i>
                                }

                                @ConfirmButtonText
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    .modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 1040;
        width: 100vw;
        height: 100vh;
        background: rgba(15, 23, 42, 0.58);
        backdrop-filter: blur(3px);
        opacity: 0;
        transition: opacity 0.18s ease;
    }

        .modal-backdrop.show {
            opacity: 1;
        }

    .modal {
        position: fixed;
        inset: 0;
        z-index: 1050;
        width: 100%;
        height: 100%;
        overflow-x: hidden;
        overflow-y: auto;
        outline: 0;
        opacity: 0;
        transition: opacity 0.18s ease;
        padding: 24px 12px;
    }

        .modal.show {
            opacity: 1;
        }

        .modal.modal-centered {
            display: flex !important;
            align-items: center;
            justify-content: center;
        }

    .modal-dialog {
        position: relative;
        width: auto;
        margin: 1.75rem auto;
        max-width: 560px;
        pointer-events: none;
        transform: translateY(18px) scale(.98);
        transition: transform 0.22s ease, opacity 0.22s ease;
        opacity: 0;
    }

    .modal.show .modal-dialog {
        transform: translateY(0) scale(1);
        opacity: 1;
    }

    .modal-centered .modal-dialog {
        margin: 0;
    }

    .modal-content {
        position: relative;
        display: flex;
        flex-direction: column;
        width: 100%;
        pointer-events: auto;
        background: #ffffff;
        background-clip: padding-box;
        border: 1px solid rgba(226, 232, 240, .95);
        border-radius: 26px;
        outline: 0;
        box-shadow: 0 28px 80px rgba(15, 23, 42, .28);
        overflow: visible;
    }

    .modal-header {
        display: flex;
        flex-shrink: 0;
        align-items: center;
        justify-content: space-between;
        padding: 22px 32px;
        border-bottom: 1px solid #eef2f7;
        border-top-left-radius: 26px;
        border-top-right-radius: 26px;
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    }

    .modal-title {
        margin: 0;
        line-height: 1.35;
        font-weight: 900;
        font-size: 20px;
        color: #12345a;
        letter-spacing: -0.02em;
        display: flex;
        align-items: center;
    }

        .modal-title i {
            color: #12345a;
        }

    .modal-body {
        position: relative;
        flex: 1 1 auto;
        padding: 28px 32px;
        overflow: visible;
        background: #ffffff;
    }

    .modal-footer {
        display: flex;
        flex-wrap: wrap;
        flex-shrink: 0;
        align-items: center;
        justify-content: flex-end;
        padding: 18px 32px 24px;
        border-top: 1px solid #eef2f7;
        border-bottom-right-radius: 26px;
        border-bottom-left-radius: 26px;
        gap: 10px;
        background: #fbfdff;
    }

    .btn-close {
        box-sizing: border-box;
        width: 34px;
        height: 34px;
        padding: 0;
        border: 0;
        border-radius: 10px;
        opacity: 1;
        cursor: pointer;
        transition: background .16s ease, color .16s ease, transform .16s ease;
        background: transparent;
        color: #64748b;
        position: relative;
    }

        .btn-close::before,
        .btn-close::after {
            content: "";
            position: absolute;
            top: 50%;
            left: 50%;
            width: 15px;
            height: 2px;
            border-radius: 2px;
            background: currentColor;
        }

        .btn-close::before {
            transform: translate(-50%, -50%) rotate(45deg);
        }

        .btn-close::after {
            transform: translate(-50%, -50%) rotate(-45deg);
        }

        .btn-close:hover {
            background: #f1f5f9;
            color: #12345a;
            transform: rotate(90deg);
        }

        .btn-close:focus {
            outline: 0;
            box-shadow: 0 0 0 3px rgba(18, 52, 90, .14);
        }

    .modal-footer .btn {
        min-width: 112px;
        height: 42px;
        border-radius: 12px;
        font-weight: 800;
        font-size: 14px;
        padding: 0 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: transform .15s ease, box-shadow .15s ease, background .15s ease;
    }

        .modal-footer .btn:hover {
            transform: translateY(-1px);
        }

    .modal-footer .btn-primary {
        background: #12345a;
        border-color: #12345a;
        color: #ffffff;
        box-shadow: 0 10px 22px rgba(18, 52, 90, .22);
    }

        .modal-footer .btn-primary:hover {
            background: #0f2b4a;
            border-color: #0f2b4a;
        }

    .modal-footer .btn-secondary {
        background: #eef3f8;
        border-color: #eef3f8;
        color: #31445c;
    }

        .modal-footer .btn-secondary:hover {
            background: #e2eaf3;
            border-color: #e2eaf3;
            color: #12345a;
        }

    .modal-footer .btn-danger {
        background: #dc3545;
        border-color: #dc3545;
        color: #ffffff;
        box-shadow: 0 10px 22px rgba(220, 53, 69, .18);
    }

    .modal-footer .btn-success {
        background: #12805c;
        border-color: #12805c;
        color: #ffffff;
        box-shadow: 0 10px 22px rgba(18, 128, 92, .18);
    }

    .modal-footer .btn:disabled {
        opacity: .65;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .modal-dialog-scrollable {
        max-height: calc(100vh - 3.5rem);
        display: flex;
        flex-direction: column;
    }

        .modal-dialog-scrollable .modal-content {
            max-height: calc(100vh - 3.5rem);
            overflow: visible;
        }

        .modal-dialog-scrollable .modal-body {
            overflow-y: auto;
            overflow-x: visible;
        }

    .modal-sm .modal-dialog {
        max-width: 380px;
    }

    .modal-default .modal-dialog {
        max-width: 560px;
    }

    .modal-lg .modal-dialog {
        max-width: 820px;
    }

    .modal-xl .modal-dialog {
        max-width: 1140px;
    }

    .modal-fullscreen .modal-dialog {
        width: 100vw;
        max-width: none;
        height: 100vh;
        margin: 0;
    }

    .modal-fullscreen .modal-content {
        height: 100vh;
        border: 0;
        border-radius: 0;
    }

    .modal-header.bg-primary,
    .modal-header.bg-dark {
        background: #12345a !important;
        color: #ffffff;
        border-bottom: none;
    }

        .modal-header.bg-primary .modal-title,
        .modal-header.bg-dark .modal-title {
            color: #ffffff;
        }

            .modal-header.bg-primary .modal-title i,
            .modal-header.bg-dark .modal-title i {
                color: #ffffff;
            }

        .modal-header.bg-primary .btn-close,
        .modal-header.bg-dark .btn-close {
            color: #ffffff;
        }

    .modal-header.bg-success {
        background: #12805c !important;
        color: #ffffff;
        border-bottom: none;
    }

        .modal-header.bg-success .modal-title,
        .modal-header.bg-success .modal-title i {
            color: #ffffff;
        }

    .modal-header.bg-danger {
        background: #dc3545 !important;
        color: #ffffff;
        border-bottom: none;
    }

        .modal-header.bg-danger .modal-title,
        .modal-header.bg-danger .modal-title i {
            color: #ffffff;
        }

    .modal-header.bg-warning {
        background: #fff7e6 !important;
        color: #7a4d00;
        border-bottom: 1px solid #ffe1a8;
    }

    .modal-header.bg-info {
        background: #e8f6ff !important;
        color: #12345a;
        border-bottom: 1px solid #ccecff;
    }

    .spinner-border {
        display: inline-block;
        width: 1rem;
        height: 1rem;
        vertical-align: -0.125em;
        border: 0.15em solid currentColor;
        border-right-color: transparent;
        border-radius: 50%;
        animation: spinner-border 0.75s linear infinite;
    }

    .spinner-border-sm {
        width: 0.875rem;
        height: 0.875rem;
        border-width: 0.125em;
    }

    @@keyframes spinner-border {
        to {
            transform: rotate(360deg);
        }
    }

    @@media (max-width: 576px) {
        .modal {
            padding: 10px;
        }

        .modal-dialog {
            margin: 0.5rem;
            max-width: calc(100% - 1rem);
        }

        .modal-header {
            padding: 18px 20px;
            border-top-left-radius: 20px;
            border-top-right-radius: 20px;
        }

        .modal-title {
            font-size: 18px;
        }

        .modal-body {
            padding: 22px 20px;
        }

        .modal-footer {
            padding: 16px 20px 20px;
            flex-direction: column-reverse;
            align-items: stretch;
        }

            .modal-footer .btn {
                width: 100%;
            }

        .modal-content {
            border-radius: 20px;
        }
    }
</style>

@code {
    public enum ModalSize
    {
        Small,
        Default,
        Large,
        ExtraLarge,
        FullScreen
    }

    [Parameter] public string Title { get; set; } = string.Empty;

    [Parameter] public string? Icon { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public EventCallback OnConfirm { get; set; }

    [Parameter] public EventCallback OnCancel { get; set; }

    [Parameter] public EventCallback OnClose { get; set; }

    [Parameter] public string ConfirmButtonText { get; set; } = string.Empty;

    [Parameter] public string CancelButtonText { get; set; } = string.Empty;

    [Parameter] public string ConfirmButtonIcon { get; set; } = "fa-solid fa-check";

    [Parameter] public string CancelButtonIcon { get; set; } = "fa-solid fa-xmark";

    [Parameter] public string ConfirmButtonClass { get; set; } = "btn-primary";

    [Parameter] public string CancelButtonClass { get; set; } = "btn-secondary";

    [Parameter] public bool ShowHeader { get; set; } = true;

    [Parameter] public bool ShowFooter { get; set; } = true;

    [Parameter] public bool ShowCloseButton { get; set; } = true;

    [Parameter] public bool ShowConfirmButton { get; set; } = true;

    [Parameter] public bool ShowCancelButton { get; set; } = true;

    [Parameter] public bool CloseOnBackdropClick { get; set; } = false;

    [Parameter] public bool Centered { get; set; } = true;

    [Parameter] public bool Scrollable { get; set; } = false;

    [Parameter] public bool IsSubmitting { get; set; } = false;

    [Parameter] public bool DisableConfirm { get; set; } = false;

    [Parameter] public ModalSize Size { get; set; } = ModalSize.Default;

    [Parameter] public string HeaderClass { get; set; } = string.Empty;

    [Parameter] public string BodyClass { get; set; } = string.Empty;

    [Parameter] public string FooterClass { get; set; } = string.Empty;

    private bool _isVisible;
    private bool _isRendered;

    private string SizeClass
    {
        get
        {
            return Size switch
            {
                ModalSize.Small => "modal-sm",
                ModalSize.Large => "modal-lg",
                ModalSize.ExtraLarge => "modal-xl",
                ModalSize.FullScreen => "modal-fullscreen",
                _ => "modal-default"
            };
        }
    }

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(ConfirmButtonText))
        {
            ConfirmButtonText = Text["확인|Confirm"];
        }

        if (string.IsNullOrWhiteSpace(CancelButtonText))
        {
            CancelButtonText = Text["취소|Cancel"];
        }
    }

    public async Task Show()
    {
        _isVisible = true;
        _isRendered = false;

        StateHasChanged();

        await Task.Delay(20);

        _isRendered = true;

        await LockBodyScroll();

        StateHasChanged();
    }

    public async Task Close()
    {
        _isRendered = false;

        StateHasChanged();

        await Task.Delay(160);

        _isVisible = false;

        await UnlockBodyScroll();

        if (OnClose.HasDelegate)
        {
            await OnClose.InvokeAsync();
        }

        StateHasChanged();
    }

    private async Task Confirm()
    {
        if (DisableConfirm || IsSubmitting)
        {
            return;
        }

        if (OnConfirm.HasDelegate)
        {
            await OnConfirm.InvokeAsync();
        }
        else
        {
            await Close();
        }
    }

    private async Task Cancel()
    {
        if (IsSubmitting)
        {
            return;
        }

        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }

        await Close();
    }

    private async Task HandleBackdropClick()
    {
        if (!CloseOnBackdropClick || IsSubmitting)
        {
            return;
        }

        await Close();
    }

    private async Task LockBodyScroll()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow='hidden';");
        }
        catch
        {
            // Ignore JS error during prerender/disconnect
        }
    }

    private async Task UnlockBodyScroll()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow='';");
        }
        catch
        {
            // Ignore JS error during prerender/disconnect
        }
    }
}