@inject ITextTranslator Text

<div class="icon-picker-wrapper @WrapperClass">
    <div class="icon-picker-trigger @(_isOpen ? "open" : "")" @onclick="Toggle">
        <div class="current-icon">
            <i class="@(string.IsNullOrWhiteSpace(Value) ? DefaultIcon : Value)"></i>
        </div>
        <div class="icon-info">
            <span class="icon-name">@(string.IsNullOrWhiteSpace(Value) ? Text["아이콘 선택|Select Icon"] : Value.Replace("fa-solid fa-", ""))</span>
        </div>
        <i class="fa-solid fa-chevron-down chevron @(_isOpen ? "open" : "")"></i>
    </div>

    @if (_isOpen)
    {
        <div class="icon-picker-dropdown">
            <div class="icon-grid">
                @foreach (var icon in _commonIcons)
                {
                    <div class="icon-item @(Value == icon ? "active" : "")" @onclick="() => SelectIcon(icon)" title="@icon">
                        <i class="@icon"></i>
                    </div>
                }
            </div>
            
            <div class="custom-icon-input">
                <input type="text" 
                       class="esc-input-sm" 
                       placeholder="@Text["직접 입력 (FontAwesome)|Custom class"]" 
                       value="@Value" 
                       @onchange="OnCustomInputChange" />
            </div>
        </div>
    }
</div>

<style>
    .icon-picker-wrapper { position: relative; width: 100%; }
    .icon-picker-trigger { 
        display: flex; align-items: center; gap: 10px; padding: 8px 12px; 
        background: #fff; border: 1px solid #cfdae8; border-radius: 12px; 
        cursor: pointer; transition: .2s; height: 42px;
    }
    .icon-picker-trigger:hover { border-color: #12345a; background: #f8fbff; }
    .icon-picker-trigger.open { border-color: #12345a; box-shadow: 0 0 0 3px rgba(18, 52, 90, .1); }
    
    .current-icon { 
        width: 26px; height: 26px; border-radius: 8px; background: #eef6ff; 
        display: grid; place-items: center; color: #12345a; font-size: 14px;
    }
    .icon-info { flex: 1; overflow: hidden; }
    .icon-name { font-size: 13px; color: #334155; white-space: nowrap; text-overflow: ellipsis; display: block; }
    .chevron { font-size: 11px; color: #94a3b8; transition: .2s; }
    .chevron.open { transform: rotate(180deg); color: #12345a; }

    .icon-picker-dropdown { 
        position: absolute; top: calc(100% + 6px); left: 0; right: 0; 
        background: #fff; border: 1px solid #e2e8f0; border-radius: 16px; 
        box-shadow: 0 10px 25px rgba(0,0,0,.1); z-index: 2100; padding: 12px;
        animation: slideIn .15s ease-out;
    }
    
    .icon-grid { 
        display: grid; grid-template-columns: repeat(auto-fill, minmax(36px, 1fr)); 
        gap: 6px; margin-bottom: 10px; max-height: 180px; overflow-y: auto; padding: 2px;
    }
    .icon-item { 
        height: 36px; border-radius: 8px; border: 1px solid #f1f5f9; 
        display: grid; place-items: center; cursor: pointer; color: #64748b; transition: .15s;
    }
    .icon-item:hover { background: #f1f5f9; color: #12345a; border-color: #cbd5e1; }
    .icon-item.active { background: #12345a; color: #fff; border-color: #12345a; }
    
    .custom-icon-input { border-top: 1px solid #f1f5f9; padding-top: 10px; }
    .esc-input-sm { 
        width: 100%; border: 1px solid #e2e8f0; border-radius: 8px; 
        padding: 6px 10px; font-size: 11px; outline: 0; background: #f8fafc;
    }
    .esc-input-sm:focus { border-color: #12345a; background: #fff; }

    @@keyframes slideIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string WrapperClass { get; set; } = string.Empty;
    [Parameter] public string DefaultIcon { get; set; } = "fa-solid fa-layer-group";

    private bool _isOpen;

    private readonly string[] _commonIcons = new[]
    {
        "fa-solid fa-layer-group",
        "fa-solid fa-users",
        "fa-solid fa-hard-drive",
        "fa-solid fa-screwdriver-wrench",
        "fa-solid fa-cube",
        "fa-solid fa-truck",
        "fa-solid fa-building",
        "fa-solid fa-helmet-safety",
        "fa-solid fa-coins",
        "fa-solid fa-chart-line",
        "fa-solid fa-briefcase",
        "fa-solid fa-oil-can",
        "fa-solid fa-bolt",
        "fa-solid fa-gear",
        "fa-solid fa-wrench",
        "fa-solid fa-hammer",
        "fa-solid fa-box",
        "fa-solid fa-boxes-stacked",
        "fa-solid fa-warehouse",
        "fa-solid fa-flask",
        "fa-solid fa-microchip",
        "fa-solid fa-plug",
        "fa-solid fa-droplet",
        "fa-solid fa-fire",
        "fa-solid fa-leaf",
        "fa-solid fa-wheat-awn",
        "fa-solid fa-industry",
        "fa-solid fa-bridge",
        "fa-solid fa-road"
    };

    private void Toggle() => _isOpen = !_isOpen;

    private async Task SelectIcon(string icon)
    {
        Value = icon;
        _isOpen = false;
        await ValueChanged.InvokeAsync(icon);
    }

    private async Task OnCustomInputChange(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        Value = val;
        await ValueChanged.InvokeAsync(val);
    }
}
